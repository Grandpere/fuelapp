# Local secrets/overrides for docker compose (not committed)
# Copy to resources/docker/.env.local and adjust values.

# Keep non-sensitive defaults from resources/docker/.env and override only secrets here.

SIGNOZ_JWT_SECRET=ChangeMeToAtLeast32CharsForSigNozJwt
SIGNOZ_TOKENIZER_JWT_SECRET=ChangeMeToAtLeast32CharsForSigNozJwt
MERCURE_JWT_SECRET=ChangeMeToAtLeast32CharsMercureKey

# Optional: override exposed ports locally if needed
# SIGNOZ_PORT=3301
# SIGNOZ_OTLP_GRPC_PORT=14317
# SIGNOZ_OTLP_HTTP_PORT=14318
