{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.audit.title'|trans }}{% endblock %}

{% set admin_section = 'audit' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">{{ 'admin.audit.title'|trans }}</h2>
            <p class="muted">{{ 'admin.audit.lead'|trans }}</p>
        </div>
    </section>

    {% if supportShortcuts is not empty %}
        <section class="card admin-panel admin-section-spaced">
            <div class="admin-page-head">
                <div class="admin-page-header">
                    <strong>{{ 'admin.audit.continuity_title'|trans }}</strong>
                    <p class="muted compact-note">{{ 'admin.audit.continuity_lead'|trans }}</p>
                </div>
                <div class="actions-wrap">
                    {% for item in supportShortcuts %}
                        <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {% if activeFilterSummary is not empty %}
        <section class="card admin-panel admin-section-spaced">
            <div class="admin-page-head">
                <div class="admin-page-header">
                    <strong>{{ 'admin.common.active_filters'|trans }}</strong>
                    <p class="muted compact-note">
                        {% for item in activeFilterSummary %}
                            {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                        {% endfor %}
                    </p>
                </div>
                <div class="admin-page-actions">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_audit_log_list') }}">{{ 'action.reset'|trans }}</a>
                </div>
            </div>
        </section>
    {% endif %}

    <section class="card admin-panel admin-section-spaced">
        <h3 class="section-title">{{ 'admin.audit.filters_title'|trans }}</h3>
        <form method="get" class="admin-filters-form">
            <div class="form-grid-2">
                <label class="label">
                    {{ 'admin.audit.filters.action'|trans }}
                    <input class="input" type="text" name="action" value="{{ filters.action ?? '' }}" placeholder="{{ 'admin.audit.filters.action_placeholder'|trans }}">
                </label>
                <label class="label">
                    {{ 'admin.audit.filters.actor'|trans }}
                    <select class="select" name="actorId">
                        <option value="">{{ 'admin.audit.filters.all_actors'|trans }}</option>
                        {% for actor in actorOptions %}
                            <option value="{{ actor.id }}" {% if filters.actorId == actor.id %}selected{% endif %}>{{ actor.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    {{ 'admin.audit.filters.target_type'|trans }}
                    <input class="input" type="text" name="targetType" value="{{ filters.targetType ?? '' }}" placeholder="{{ 'admin.audit.filters.target_type_placeholder'|trans }}">
                </label>
                <label class="label">
                    {{ 'admin.audit.filters.target_id'|trans }}
                    <input class="input" type="text" name="targetId" value="{{ filters.targetId ?? '' }}" placeholder="{{ 'admin.audit.filters.target_id_placeholder'|trans }}">
                </label>
                <label class="label">
                    {{ 'admin.audit.filters.correlation_id'|trans }}
                    <input class="input" type="text" name="correlationId" value="{{ filters.correlationId ?? '' }}" placeholder="{{ 'admin.audit.filters.correlation_id_placeholder'|trans }}">
                </label>
                <label class="label">
                    {{ 'admin.audit.filters.from_date'|trans }}
                    <input class="input" type="text" name="from" value="{{ filters.from ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
                <label class="label">
                    {{ 'admin.audit.filters.to_date'|trans }}
                    <input class="input" type="text" name="to" value="{{ filters.to ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
            </div>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">{{ 'admin.audit.apply_filters'|trans }}</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_audit_log_list') }}">{{ 'action.reset'|trans }}</a>
            </div>
        </form>
    </section>

    <section class="card admin-panel admin-section-spaced">
        <div class="table-wrap table-min-1150">
            <table class="app-table">
                <thead>
                <tr>
                    <th>{{ 'admin.audit.table.created'|trans }}</th>
                    <th>{{ 'admin.audit.table.action'|trans }}</th>
                    <th>{{ 'admin.audit.table.actor'|trans }}</th>
                    <th>{{ 'admin.audit.table.target'|trans }}</th>
                    <th>{{ 'admin.audit.table.correlation_id'|trans }}</th>
                    <th>{{ 'admin.audit.table.diff_summary'|trans }}</th>
                    <th>{{ 'common.actions'|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for entry in entries %}
                    <tr class="table-row">
                        <td>{{ entry.entry.createdAt|date('Y-m-d H:i:s') }}</td>
                        <td>{{ entry.entry.action }}</td>
                        <td>
                            <div>{{ entry.entry.actorEmail ?? 'common.na'|trans }}</div>
                            <div class="muted inline-meta">{{ entry.entry.actorId ?? 'common.na'|trans }}</div>
                        </td>
                        <td>
                            <div>{{ entry.entry.targetType }}</div>
                            <div class="muted inline-meta">{{ entry.entry.targetId }}</div>
                        </td>
                        <td>{{ entry.entry.correlationId }}</td>
                        <td>
                            {% if entry.entry.diffSummary is not empty %}
                                <details>
                                    <summary>{{ 'admin.audit.table.view_diff'|trans }}</summary>
                                    <pre class="preformatted-block">{{ entry.entry.diffSummary|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                                </details>
                            {% else %}
                                <span class="muted">{{ 'common.na'|trans }}</span>
                            {% endif %}
                        </td>
                        <td class="action-cell-flex">
                            {% if entry.userUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.userUrl }}">{{ 'admin.audit.actions.user'|trans }}</a>
                            {% endif %}
                            {% if entry.identitiesUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.identitiesUrl }}">{{ 'admin.audit.actions.identities'|trans }}</a>
                            {% endif %}
                            {% if entry.securityUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.securityUrl }}">{{ 'admin.audit.actions.security'|trans }}</a>
                            {% endif %}
                            {% if entry.correlationUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.correlationUrl }}">{{ 'admin.audit.actions.correlation'|trans }}</a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="muted">{{ 'admin.audit.empty'|trans }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
