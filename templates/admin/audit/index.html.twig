{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Audit Logs{% endblock %}

{% set admin_section = 'audit' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">Audit Logs</h2>
            <p class="muted">Immutable admin action trail with actor, target and correlation id.</p>
        </div>
    </section>

    {% if supportShortcuts is not empty %}
        <section class="card admin-panel admin-section-spaced">
            <div class="admin-page-head">
                <div class="admin-page-header">
                    <strong>Investigation continuity</strong>
                    <p class="muted compact-note">Keep the same actor or correlation in view while moving between user, identity, security, and audit screens.</p>
                </div>
                <div class="actions-wrap">
                    {% for item in supportShortcuts %}
                        <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {% if activeFilterSummary is not empty %}
        <section class="card admin-panel admin-section-spaced">
            <div class="admin-page-head">
                <div class="admin-page-header">
                    <strong>Active filters</strong>
                    <p class="muted compact-note">
                        {% for item in activeFilterSummary %}
                            {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                        {% endfor %}
                    </p>
                </div>
                <div class="admin-page-actions">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_audit_log_list') }}">Reset</a>
                </div>
            </div>
        </section>
    {% endif %}

    <section class="card admin-panel admin-section-spaced">
        <h3 class="section-title">Filters</h3>
        <form method="get" class="admin-filters-form">
            <div class="form-grid-2">
                <label class="label">
                    Action
                    <input class="input" type="text" name="action" value="{{ filters.action ?? '' }}" placeholder="admin.station.updated">
                </label>
                <label class="label">
                    Actor
                    <select class="select" name="actorId">
                        <option value="">All actors</option>
                        {% for actor in actorOptions %}
                            <option value="{{ actor.id }}" {% if filters.actorId == actor.id %}selected{% endif %}>{{ actor.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    Target type
                    <input class="input" type="text" name="targetType" value="{{ filters.targetType ?? '' }}" placeholder="station">
                </label>
                <label class="label">
                    Target ID
                    <input class="input" type="text" name="targetId" value="{{ filters.targetId ?? '' }}" placeholder="UUID">
                </label>
                <label class="label">
                    Correlation ID
                    <input class="input" type="text" name="correlationId" value="{{ filters.correlationId ?? '' }}" placeholder="corr-...">
                </label>
                <label class="label">
                    From date
                    <input class="input" type="text" name="from" value="{{ filters.from ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
                <label class="label">
                    To date
                    <input class="input" type="text" name="to" value="{{ filters.to ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
            </div>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">Apply filters</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_audit_log_list') }}">Reset</a>
            </div>
        </form>
    </section>

    <section class="card admin-panel admin-section-spaced">
        <div class="table-wrap table-min-1150">
            <table class="app-table">
                <thead>
                <tr>
                    <th>Created</th>
                    <th>Action</th>
                    <th>Actor</th>
                    <th>Target</th>
                    <th>Correlation ID</th>
                    <th>Diff Summary</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for entry in entries %}
                    <tr class="table-row">
                        <td>{{ entry.entry.createdAt|date('Y-m-d H:i:s') }}</td>
                        <td>{{ entry.entry.action }}</td>
                        <td>
                            <div>{{ entry.entry.actorEmail ?? 'n/a' }}</div>
                            <div class="muted inline-meta">{{ entry.entry.actorId ?? 'n/a' }}</div>
                        </td>
                        <td>
                            <div>{{ entry.entry.targetType }}</div>
                            <div class="muted inline-meta">{{ entry.entry.targetId }}</div>
                        </td>
                        <td>{{ entry.entry.correlationId }}</td>
                        <td>
                            {% if entry.entry.diffSummary is not empty %}
                                <details>
                                    <summary>view</summary>
                                    <pre class="preformatted-block">{{ entry.entry.diffSummary|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                                </details>
                            {% else %}
                                <span class="muted">n/a</span>
                            {% endif %}
                        </td>
                        <td class="action-cell-flex">
                            {% if entry.userUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.userUrl }}">User</a>
                            {% endif %}
                            {% if entry.identitiesUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.identitiesUrl }}">Identities</a>
                            {% endif %}
                            {% if entry.securityUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.securityUrl }}">Security</a>
                            {% endif %}
                            {% if entry.correlationUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.correlationUrl }}">Correlation</a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="muted">No audit entries found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
