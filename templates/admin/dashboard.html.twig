{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}

{% set admin_section = 'dashboard' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">{{ 'admin.dashboard.title'|trans }}</h2>
            <p class="muted">{{ 'admin.dashboard.lead'|trans }}</p>
        </div>

        <div class="admin-metric-grid metric-grid-spaced">
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.dashboard.metrics.failed_imports'|trans }}</p>
                <p class="admin-metric-value">{{ importMetrics['failed']|default(0) }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.dashboard.metrics.needs_review'|trans }}</p>
                <p class="admin-metric-value">{{ importMetrics['needs_review']|default(0) }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.dashboard.metrics.due_reminders'|trans }}</p>
                <p class="admin-metric-value">{{ dueReminderCount }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.dashboard.metrics.receipts'|trans }}</p>
                <p class="admin-metric-value">{{ receiptCount }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.dashboard.metrics.vehicles'|trans }}</p>
                <p class="admin-metric-value">{{ vehicleCount }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.dashboard.metrics.stations'|trans }}</p>
                <p class="admin-metric-value">{{ stationCount }}</p>
            </article>
        </div>
    </section>

    <section class="card admin-panel admin-section-spaced">
        <h3 class="section-title">{{ 'admin.dashboard.attention_title'|trans }}</h3>
        {% if attentionCards is not empty %}
            <div class="admin-dashboard-columns">
                {% for card in attentionCards %}
                    <article class="card-subtle card-subtle-block admin-dashboard-item">
                        <div class="admin-dashboard-item-head">
                            <span class="pill status-pill status-{{ card.statusClass }}">{{ card.title }}</span>
                            <strong class="admin-dashboard-item-value">{{ card.value }}</strong>
                        </div>
                        <p class="muted">{{ card.description }}</p>
                        <div class="action-row">
                            <a class="btn btn-secondary btn-compact" href="{{ card.url }}">{{ card.action }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ card.secondaryUrl }}">{{ card.secondaryAction }}</a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <p class="muted">{{ 'admin.dashboard.attention_empty'|trans }}</p>
        {% endif %}
    </section>

    <section class="card admin-panel admin-section-spaced">
        <h3 class="section-title">{{ 'admin.dashboard.recent_receipts_title'|trans }}</h3>
        {% if recentReceipts is not empty %}
            <div class="admin-dashboard-list">
                {% for receipt in recentReceipts %}
                    <article class="card-subtle card-subtle-block admin-dashboard-item">
                        <div class="admin-dashboard-item-head">
                            <strong>{{ receipt.issuedAt|date('Y-m-d H:i') }}</strong>
                            <span class="muted">{{ (receipt.totalCents / 100)|number_format(2, ',', ' ') }} EUR</span>
                        </div>
                        <p class="muted compact-note">{{ receipt.id }}</p>
                        <div class="compact-note">
                            {% if receipt.vehicleId %}
                                {{ 'admin.dashboard.receipt_vehicle'|trans }}: {{ vehicleNames[receipt.vehicleId]|default(receipt.vehicleId) }}
                            {% else %}
                                {{ 'admin.dashboard.receipt_vehicle'|trans }}: {{ 'common.na'|trans }}
                            {% endif %}
                            ·
                            {% if receipt.stationId %}
                                {{ 'admin.dashboard.receipt_station'|trans }}: {{ stationNames[receipt.stationId]|default(receipt.stationId) }}
                            {% else %}
                                {{ 'admin.dashboard.receipt_station'|trans }}: {{ 'common.na'|trans }}
                            {% endif %}
                        </div>
                        <div class="action-row">
                            <a class="btn btn-secondary btn-compact" href="{{ receipt.showUrl }}">{{ 'action.open'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ receipt.editUrl }}">{{ 'action.edit'|trans }}</a>
                            {% if receipt.vehicleId %}
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_show', {id: receipt.vehicleId, return_to: app.request.requestUri}) }}">{{ 'admin.dashboard.receipt_vehicle'|trans }}</a>
                            {% endif %}
                            {% if receipt.stationId %}
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_station_show', {id: receipt.stationId, return_to: app.request.requestUri}) }}">{{ 'admin.dashboard.receipt_station'|trans }}</a>
                            {% endif %}
                            {% if receipt.importUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ receipt.importUrl }}">{{ 'admin.shell.nav.imports'|trans }}</a>
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <p class="muted">{{ 'admin.dashboard.recent_receipts_empty'|trans }}</p>
        {% endif %}
    </section>

    <section class="card admin-panel admin-section-spaced">
        <h3 class="section-title">{{ 'admin.dashboard.import_snapshot_title'|trans }}</h3>
        {% if recentImports is not empty %}
            <div class="admin-dashboard-list">
                {% for job in recentImports %}
                    <article class="card-subtle card-subtle-block admin-dashboard-item">
                        <div class="admin-dashboard-item-head">
                            <span class="pill status-pill status-{{ job.status }}">{{ ('import.status.' ~ job.status)|trans }}</span>
                            <span class="muted">{{ job.createdAt|date('Y-m-d H:i') }}</span>
                        </div>
                        <strong>{{ job.file }}</strong>
                        <p class="muted compact-note">{{ job.ownerLabel }}</p>
                        <div class="action-row">
                            <a class="btn btn-secondary btn-compact" href="{{ job.primaryUrl }}">{{ job.primaryLabel }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ job.secondaryUrl }}">{{ job.secondaryLabel }}</a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <p class="muted">{{ 'admin.dashboard.imports_empty'|trans }}</p>
        {% endif %}
    </section>

    <section class="card admin-panel admin-section-spaced">
        <h3 class="section-title">{{ 'admin.dashboard.support_hub_title'|trans }}</h3>
        <div class="admin-dashboard-columns">
            <article class="card-subtle card-subtle-block admin-dashboard-item">
                <div class="admin-dashboard-item-head">
                    <strong>{{ 'admin.dashboard.support.import_recovery_title'|trans }}</strong>
                    <span class="muted compact-note">{{ 'admin.dashboard.support.import_recovery_counts'|trans({'%failed%': importMetrics['failed']|default(0), '%review%': importMetrics['needs_review']|default(0)}) }}</span>
                </div>
                <p class="muted">{{ 'admin.dashboard.support.import_recovery_lead'|trans }}</p>
                <div class="action-row">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_import_job_list', {status: 'failed'}) }}">{{ 'admin.dashboard.metrics.failed_imports'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_import_job_list', {status: 'needs_review'}) }}">{{ 'admin.dashboard.metrics.needs_review'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_import_job_list', {status: 'processed'}) }}">{{ 'import.status.processed'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_import_job_list', {status: 'duplicate'}) }}">{{ 'import.status.duplicate'|trans }}</a>
                </div>
            </article>

            <article class="card-subtle card-subtle-block admin-dashboard-item">
                <div class="admin-dashboard-item-head">
                    <strong>{{ 'admin.dashboard.support.maintenance_investigation_title'|trans }}</strong>
                    <span class="muted compact-note">{{ 'admin.dashboard.support.maintenance_investigation_counts'|trans({'%due%': dueReminderCount, '%reminders%': maintenanceReminderCount, '%events%': maintenanceEventCount}) }}</span>
                </div>
                <p class="muted">{{ 'admin.dashboard.support.maintenance_investigation_lead'|trans }}</p>
                <div class="action-row">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_reminder_list') }}">{{ 'admin.shell.nav.maintenance_reminders'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_list') }}">{{ 'admin.shell.nav.maintenance_events'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_list') }}">{{ 'admin.shell.nav.receipts'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_list') }}">{{ 'admin.shell.nav.vehicles'|trans }}</a>
                </div>
            </article>

            <article class="card-subtle card-subtle-block admin-dashboard-item">
                <div class="admin-dashboard-item-head">
                    <strong>{{ 'admin.dashboard.support.vehicle_queues_title'|trans }}</strong>
                    <span class="muted compact-note">{{ 'admin.dashboard.support.vehicle_queues_counts'|trans({'%due%': supportSignals.vehicleDueCount, '%without_receipts%': supportSignals.vehiclesWithoutReceipts}) }}</span>
                </div>
                <p class="muted">{{ 'admin.dashboard.support.vehicle_queues_lead'|trans }}</p>
                <div class="action-row">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_list') }}">{{ 'admin.shell.nav.vehicles'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_reminder_list') }}">{{ 'admin.dashboard.metrics.due_reminders'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_list') }}">{{ 'admin.shell.nav.receipts'|trans }}</a>
                </div>
            </article>

            <article class="card-subtle card-subtle-block admin-dashboard-item">
                <div class="admin-dashboard-item-head">
                    <strong>{{ 'admin.dashboard.support.station_queues_title'|trans }}</strong>
                    <span class="muted compact-note">{{ 'admin.dashboard.support.station_queues_counts'|trans({'%without_receipts%': supportSignals.stationsWithoutReceipts, '%pending%': supportSignals.pendingStationCount}) }}</span>
                </div>
                <p class="muted">{{ 'admin.dashboard.support.station_queues_lead'|trans }}</p>
                <div class="action-row">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_station_list') }}">{{ 'admin.shell.nav.stations'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_list') }}">{{ 'admin.shell.nav.receipts'|trans }}</a>
                </div>
            </article>

            <article class="card-subtle card-subtle-block admin-dashboard-item">
                <div class="admin-dashboard-item-head">
                    <strong>{{ 'admin.dashboard.support.account_recovery_title'|trans }}</strong>
                    <span class="muted compact-note">{{ 'admin.dashboard.support.account_recovery_counts'|trans({'%missing_identities%': supportSignals.missingIdentityCount, '%unverified%': supportSignals.unverifiedUserCount}) }}</span>
                </div>
                <p class="muted">{{ 'admin.dashboard.support.account_recovery_lead'|trans }}</p>
                <div class="action-row">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_user_list', {has_identity: '0'}) }}">{{ 'admin.dashboard.attention.missing_identities_title'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_user_list', {verification: 'unverified'}) }}">{{ 'admin.dashboard.attention.unverified_accounts_title'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_security_activity_list') }}">{{ 'admin.shell.nav.security_activities'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_audit_log_list') }}">{{ 'admin.shell.nav.audit_logs'|trans }}</a>
                </div>
            </article>
        </div>

        <div class="actions-wrap admin-table-top">
            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_station_list') }}">{{ 'admin.shell.nav.stations'|trans }}</a>
            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_identity_list') }}">{{ 'admin.shell.nav.identities'|trans }}</a>
            <a class="btn btn-secondary btn-compact" href="/api/docs">{{ 'admin.dashboard.support.open_api_docs'|trans }}</a>
        </div>
    </section>
{% endblock %}
