{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Identities{% endblock %}

{% set admin_section = 'identities' %}

{% block admin_content %}
    <section class="card admin-panel">
        <h2 class="page-title">Identities</h2>
        <p class="muted">Manage linked social/OIDC identities and reassign ownership when needed.</p>

        <form method="get" action="{{ path('ui_admin_identity_list') }}" style="margin-top: 1rem; display:grid; gap:0.6rem; grid-template-columns: repeat(4, minmax(0, 1fr)); align-items:end;">
            <label class="label">
                Search
                <input class="input" type="text" name="q" value="{{ filters.q }}" placeholder="provider, subject, email">
            </label>
            <label class="label">
                Provider
                <input class="input" type="text" name="provider" value="{{ filters.provider }}" placeholder="google, auth0...">
            </label>
            <label class="label">
                User id
                <input class="input" type="text" name="user_id" value="{{ filters.user_id }}" placeholder="UUID">
            </label>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                <button class="btn btn-primary" type="submit">Apply</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_identity_list') }}">Reset</a>
            </div>
        </form>

        <div class="table-wrap" style="margin-top: 1rem;">
            <table class="app-table" style="min-width: 1120px;">
                <thead>
                <tr>
                    <th>Provider</th>
                    <th>Subject</th>
                    <th>Identity Email</th>
                    <th>Linked User</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for identity in identities %}
                    <tr>
                        <td>{{ identity.provider }}</td>
                        <td><code>{{ identity.subject }}</code></td>
                        <td>{{ identity.email ?? 'n/a' }}</td>
                        <td>
                            <div>{{ identity.userEmail }}</div>
                            <small class="muted">{{ identity.userId }}</small>
                        </td>
                        <td style="display:grid; gap:0.45rem;">
                            <form method="post" action="{{ path('ui_admin_identity_relink', {id: identity.id}) }}" style="display:flex; gap:0.45rem; flex-wrap:wrap;" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_identity_relink_' ~ identity.id) }}">
                                <select class="select" name="user_id" style="min-width: 240px;">
                                    {% for user in users %}
                                        <option value="{{ user.id }}" {% if user.id == identity.userId %}selected{% endif %}>{{ user.email }}</option>
                                    {% endfor %}
                                </select>
                                <button class="btn btn-secondary" type="submit">Relink</button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_identity_delete', {id: identity.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_identity_delete_' ~ identity.id) }}">
                                <button class="btn btn-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="muted">No identities found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
