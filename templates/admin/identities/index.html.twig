{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.identities.title'|trans }}{% endblock %}

{% set admin_section = 'identities' %}

{% block admin_content %}
    {% set returnTo = app.request.requestUri %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">{{ 'admin.identities.title'|trans }}</h2>
            <p class="muted">{{ 'admin.identities.lead'|trans }}</p>
        </div>

        {% if supportShortcuts is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.identities.continuity_title'|trans }}</strong>
                        <p class="muted compact-note">{{ 'admin.identities.continuity_lead'|trans }}</p>
                    </div>
                    <div class="actions-wrap">
                        {% for item in supportShortcuts %}
                            <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.common.active_filters'|trans }}</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_identity_list') }}">{{ 'action.reset'|trans }}</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <form method="get" action="{{ path('ui_admin_identity_list') }}" class="admin-filter-grid-4 admin-table-top">
            <label class="label">
                {{ 'admin.identities.filters.search'|trans }}
                <input class="input" type="text" name="q" value="{{ filters.q }}" placeholder="{{ 'admin.identities.filters.search_placeholder'|trans }}">
            </label>
            <label class="label">
                {{ 'admin.identities.filters.provider'|trans }}
                <input class="input" type="text" name="provider" value="{{ filters.provider }}" placeholder="{{ 'admin.identities.filters.provider_placeholder'|trans }}">
            </label>
            <label class="label">
                {{ 'admin.identities.filters.user'|trans }}
                <select class="select" name="user_id">
                    <option value="">{{ 'admin.identities.filters.all_users'|trans }}</option>
                    {% for user in userOptions %}
                        <option value="{{ user.id }}" {% if filters.user_id == user.id %}selected{% endif %}>{{ user.label }}</option>
                    {% endfor %}
                </select>
            </label>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">{{ 'action.apply'|trans }}</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_identity_list') }}">{{ 'action.reset'|trans }}</a>
            </div>
        </form>

        <div class="table-wrap admin-table-top table-min-1120">
            <table class="app-table">
                <thead>
                <tr>
                    <th>{{ 'admin.identities.table.provider'|trans }}</th>
                    <th>{{ 'admin.identities.table.subject'|trans }}</th>
                    <th>{{ 'admin.identities.table.identity_email'|trans }}</th>
                    <th>{{ 'admin.identities.table.linked_user'|trans }}</th>
                    <th>{{ 'common.actions'|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for identity in identities %}
                    <tr>
                        <td>{{ identity.record.provider }}</td>
                        <td><code>{{ identity.record.subject }}</code></td>
                        <td>{{ identity.record.email ?? 'common.na'|trans }}</td>
                        <td>
                            <div>{{ identity.record.userEmail }}</div>
                            <small class="muted">{{ identity.record.userId }}</small>
                        </td>
                        <td class="stack-sm">
                            <div class="actions-wrap">
                                <a class="btn btn-secondary btn-compact" href="{{ identity.userListUrl }}">{{ 'admin.identities.actions.user'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ identity.securityUrl }}">{{ 'admin.identities.actions.security'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ identity.auditUrl }}">{{ 'admin.identities.actions.audit'|trans }}</a>
                            </div>
                            <form method="post" action="{{ path('ui_admin_identity_relink', {id: identity.record.id}) }}" class="admin-form-actions" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_identity_relink_' ~ identity.record.id) }}">
                                <input type="hidden" name="_redirect" value="{{ returnTo }}">
                                <select class="select" name="user_id">
                                    {% for user in users %}
                                        <option value="{{ user.id }}" {% if user.id == identity.record.userId %}selected{% endif %}>{{ user.email }}</option>
                                    {% endfor %}
                                </select>
                                <button class="btn btn-secondary btn-compact" type="submit">{{ 'admin.identities.actions.relink'|trans }}</button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_identity_delete', {id: identity.record.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_identity_delete_' ~ identity.record.id) }}">
                                <input type="hidden" name="_redirect" value="{{ returnTo }}">
                                <button class="btn btn-danger btn-compact" type="submit">{{ 'action.delete'|trans }}</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="muted">{{ 'admin.identities.empty'|trans }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
