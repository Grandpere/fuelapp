{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.import.index.title'|trans }}{% endblock %}

{% set admin_section = 'imports' %}

{% block admin_content %}
    {% set returnTo = app.request.requestUri %}
    <section class="card admin-panel">
        <div class="admin-page-head">
            <div class="admin-page-header">
                <h2 class="page-title">{{ 'admin.import.index.title'|trans }}</h2>
                <p class="muted">{{ 'admin.import.index.lead'|trans }}</p>
            </div>
        </div>

        <div class="admin-metric-grid admin-table-top">
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'import.status.needs_review'|trans }}</p>
                <p class="admin-metric-value">{{ metrics['needs_review']|default(0) }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'import.status.failed'|trans }}</p>
                <p class="admin-metric-value">{{ metrics['failed']|default(0) }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'import.status.queued'|trans }} + {{ 'import.status.processing'|trans }}</p>
                <p class="admin-metric-value">{{ (metrics['queued']|default(0)) + (metrics['processing']|default(0)) }}</p>
            </article>
        </div>

        <div class="actions-wrap admin-table-top">
            {% for filter in statusQuickFilters %}
                <a class="btn {{ filter.isActive ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ filter.url }}">
                    {{ filter.label }} ({{ filter.count }})
                </a>
            {% endfor %}
        </div>

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.import.index.active_filters'|trans }}</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_import_job_list') }}">{{ 'action.reset'|trans }}</a>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if followUpShortcuts is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">{{ 'admin.import.index.queue_speed'|trans }}</p>
                <p class="muted compact-note">{{ 'admin.import.index.queue_speed_lead'|trans }}</p>
                <div class="actions-wrap">
                    {% for shortcut in followUpShortcuts %}
                        <a class="btn {{ shortcut.variant == 'primary' ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ shortcut.url }}">
                            {{ shortcut.label }}
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </section>

    <section class="card admin-panel admin-section-spaced">
        <h3 class="section-title">{{ 'admin.import.index.filters_title'|trans }}</h3>
        <form method="get" class="admin-filters-form">
            <div class="form-grid-2">
                <label class="label">
                    {{ 'admin.import.index.filter_status'|trans }}
                    <select name="status" class="select">
                        <option value="">{{ 'admin.import.index.filter_all_statuses'|trans }}</option>
                        {% for status in statusOptions %}
                            <option value="{{ status }}" {{ filters.status == status ? 'selected' : '' }}>{{ ('import.status.' ~ status)|trans }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    {{ 'admin.import.index.filter_source'|trans }}
                    <input class="input" type="text" name="source" value="{{ filters.source ?? '' }}" placeholder="local">
                </label>
                <label class="label">
                    {{ 'admin.import.index.filter_owner'|trans }}
                    <select name="ownerId" class="select">
                        <option value="">{{ 'admin.import.index.filter_all_owners'|trans }}</option>
                        {% for owner in ownerOptions %}
                            <option value="{{ owner.id }}" {{ filters.ownerId == owner.id ? 'selected' : '' }}>{{ owner.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    {{ 'admin.import.index.filter_search'|trans }}
                    <input class="input" type="text" name="q" value="{{ filters.q ?? '' }}" placeholder="invoice-2026-02.pdf">
                </label>
                <label class="label">
                    {{ 'admin.import.index.filter_created_from'|trans }}
                    <input class="input" type="text" name="createdFrom" value="{{ filters.createdFrom ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
                <label class="label">
                    {{ 'admin.import.index.filter_created_to'|trans }}
                    <input class="input" type="text" name="createdTo" value="{{ filters.createdTo ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
            </div>
            <div class="actions-wrap">
                <button class="btn btn-primary" type="submit">{{ 'admin.import.index.apply_filters'|trans }}</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_import_job_list') }}">{{ 'action.reset'|trans }}</a>
            </div>
        </form>
    </section>

    <section class="card admin-panel admin-section-spaced">
        <div class="table-wrap">
            <table class="app-table table-min-1180">
                <thead>
                <tr>
                    <th>{{ 'admin.import.index.column.id'|trans }}</th>
                    <th>{{ 'admin.import.index.column.status'|trans }}</th>
                    <th>{{ 'admin.import.index.column.signal'|trans }}</th>
                    <th>{{ 'admin.import.index.column.owner_id'|trans }}</th>
                    <th>{{ 'admin.import.index.column.file'|trans }}</th>
                    <th>{{ 'admin.import.index.column.source'|trans }}</th>
                    <th>{{ 'admin.import.index.column.created'|trans }}</th>
                    <th>{{ 'admin.import.index.column.updated'|trans }}</th>
                    <th>{{ 'admin.import.index.column.action'|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for job in jobs %}
                    <tr
                        class="table-row row-link"
                        data-controller="row-link"
                        data-action="click->row-link#navigate"
                        data-row-link-url-value="{{ path('ui_admin_import_job_show', {id: job.job.id.toString, return_to: returnTo}) }}"
                        onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                    >
                        <td>{{ job.job.id.toString }}</td>
                        <td>
                            <span class="pill status-pill status-{{ job.job.status.value }}">
                                {{ ('import.status.' ~ job.job.status.value)|trans }}
                            </span>
                        </td>
                        <td>
                            <strong>{{ job.summary.headline }}</strong>
                            <div class="muted compact-note">{{ job.summary.detail }}</div>
                            <div class="muted compact-note">{{ 'admin.import.index.signal_cause'|trans }}: {{ job.decision.cause }}</div>
                            <div class="muted compact-note">{{ 'admin.import.index.signal_next'|trans }}: {{ job.decision.nextStep }}</div>
                        </td>
                        <td>{{ job.job.ownerId }}</td>
                        <td>
                            <div>{{ job.job.originalFilename }}</div>
                            <div class="muted compact-note">{{ job.job.mimeType }} · {{ 'admin.import.index.file_bytes'|trans({'%bytes%': job.job.fileSizeBytes}) }}</div>
                        </td>
                        <td>{{ job.job.storage }}</td>
                        <td>{{ job.job.createdAt|date('Y-m-d H:i:s') }}</td>
                        <td>{{ job.job.updatedAt|date('Y-m-d H:i:s') }}</td>
                        <td>
                            <div class="action-cell-flex" data-row-link-ignore>
                                <a class="btn {{ job.primaryAction.variant == 'primary' ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ job.primaryAction.url }}" data-turbo-frame="_top">{{ job.primaryAction.label }}</a>
                                {% if job.secondaryAction is not null %}
                                    <a class="btn btn-secondary btn-compact" href="{{ job.secondaryAction.url }}" data-turbo-frame="_top">{{ job.secondaryAction.label }}</a>
                                {% endif %}
                                <form method="post" action="{{ path('ui_admin_import_job_delete', {id: job.job.id.toString}) }}" data-turbo-frame="_top" onsubmit="return confirm('{{ 'admin.import.index.confirm_delete'|trans|e('js') }}');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_import_delete_' ~ job.job.id.toString) }}">
                                    <input type="hidden" name="_redirect" value="{{ returnTo }}">
                                    <button class="btn btn-danger btn-compact" type="submit">{{ 'action.delete'|trans }}</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="muted">{{ 'admin.import.index.empty'|trans }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
