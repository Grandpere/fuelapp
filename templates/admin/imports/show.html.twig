{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.import.show.title'|trans }}{% endblock %}

{% set admin_section = 'imports' %}

{% block admin_content %}
    {% set parsedDraft = payloadData is not null and payloadData.parsedDraft is defined and payloadData.parsedDraft is iterable ? payloadData.parsedDraft : null %}
    {% set creationPayload = payloadData is not null and payloadData.creationPayload is defined and payloadData.creationPayload is iterable ? payloadData.creationPayload : null %}
    {% set reviewLines = creationPayload is not null and creationPayload.lines is defined and creationPayload.lines is iterable ? creationPayload.lines : (parsedDraft is not null and parsedDraft.lines is defined and parsedDraft.lines is iterable ? parsedDraft.lines : []) %}
    {% set issueList = parsedDraft is not null and parsedDraft.issues is defined and parsedDraft.issues is iterable ? parsedDraft.issues : [] %}
    {% set issuedAtMissing = 'issued_at_missing' in issueList %}

    <section class="card admin-panel">
        <div class="admin-page-head">
            <div class="admin-page-header">
                <h2 class="page-title">{{ 'admin.import.show.title'|trans }}</h2>
                <p class="muted">{{ 'admin.import.show.lead'|trans }}</p>
            </div>
        </div>

        <dl class="admin-dl admin-table-top">
            <dt class="admin-dt">{{ 'admin.import.show.field.id'|trans }}</dt>
            <dd class="admin-dd">{{ job.id.toString }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.status'|trans }}</dt>
            <dd class="admin-dd">{{ ('import.status.' ~ job.status.value)|trans }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.owner_id'|trans }}</dt>
            <dd class="admin-dd">{{ job.ownerId }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.storage'|trans }}</dt>
            <dd class="admin-dd">{{ job.storage }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.file_path'|trans }}</dt>
            <dd class="admin-dd">{{ job.filePath }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.original_filename'|trans }}</dt>
            <dd class="admin-dd">{{ job.originalFilename }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.mime_type'|trans }}</dt>
            <dd class="admin-dd">{{ job.mimeType }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.file_size'|trans }}</dt>
            <dd class="admin-dd">{{ 'admin.import.show.bytes'|trans({'%bytes%': job.fileSizeBytes}) }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.checksum'|trans }}</dt>
            <dd class="admin-dd">{{ job.fileChecksumSha256 }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.created_at'|trans }}</dt>
            <dd class="admin-dd">{{ job.createdAt|date('Y-m-d H:i:s') }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.updated_at'|trans }}</dt>
            <dd class="admin-dd">{{ job.updatedAt|date('Y-m-d H:i:s') }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.started_at'|trans }}</dt>
            <dd class="admin-dd">{{ job.startedAt ? job.startedAt|date('Y-m-d H:i:s') : ('common.na'|trans) }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.completed_at'|trans }}</dt>
            <dd class="admin-dd">{{ job.completedAt ? job.completedAt|date('Y-m-d H:i:s') : ('common.na'|trans) }}</dd>
            <dt class="admin-dt">{{ 'admin.import.show.field.failed_at'|trans }}</dt>
            <dd class="admin-dd">{{ job.failedAt ? job.failedAt|date('Y-m-d H:i:s') : ('common.na'|trans) }}</dd>
        </dl>

        {% if triageSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">{{ 'admin.import.show.triage_summary'|trans }}</p>
                <dl class="admin-dl">
                    {% for label, value in triageSummary %}
                        <dt class="admin-dt">{{ label }}</dt>
                        <dd class="admin-dd">{{ value }}</dd>
                    {% endfor %}
                </dl>
            </div>
        {% endif %}

        <div class="card-subtle card-subtle-block admin-table-top">
            <p class="text-block-title">{{ 'admin.import.show.triage_readout'|trans }}</p>
            <dl class="admin-dl">
                <dt class="admin-dt">{{ 'admin.import.show.probable_cause'|trans }}</dt>
                <dd class="admin-dd">{{ triageReadout.probableCause }}</dd>
                <dt class="admin-dt">{{ 'admin.import.show.next_best_action'|trans }}</dt>
                <dd class="admin-dd">{{ triageReadout.nextAction }}</dd>
                {% if triageReadout.operatorNote is not null %}
                    <dt class="admin-dt">{{ 'admin.import.show.operator_note'|trans }}</dt>
                    <dd class="admin-dd">{{ triageReadout.operatorNote }}</dd>
                {% endif %}
            </dl>
        </div>

        <div class="card-subtle card-subtle-block admin-table-top">
            <p class="text-block-title">{{ 'admin.import.show.support_diagnostics'|trans }}</p>
            <dl class="admin-dl">
                <dt class="admin-dt">{{ 'admin.import.show.owner'|trans }}</dt>
                <dd class="admin-dd">{{ ownerLabel }}</dd>
                {% if requestCorrelationId is not null %}
                    <dt class="admin-dt">{{ 'admin.import.show.request_correlation'|trans }}</dt>
                    <dd class="admin-dd">{{ requestCorrelationId }}</dd>
                {% endif %}
            </dl>
            {% if investigationShortcuts is not empty or requestCorrelationId is not null %}
                <div class="actions-wrap admin-table-top">
                    {% for action in investigationShortcuts %}
                        <a class="btn btn-secondary btn-compact" href="{{ action.url }}" data-turbo-frame="_top">{{ action.label }}</a>
                    {% endfor %}
                    {% if requestCorrelationId is not null %}
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_audit_log_list', {correlationId: requestCorrelationId}) }}" data-turbo-frame="_top">{{ 'admin.import.show.request_audit_trail'|trans }}</a>
                    {% endif %}
                </div>
            {% endif %}
        </div>

        {% if payloadData is not null %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">{{ 'admin.import.show.decoded_payload'|trans }}</p>
                <pre class="preformatted-block">{{ payloadData|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
            </div>
        {% elseif payload %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">{{ 'admin.import.show.raw_payload'|trans }}</p>
                <pre class="preformatted-block">{{ payload }}</pre>
            </div>
        {% else %}
            <p class="muted admin-table-top">{{ 'admin.import.show.no_payload'|trans }}</p>
        {% endif %}

        <div class="actions-wrap admin-table-top">
            <a class="btn btn-secondary" href="{{ backToListUrl }}" data-turbo-frame="_top">{{ 'action.back_to_list'|trans }}</a>
            <a class="btn btn-secondary" href="/api/imports/{{ job.id.toString }}" data-turbo-frame="_top">{{ 'admin.import.show.open_user_api'|trans }}</a>
            <a class="btn btn-secondary" href="/api/admin/imports/{{ job.id.toString }}/retry" data-turbo-frame="_top">{{ 'admin.import.show.open_admin_retry_api'|trans }}</a>
            {% if job.status.value == 'needs_review' %}
                <form method="post" action="{{ path('ui_admin_import_job_reparse', {id: job.id.toString}) }}" data-turbo-frame="_top">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_import_reparse_' ~ job.id.toString) }}">
                    <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">
                    <button class="btn btn-secondary" type="submit">{{ 'import.show.reparse'|trans }}</button>
                </form>
            {% endif %}
            <form method="post" action="{{ path('ui_admin_import_job_delete', {id: job.id.toString}) }}" data-turbo-frame="_top" onsubmit="return confirm('{{ 'admin.import.index.confirm_delete'|trans|e('js') }}');">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_delete_' ~ job.id.toString) }}">
                <input type="hidden" name="_redirect" value="{{ backToListUrl }}">
                <button class="btn btn-danger" type="submit">{{ 'action.delete'|trans }}</button>
            </form>
        </div>

        {% if statusActions is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">{{ 'admin.import.show.next_step'|trans }}</p>
                <div class="actions-wrap">
                    {% for action in statusActions %}
                        <a class="btn {{ action.variant == 'primary' ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ action.url }}" data-turbo-frame="_top">{{ action.label }}</a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {% if receiptContinuity is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">{{ 'admin.import.show.receipt_continuity'|trans }}</p>
                <div class="actions-wrap">
                    {% for action in receiptContinuity %}
                        <a class="btn {{ action.variant == 'primary' ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ action.url }}" data-turbo-frame="_top">{{ action.label }}</a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </section>

    {% if payloadData is not null and payloadData.fallbackReason is defined %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.import.show.ocr_fallback'|trans }}</h3>
            <p class="muted">
                {{ payloadData.fallbackNotice is defined ? payloadData.fallbackNotice : ('import.show.ocr_fallback_default'|trans) }}
            </p>
            <div class="actions-wrap">
                <span class="pill status-pill status-needs_review">{{ payloadData.fallbackStrategy is defined ? payloadData.fallbackStrategy|replace({'_': ' '}) : ('import.show.manual_review'|trans) }}</span>
                <span class="muted compact-note">{{ payloadData.fallbackReason }}</span>
            </div>
        </section>
    {% endif %}

    {% if issueList|length > 0 %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.import.show.detected_issues'|trans }}</h3>
            <p class="muted">{{ issueList|join(', ') }}</p>
        </section>
    {% endif %}

    {% if issuedAtMissing %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.import.show.date_required'|trans }}</h3>
            <p class="muted">{{ 'admin.import.show.date_required_lead'|trans }}</p>
        </section>
    {% endif %}

    {% if job.status.value == 'processed' %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.import.show.import_completed'|trans }}</h3>
            <p class="muted">{{ 'admin.import.show.import_completed_lead'|trans }}</p>
            <div class="actions-wrap">
                {% if resolvedFinalizedReceiptId is not null %}
                    <a class="btn btn-primary btn-compact" href="{{ path('ui_admin_receipt_show', {id: resolvedFinalizedReceiptId, return_to: currentImportUrl}) }}" data-turbo-frame="_top">{{ 'import.action.open_created_receipt'|trans }}</a>
                {% else %}
                    <span class="muted compact-note">{{ 'admin.import.show.linked_resource_missing'|trans }}</span>
                {% endif %}
                <a class="btn btn-secondary btn-compact" href="{{ backToListUrl }}" data-turbo-frame="_top">{{ 'import.action.back_to_imports'|trans }}</a>
            </div>
        </section>
    {% elseif job.status.value == 'duplicate' %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.import.show.duplicate_import'|trans }}</h3>
            <p class="muted">{{ 'admin.import.show.duplicate_import_lead'|trans }}</p>
            <div class="actions-wrap">
                {% if resolvedDuplicateReceiptId is not null %}
                    <a class="btn btn-primary btn-compact" href="{{ path('ui_admin_receipt_show', {id: resolvedDuplicateReceiptId, return_to: currentImportUrl}) }}" data-turbo-frame="_top">{{ 'import.action.open_existing_receipt'|trans }}</a>
                {% elseif resolvedDuplicateOriginalImportId is not null %}
                    <a class="btn btn-primary btn-compact" href="{{ path('ui_admin_import_job_show', {id: resolvedDuplicateOriginalImportId, return_to: currentImportUrl}) }}" data-turbo-frame="_top">{{ 'import.action.open_original_import'|trans }}</a>
                {% else %}
                    <span class="muted compact-note">{{ 'admin.import.show.linked_resource_missing'|trans }}</span>
                {% endif %}
                <a class="btn btn-secondary btn-compact" href="{{ backToListUrl }}" data-turbo-frame="_top">{{ 'import.action.back_to_imports'|trans }}</a>
            </div>
        </section>
    {% endif %}

    {% if job.status.value == 'failed' %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.import.show.retry_failed_job'|trans }}</h3>
            <p class="muted">{{ 'admin.import.show.retry_failed_job_lead'|trans }}</p>
            <form method="post" action="{{ path('ui_admin_import_job_retry', {id: job.id.toString}) }}" data-turbo-frame="_top">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_retry_' ~ job.id.toString) }}">
                <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">
                <button class="btn btn-primary btn-compact" type="submit">{{ 'admin.import.show.retry_job'|trans }}</button>
            </form>
        </section>
    {% endif %}

    {% if job.status.value == 'needs_review' %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.import.show.fix_and_finalize'|trans }}</h3>
            <p class="muted">{{ 'admin.import.show.fix_and_finalize_lead'|trans }}</p>

            <form method="post" action="{{ path('ui_admin_import_job_finalize', {id: job.id.toString}) }}" data-turbo-frame="_top" class="form-stack">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_finalize_' ~ job.id.toString) }}">
                <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">

                <div class="form-grid-2">
                    <label class="label">
                        {{ 'admin.import.show.issued_at'|trans }}
                        <span class="muted compact-note">{{ (issuedAtMissing ? 'admin.import.show.issued_at_required_hint' : 'admin.import.show.issued_at_hint')|trans }}</span>
                        <input class="input" type="datetime-local" name="issuedAt" value="{{ creationPayload is not null and creationPayload.issuedAt is defined and creationPayload.issuedAt is not null ? creationPayload.issuedAt|date('Y-m-d\\\\TH:i') : (parsedDraft is not null and parsedDraft.issuedAt is defined and parsedDraft.issuedAt is not null ? parsedDraft.issuedAt|date('Y-m-d\\\\TH:i') : '') }}">
                    </label>
                    <label class="label">
                        {{ 'admin.import.show.station_name'|trans }}
                        <input class="input" type="text" name="stationName" value="{{ creationPayload is not null and creationPayload.stationName is defined ? creationPayload.stationName : (parsedDraft is not null and parsedDraft.stationName is defined ? parsedDraft.stationName : '') }}">
                    </label>
                    <label class="label">
                        {{ 'admin.import.show.station_street'|trans }}
                        <input class="input" type="text" name="stationStreetName" value="{{ creationPayload is not null and creationPayload.stationStreetName is defined ? creationPayload.stationStreetName : (parsedDraft is not null and parsedDraft.stationStreetName is defined ? parsedDraft.stationStreetName : '') }}">
                    </label>
                    <label class="label">
                        {{ 'admin.import.show.station_postal_code'|trans }}
                        <input class="input" type="text" name="stationPostalCode" value="{{ creationPayload is not null and creationPayload.stationPostalCode is defined ? creationPayload.stationPostalCode : (parsedDraft is not null and parsedDraft.stationPostalCode is defined ? parsedDraft.stationPostalCode : '') }}">
                    </label>
                    <label class="label">
                        {{ 'admin.import.show.station_city'|trans }}
                        <input class="input" type="text" name="stationCity" value="{{ creationPayload is not null and creationPayload.stationCity is defined ? creationPayload.stationCity : (parsedDraft is not null and parsedDraft.stationCity is defined ? parsedDraft.stationCity : '') }}">
                    </label>
                    <label class="label">
                        {{ 'admin.import.show.latitude_micro_degrees'|trans }}
                        <input class="input" type="number" name="latitudeMicroDegrees" value="{{ creationPayload is not null and creationPayload.latitudeMicroDegrees is defined ? creationPayload.latitudeMicroDegrees : '' }}" step="1">
                    </label>
                    <label class="label">
                        {{ 'admin.import.show.longitude_micro_degrees'|trans }}
                        <input class="input" type="number" name="longitudeMicroDegrees" value="{{ creationPayload is not null and creationPayload.longitudeMicroDegrees is defined ? creationPayload.longitudeMicroDegrees : '' }}" step="1">
                    </label>
                    <label class="label">
                        {{ 'admin.import.show.odometer'|trans }}
                        <input class="input" type="number" name="odometerKilometers" value="{{ creationPayload is not null and creationPayload.odometerKilometers is defined ? creationPayload.odometerKilometers : (parsedDraft is not null and parsedDraft.odometerKilometers is defined ? parsedDraft.odometerKilometers : '') }}" min="0" step="1">
                    </label>
                </div>

                <div class="form-stack">
                    <p class="text-block-title">{{ 'admin.import.show.receipt_lines'|trans }}</p>
                    {% if reviewLines|length > 0 %}
                        {% for line in reviewLines %}
                            <section class="card-subtle card-subtle-block">
                                <p class="compact-note muted">{{ 'admin.import.show.line_number'|trans({'%index%': loop.index}) }}</p>
                                <div class="form-grid-2">
                                    <label class="label">
                                        {{ 'receipt.form.fuel_type'|trans }}
                                        <input class="input" type="text" name="lines[{{ loop.index0 }}][fuelType]" value="{{ line.fuelType is defined ? line.fuelType : '' }}" placeholder="diesel">
                                    </label>
                                    <label class="label">
                                        {{ 'admin.import.show.quantity_ml'|trans }}
                                        <input class="input" type="number" name="lines[{{ loop.index0 }}][quantityMilliLiters]" value="{{ line.quantityMilliLiters is defined and line.quantityMilliLiters is not null ? line.quantityMilliLiters : '' }}" min="1" step="1">
                                    </label>
                                    <label class="label">
                                        {{ 'admin.import.show.unit_price_deci_cents'|trans }}
                                        <input class="input" type="number" name="lines[{{ loop.index0 }}][unitPriceDeciCentsPerLiter]" value="{{ line.unitPriceDeciCentsPerLiter is defined and line.unitPriceDeciCentsPerLiter is not null ? line.unitPriceDeciCentsPerLiter : '' }}" min="0" step="1">
                                    </label>
                                    <label class="label">
                                        {{ 'admin.import.show.vat_rate'|trans }}
                                        <input class="input" type="number" name="lines[{{ loop.index0 }}][vatRatePercent]" value="{{ line.vatRatePercent is defined and line.vatRatePercent is not null ? line.vatRatePercent : '' }}" min="0" max="100" step="1">
                                    </label>
                                </div>
                            </section>
                        {% endfor %}
                    {% else %}
                        <section class="card-subtle card-subtle-block">
                            <p class="muted">{{ 'admin.import.show.no_fuel_lines'|trans }}</p>
                            <div class="form-grid-2">
                                <label class="label">
                                    {{ 'receipt.form.fuel_type'|trans }}
                                    <input class="input" type="text" name="lines[0][fuelType]" value="" placeholder="diesel">
                                </label>
                                <label class="label">
                                    {{ 'admin.import.show.quantity_ml'|trans }}
                                    <input class="input" type="number" name="lines[0][quantityMilliLiters]" value="" min="1" step="1">
                                </label>
                                <label class="label">
                                    {{ 'admin.import.show.unit_price_deci_cents'|trans }}
                                    <input class="input" type="number" name="lines[0][unitPriceDeciCentsPerLiter]" value="" min="0" step="1">
                                </label>
                                <label class="label">
                                    {{ 'admin.import.show.vat_rate'|trans }}
                                    <input class="input" type="number" name="lines[0][vatRatePercent]" value="" min="0" max="100" step="1">
                                </label>
                            </div>
                        </section>
                    {% endif %}
                </div>

                <div class="actions-wrap">
                    <button class="btn btn-primary btn-compact" type="submit">{{ 'admin.import.show.finalize_job'|trans }}</button>
                    <a class="btn btn-secondary btn-compact" href="/api/docs">{{ 'admin.import.show.finalize_from_api_docs'|trans }}</a>
                </div>
            </form>
        </section>
    {% endif %}
{% endblock %}
