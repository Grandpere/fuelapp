{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Import Job Detail{% endblock %}

{% set admin_section = 'imports' %}

{% block admin_content %}
    {% set parsedDraft = payloadData is not null and payloadData.parsedDraft is defined and payloadData.parsedDraft is iterable ? payloadData.parsedDraft : null %}
    {% set creationPayload = payloadData is not null and payloadData.creationPayload is defined and payloadData.creationPayload is iterable ? payloadData.creationPayload : null %}
    {% set reviewLines = creationPayload is not null and creationPayload.lines is defined and creationPayload.lines is iterable ? creationPayload.lines : (parsedDraft is not null and parsedDraft.lines is defined and parsedDraft.lines is iterable ? parsedDraft.lines : []) %}
    {% set issueList = parsedDraft is not null and parsedDraft.issues is defined and parsedDraft.issues is iterable ? parsedDraft.issues : [] %}
    {% set issuedAtMissing = 'issued_at_missing' in issueList %}

    <section class="card admin-panel">
        <div class="admin-page-head">
            <div class="admin-page-header">
                <h2 class="page-title">Import Job Detail</h2>
                <p class="muted">Detailed payload and processing metadata for troubleshooting.</p>
            </div>
        </div>

        <dl class="admin-dl admin-table-top">
            <dt class="admin-dt">ID</dt>
            <dd class="admin-dd">{{ job.id.toString }}</dd>
            <dt class="admin-dt">Status</dt>
            <dd class="admin-dd">{{ job.status.value }}</dd>
            <dt class="admin-dt">Owner ID</dt>
            <dd class="admin-dd">{{ job.ownerId }}</dd>
            <dt class="admin-dt">Storage</dt>
            <dd class="admin-dd">{{ job.storage }}</dd>
            <dt class="admin-dt">File path</dt>
            <dd class="admin-dd">{{ job.filePath }}</dd>
            <dt class="admin-dt">Original filename</dt>
            <dd class="admin-dd">{{ job.originalFilename }}</dd>
            <dt class="admin-dt">Mime type</dt>
            <dd class="admin-dd">{{ job.mimeType }}</dd>
            <dt class="admin-dt">File size</dt>
            <dd class="admin-dd">{{ job.fileSizeBytes }} bytes</dd>
            <dt class="admin-dt">Checksum (sha256)</dt>
            <dd class="admin-dd">{{ job.fileChecksumSha256 }}</dd>
            <dt class="admin-dt">Created at</dt>
            <dd class="admin-dd">{{ job.createdAt|date('Y-m-d H:i:s') }}</dd>
            <dt class="admin-dt">Updated at</dt>
            <dd class="admin-dd">{{ job.updatedAt|date('Y-m-d H:i:s') }}</dd>
            <dt class="admin-dt">Started at</dt>
            <dd class="admin-dd">{{ job.startedAt ? job.startedAt|date('Y-m-d H:i:s') : 'n/a' }}</dd>
            <dt class="admin-dt">Completed at</dt>
            <dd class="admin-dd">{{ job.completedAt ? job.completedAt|date('Y-m-d H:i:s') : 'n/a' }}</dd>
            <dt class="admin-dt">Failed at</dt>
            <dd class="admin-dd">{{ job.failedAt ? job.failedAt|date('Y-m-d H:i:s') : 'n/a' }}</dd>
        </dl>

        {% if triageSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">Triage summary</p>
                <dl class="admin-dl">
                    {% for label, value in triageSummary %}
                        <dt class="admin-dt">{{ label }}</dt>
                        <dd class="admin-dd">{{ value }}</dd>
                    {% endfor %}
                </dl>
            </div>
        {% endif %}

        <div class="card-subtle card-subtle-block admin-table-top">
            <p class="text-block-title">Triage readout</p>
            <dl class="admin-dl">
                <dt class="admin-dt">Probable cause</dt>
                <dd class="admin-dd">{{ triageReadout.probableCause }}</dd>
                <dt class="admin-dt">Next best action</dt>
                <dd class="admin-dd">{{ triageReadout.nextAction }}</dd>
                {% if triageReadout.operatorNote is not null %}
                    <dt class="admin-dt">Operator note</dt>
                    <dd class="admin-dd">{{ triageReadout.operatorNote }}</dd>
                {% endif %}
            </dl>
        </div>

        {% if payloadData is not null %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">Decoded payload</p>
                <pre class="preformatted-block">{{ payloadData|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
            </div>
        {% elseif payload %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">Raw payload</p>
                <pre class="preformatted-block">{{ payload }}</pre>
            </div>
        {% else %}
            <p class="muted admin-table-top">No payload available.</p>
        {% endif %}

        <div class="actions-wrap admin-table-top">
            <a class="btn btn-secondary" href="{{ backToListUrl }}" data-turbo-frame="_top">Back to list</a>
            <a class="btn btn-secondary" href="/api/imports/{{ job.id.toString }}" data-turbo-frame="_top">Open user API resource</a>
            <a class="btn btn-secondary" href="/api/admin/imports/{{ job.id.toString }}/retry" data-turbo-frame="_top">Open admin retry endpoint</a>
            {% if job.status.value == 'needs_review' %}
                <form method="post" action="{{ path('ui_admin_import_job_reparse', {id: job.id.toString}) }}" data-turbo-frame="_top">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_import_reparse_' ~ job.id.toString) }}">
                    <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">
                    <button class="btn btn-secondary" type="submit">Reparse</button>
                </form>
            {% endif %}
            <form method="post" action="{{ path('ui_admin_import_job_delete', {id: job.id.toString}) }}" data-turbo-frame="_top" onsubmit="return confirm('Delete this import job and source file?');">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_delete_' ~ job.id.toString) }}">
                <input type="hidden" name="_redirect" value="{{ backToListUrl }}">
                <button class="btn btn-danger" type="submit">Delete</button>
            </form>
        </div>

        {% if statusActions is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">Next step</p>
                <div class="actions-wrap">
                    {% for action in statusActions %}
                        <a class="btn {{ action.variant == 'primary' ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ action.url }}" data-turbo-frame="_top">{{ action.label }}</a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {% if receiptContinuity is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <p class="text-block-title">Receipt continuity</p>
                <div class="actions-wrap">
                    {% for action in receiptContinuity %}
                        <a class="btn {{ action.variant == 'primary' ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ action.url }}" data-turbo-frame="_top">{{ action.label }}</a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </section>

    {% if payloadData is not null and payloadData.fallbackReason is defined %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">OCR fallback</h3>
            <p class="muted">
                {{ payloadData.fallbackNotice is defined ? payloadData.fallbackNotice : 'Automatic OCR is temporarily unavailable. Manual review remains available with the original uploaded file.' }}
            </p>
            <div class="actions-wrap">
                <span class="pill status-pill status-needs_review">{{ payloadData.fallbackStrategy is defined ? payloadData.fallbackStrategy|replace({'_': ' '}) : 'manual review' }}</span>
                <span class="muted compact-note">{{ payloadData.fallbackReason }}</span>
            </div>
        </section>
    {% endif %}

    {% if issueList|length > 0 %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">Detected issues</h3>
            <p class="muted">{{ issueList|join(', ') }}</p>
        </section>
    {% endif %}

    {% if issuedAtMissing %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">Date required before finalization</h3>
            <p class="muted">OCR could not read the receipt date. Enter the receipt date and time below before finalizing this import.</p>
        </section>
    {% endif %}

    {% if job.status.value == 'processed' %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">Import completed</h3>
            <p class="muted">This import already created a receipt. Jump straight to the resulting receipt from here.</p>
            <div class="actions-wrap">
                {% if resolvedFinalizedReceiptId is not null %}
                    <a class="btn btn-primary btn-compact" href="{{ path('ui_admin_receipt_show', {id: resolvedFinalizedReceiptId, return_to: currentImportUrl}) }}" data-turbo-frame="_top">Open created receipt</a>
                {% else %}
                    <span class="muted compact-note">The linked receipt is no longer available.</span>
                {% endif %}
                <a class="btn btn-secondary btn-compact" href="{{ backToListUrl }}" data-turbo-frame="_top">Back to queue</a>
            </div>
        </section>
    {% elseif job.status.value == 'duplicate' %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">Duplicate import</h3>
            <p class="muted">This job matches an existing receipt or previously uploaded import. Open the existing record directly from here.</p>
            <div class="actions-wrap">
                {% if resolvedDuplicateReceiptId is not null %}
                    <a class="btn btn-primary btn-compact" href="{{ path('ui_admin_receipt_show', {id: resolvedDuplicateReceiptId, return_to: currentImportUrl}) }}" data-turbo-frame="_top">Open existing receipt</a>
                {% elseif resolvedDuplicateOriginalImportId is not null %}
                    <a class="btn btn-primary btn-compact" href="{{ path('ui_admin_import_job_show', {id: resolvedDuplicateOriginalImportId, return_to: currentImportUrl}) }}" data-turbo-frame="_top">Open original import</a>
                {% else %}
                    <span class="muted compact-note">The linked receipt or original import is no longer available.</span>
                {% endif %}
                <a class="btn btn-secondary btn-compact" href="{{ backToListUrl }}" data-turbo-frame="_top">Back to queue</a>
            </div>
        </section>
    {% endif %}

    {% if job.status.value == 'failed' %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">Retry Failed Job</h3>
            <p class="muted">Queue this failed import job for async reprocessing, then come straight back here to continue the investigation.</p>
            <form method="post" action="{{ path('ui_admin_import_job_retry', {id: job.id.toString}) }}" data-turbo-frame="_top">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_retry_' ~ job.id.toString) }}">
                <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">
                <button class="btn btn-primary btn-compact" type="submit">Retry job</button>
            </form>
        </section>
    {% endif %}

    {% if job.status.value == 'needs_review' %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">Fix And Finalize</h3>
            <p class="muted">Optional corrections can be provided before finalization. Leave fields empty to use payload values and stay anchored to this queue context after submit.</p>

            <form method="post" action="{{ path('ui_admin_import_job_finalize', {id: job.id.toString}) }}" data-turbo-frame="_top" class="form-stack">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_finalize_' ~ job.id.toString) }}">
                <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">

                <div class="form-grid-2">
                    <label class="label">
                        Issued at
                        <span class="muted compact-note">{{ issuedAtMissing ? 'Required for this import: OCR did not detect the receipt date.' : 'Use the receipt date/time. Leave empty only when OCR already filled it.' }}</span>
                        <input class="input" type="datetime-local" name="issuedAt" value="{{ creationPayload is not null and creationPayload.issuedAt is defined and creationPayload.issuedAt is not null ? creationPayload.issuedAt|date('Y-m-d\\\\TH:i') : (parsedDraft is not null and parsedDraft.issuedAt is defined and parsedDraft.issuedAt is not null ? parsedDraft.issuedAt|date('Y-m-d\\\\TH:i') : '') }}">
                    </label>
                    <label class="label">
                        Station name
                        <input class="input" type="text" name="stationName" value="{{ creationPayload is not null and creationPayload.stationName is defined ? creationPayload.stationName : (parsedDraft is not null and parsedDraft.stationName is defined ? parsedDraft.stationName : '') }}">
                    </label>
                    <label class="label">
                        Station street
                        <input class="input" type="text" name="stationStreetName" value="{{ creationPayload is not null and creationPayload.stationStreetName is defined ? creationPayload.stationStreetName : (parsedDraft is not null and parsedDraft.stationStreetName is defined ? parsedDraft.stationStreetName : '') }}">
                    </label>
                    <label class="label">
                        Station postal code
                        <input class="input" type="text" name="stationPostalCode" value="{{ creationPayload is not null and creationPayload.stationPostalCode is defined ? creationPayload.stationPostalCode : (parsedDraft is not null and parsedDraft.stationPostalCode is defined ? parsedDraft.stationPostalCode : '') }}">
                    </label>
                    <label class="label">
                        Station city
                        <input class="input" type="text" name="stationCity" value="{{ creationPayload is not null and creationPayload.stationCity is defined ? creationPayload.stationCity : (parsedDraft is not null and parsedDraft.stationCity is defined ? parsedDraft.stationCity : '') }}">
                    </label>
                    <label class="label">
                        Latitude (micro degrees)
                        <input class="input" type="number" name="latitudeMicroDegrees" value="{{ creationPayload is not null and creationPayload.latitudeMicroDegrees is defined ? creationPayload.latitudeMicroDegrees : '' }}" step="1">
                    </label>
                    <label class="label">
                        Longitude (micro degrees)
                        <input class="input" type="number" name="longitudeMicroDegrees" value="{{ creationPayload is not null and creationPayload.longitudeMicroDegrees is defined ? creationPayload.longitudeMicroDegrees : '' }}" step="1">
                    </label>
                    <label class="label">
                        Odometer (km)
                        <input class="input" type="number" name="odometerKilometers" value="{{ creationPayload is not null and creationPayload.odometerKilometers is defined ? creationPayload.odometerKilometers : (parsedDraft is not null and parsedDraft.odometerKilometers is defined ? parsedDraft.odometerKilometers : '') }}" min="0" step="1">
                    </label>
                </div>

                <div class="form-stack">
                    <p class="text-block-title">Receipt lines</p>
                    {% if reviewLines|length > 0 %}
                        {% for line in reviewLines %}
                            <section class="card-subtle card-subtle-block">
                                <p class="compact-note muted">Line {{ loop.index }}</p>
                                <div class="form-grid-2">
                                    <label class="label">
                                        Fuel type
                                        <input class="input" type="text" name="lines[{{ loop.index0 }}][fuelType]" value="{{ line.fuelType is defined ? line.fuelType : '' }}" placeholder="diesel">
                                    </label>
                                    <label class="label">
                                        Quantity (mL)
                                        <input class="input" type="number" name="lines[{{ loop.index0 }}][quantityMilliLiters]" value="{{ line.quantityMilliLiters is defined and line.quantityMilliLiters is not null ? line.quantityMilliLiters : '' }}" min="1" step="1">
                                    </label>
                                    <label class="label">
                                        Unit price (deci-cents/L)
                                        <input class="input" type="number" name="lines[{{ loop.index0 }}][unitPriceDeciCentsPerLiter]" value="{{ line.unitPriceDeciCentsPerLiter is defined and line.unitPriceDeciCentsPerLiter is not null ? line.unitPriceDeciCentsPerLiter : '' }}" min="0" step="1">
                                    </label>
                                    <label class="label">
                                        VAT rate (%)
                                        <input class="input" type="number" name="lines[{{ loop.index0 }}][vatRatePercent]" value="{{ line.vatRatePercent is defined and line.vatRatePercent is not null ? line.vatRatePercent : '' }}" min="0" max="100" step="1">
                                    </label>
                                </div>
                            </section>
                        {% endfor %}
                    {% else %}
                        <section class="card-subtle card-subtle-block">
                            <p class="muted">No fuel lines were parsed. Add one manually below if you want to finalize this import.</p>
                            <div class="form-grid-2">
                                <label class="label">
                                    Fuel type
                                    <input class="input" type="text" name="lines[0][fuelType]" value="" placeholder="diesel">
                                </label>
                                <label class="label">
                                    Quantity (mL)
                                    <input class="input" type="number" name="lines[0][quantityMilliLiters]" value="" min="1" step="1">
                                </label>
                                <label class="label">
                                    Unit price (deci-cents/L)
                                    <input class="input" type="number" name="lines[0][unitPriceDeciCentsPerLiter]" value="" min="0" step="1">
                                </label>
                                <label class="label">
                                    VAT rate (%)
                                    <input class="input" type="number" name="lines[0][vatRatePercent]" value="" min="0" max="100" step="1">
                                </label>
                            </div>
                        </section>
                    {% endif %}
                </div>

                <div class="actions-wrap">
                    <button class="btn btn-primary btn-compact" type="submit">Finalize job</button>
                    <a class="btn btn-secondary btn-compact" href="/api/docs">Finalize from API docs</a>
                </div>
            </form>
        </section>
    {% endif %}
{% endblock %}
