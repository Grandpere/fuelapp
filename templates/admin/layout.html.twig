{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-shell {
            --admin-sidebar-width: 260px;
            --admin-sidebar-rail-width: 3.4rem;
            max-width: 1520px;
            margin: 0 auto;
            padding: 1rem 1rem 2rem;
            display: grid;
            gap: 1rem;
            grid-template-columns: var(--admin-sidebar-width) minmax(0, 1fr);
            position: relative;
            align-items: start;
        }

        .admin-shell[data-admin-sidebar-collapsed='true'] {
            grid-template-columns: var(--admin-sidebar-rail-width) minmax(0, 1fr);
        }

        .admin-sidebar {
            padding: 1rem;
            position: sticky;
            top: 1rem;
            height: fit-content;
        }

        .admin-shell[data-admin-sidebar-collapsed='true'] .admin-sidebar {
            display: none;
        }

        .admin-sidebar-toggle-shell {
            display: none;
        }

        .admin-shell[data-admin-sidebar-collapsed='true'] .admin-sidebar-toggle-shell {
            display: block;
            position: sticky;
            top: 1rem;
            align-self: start;
            z-index: 5;
        }

        .admin-sidebar-toggle {
            min-width: 0;
            width: 2.2rem;
            height: 2.2rem;
            padding: 0;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.95rem;
            line-height: 1;
        }

        .admin-sidebar-collapsed-rail {
            width: var(--admin-sidebar-rail-width);
            padding: 0.6rem 0.5rem;
            display: grid;
            justify-items: center;
            gap: 0.5rem;
            height: fit-content;
        }

        .admin-sidebar-collapsed-label {
            writing-mode: vertical-rl;
            transform: rotate(180deg);
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--text-soft);
            font-weight: 700;
        }

        .admin-sidebar-head {
            display: flex;
            align-items: start;
            justify-content: space-between;
            gap: 0.75rem;
        }

        .admin-sidebar-title-block {
            min-width: 0;
        }

        .admin-title {
            margin: 0;
            font-family: var(--font-display);
            font-size: 1.1rem;
        }

        .admin-subtitle {
            margin: 0.35rem 0 0;
            color: var(--text-soft);
            font-size: 0.82rem;
        }

        .admin-nav {
            margin-top: 1rem;
            display: grid;
            gap: 0.5rem;
        }

        .admin-sidebar-actions {
            margin-top: 1rem;
            display: grid;
            gap: 0.6rem;
        }

        .admin-nav-link {
            display: block;
            padding: 0.62rem 0.72rem;
            border-radius: 10px;
            text-decoration: none;
            border: 1px solid var(--surface-soft-border);
            background: var(--surface-soft-bg);
            color: var(--text);
            font-weight: 600;
            font-size: 0.88rem;
        }

        .admin-nav-link.is-active {
            border-color: rgba(247, 181, 0, 0.6);
            background: rgba(247, 181, 0, 0.15);
            color: var(--text-strong);
        }

        .admin-main {
            min-width: 0;
            display: grid;
            gap: 1rem;
            align-content: start;
        }

        .admin-panel {
            padding: 1.1rem;
        }

        .admin-section-spaced {
            margin-top: 1rem;
        }

        .admin-metric-grid {
            display: grid;
            gap: 0.9rem;
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .admin-metric-card {
            padding: 0.9rem;
        }

        .admin-metric-label {
            margin: 0;
            font-size: 0.78rem;
            color: var(--text-soft);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .admin-metric-value {
            margin: 0.35rem 0 0;
            font-family: var(--font-display);
            font-size: 2rem;
            line-height: 1;
        }

        .admin-inline-list {
            margin: 0;
            padding: 0;
            list-style: none;
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .admin-dl {
            margin: 0;
            display: grid;
            grid-template-columns: minmax(140px, 220px) minmax(0, 1fr);
            gap: 0.55rem 1rem;
        }

        .admin-dt {
            color: var(--text-soft);
            font-size: 0.83rem;
        }

        .admin-dd {
            margin: 0;
            font-weight: 600;
            word-break: break-word;
        }

        .admin-filters-form {
            margin-top: 0.9rem;
            display: grid;
            gap: 0.75rem;
        }

        .admin-page-head {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 0.8rem;
            align-items: start;
        }

        .admin-page-header {
            display: grid;
            gap: 0.35rem;
        }

        .admin-page-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .admin-request-correlation {
            display: grid;
            gap: 0.45rem;
            padding: 0.85rem 1rem;
        }

        .admin-request-correlation code {
            word-break: break-all;
        }

        .admin-filter-grid-4,
        .admin-filter-grid-5 {
            display: grid;
            gap: 0.6rem;
            align-items: end;
        }

        .admin-filter-grid-4 {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .admin-filter-grid-5 {
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .admin-form-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .admin-detail-stack {
            margin-top: 1rem;
        }

        .admin-table-top {
            margin-top: 1rem;
        }

        .admin-dashboard-columns,
        .admin-dashboard-list {
            display: grid;
            gap: 0.9rem;
        }

        .admin-dashboard-columns {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .admin-dashboard-item {
            display: grid;
            gap: 0.7rem;
        }

        .admin-dashboard-item-head {
            display: flex;
            gap: 0.8rem;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .admin-dashboard-item-value {
            font-family: var(--font-display);
            font-size: 1.35rem;
            line-height: 1;
        }

        @media (max-width: 980px) {
            .admin-shell {
                grid-template-columns: 1fr;
            }

            .admin-sidebar-toggle-shell {
                display: none;
            }

            .admin-sidebar {
                position: static;
            }

            .admin-dashboard-columns,
            .admin-metric-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .admin-page-head,
            .admin-filter-grid-4,
            .admin-filter-grid-5 {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .admin-dashboard-columns,
            .admin-metric-grid {
                grid-template-columns: 1fr;
            }

            .admin-dl {
                grid-template-columns: 1fr;
                gap: 0.2rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="admin-shell" data-admin-shell>
        <div class="admin-sidebar-toggle-shell">
            <div class="card admin-sidebar-collapsed-rail">
                <button
                    class="btn btn-secondary btn-compact admin-sidebar-toggle"
                    type="button"
                    data-admin-sidebar-toggle
                    aria-expanded="false"
                    aria-label="Show admin menu"
                    title="Show admin menu"
                >
                    <span aria-hidden="true">▶</span>
                </button>
                <span class="admin-sidebar-collapsed-label">Admin</span>
            </div>
        </div>

        <aside class="admin-sidebar card" aria-label="Navigation admin">
            <div class="admin-sidebar-head">
                <div class="admin-sidebar-title-block">
                    <h1 class="admin-title">Back-office</h1>
                    <p class="admin-subtitle">Operations and system management</p>
                </div>
                <button
                    class="btn btn-secondary btn-compact admin-sidebar-toggle"
                    type="button"
                    data-admin-sidebar-toggle
                    aria-expanded="true"
                    aria-label="Hide admin menu"
                    title="Hide admin menu"
                >
                    <span aria-hidden="true">◀</span>
                </button>
            </div>
            <div class="admin-sidebar-actions">
                <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index') }}">Back to app</a>
            </div>
            <nav class="admin-nav">
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'dashboard' ? 'is-active' : '' }}" href="{{ path('ui_admin_dashboard') }}">Dashboard</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'users' ? 'is-active' : '' }}" href="{{ path('ui_admin_user_list') }}">Users</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'identities' ? 'is-active' : '' }}" href="{{ path('ui_admin_identity_list') }}">Identities</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'stations' ? 'is-active' : '' }}" href="{{ path('ui_admin_station_list') }}">Stations</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'receipts' ? 'is-active' : '' }}" href="{{ path('ui_admin_receipt_list') }}">Receipts</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'vehicles' ? 'is-active' : '' }}" href="{{ path('ui_admin_vehicle_list') }}">Vehicles</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'maintenance_events' ? 'is-active' : '' }}" href="{{ path('ui_admin_maintenance_event_list') }}">Maintenance Events</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'maintenance_reminders' ? 'is-active' : '' }}" href="{{ path('ui_admin_maintenance_reminder_list') }}">Maintenance Reminders</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'imports' ? 'is-active' : '' }}" href="{{ path('ui_admin_import_job_list') }}">Imports</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'security_activities' ? 'is-active' : '' }}" href="{{ path('ui_admin_security_activity_list') }}">Security Activities</a>
                <a class="admin-nav-link {{ admin_section is defined and admin_section == 'audit' ? 'is-active' : '' }}" href="{{ path('ui_admin_audit_log_list') }}">Audit Logs</a>
            </nav>
        </aside>

        <main class="admin-main">
            {% set requestCorrelationId = app.request.attributes.get('_correlation_id') %}
            {% if requestCorrelationId %}
                <section class="card card-subtle admin-request-correlation">
                    <div class="admin-page-head">
                        <div class="admin-page-header">
                            <strong>Request correlation</strong>
                            <p class="muted compact-note">Keep this id when a support action or rendering issue needs log or audit follow-up.</p>
                        </div>
                        <div class="admin-page-actions">
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_audit_log_list', {correlationId: requestCorrelationId}) }}">Audit trail</a>
                        </div>
                    </div>
                    <code>{{ requestCorrelationId }}</code>
                </section>
            {% endif %}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash{{ label == 'error' ? ' flash-error' : '' }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
            {% block admin_content %}{% endblock %}
        </main>
    </div>

    <script>
        (function () {
            const storageKey = 'fuelapp.adminSidebarCollapsed';
            const shell = document.querySelector('[data-admin-shell]');
            const toggles = Array.from(document.querySelectorAll('[data-admin-sidebar-toggle]'));

            if (!shell || toggles.length === 0) {
                return;
            }

            const syncState = (collapsed) => {
                shell.dataset.adminSidebarCollapsed = collapsed ? 'true' : 'false';
                toggles.forEach((toggle) => {
                    toggle.innerHTML = '<span aria-hidden="true">' + (collapsed ? '▶' : '◀') + '</span>';
                    toggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
                    toggle.setAttribute('aria-label', collapsed ? 'Show admin menu' : 'Hide admin menu');
                    toggle.setAttribute('title', collapsed ? 'Show admin menu' : 'Hide admin menu');
                });
            };

            let collapsed = false;

            try {
                collapsed = window.localStorage.getItem(storageKey) === 'true';
            } catch (error) {
                collapsed = false;
            }

            syncState(collapsed);

            toggles.forEach((toggle) => {
                toggle.addEventListener('click', () => {
                    collapsed = !collapsed;
                    syncState(collapsed);

                    try {
                        window.localStorage.setItem(storageKey, collapsed ? 'true' : 'false');
                    } catch (error) {
                    }
                });
            });
        }());
    </script>
{% endblock %}
