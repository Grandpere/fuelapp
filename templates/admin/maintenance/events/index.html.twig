{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.maintenance_events.title'|trans }}{% endblock %}

{% set admin_section = 'maintenance_events' %}

{% block admin_content %}
    {% set returnTo = app.request.requestUri %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">{{ 'admin.maintenance_events.title'|trans }}</h2>
            <p class="muted">{{ 'admin.maintenance_events.lead'|trans }}</p>
        </div>

        <form method="get" action="{{ path('ui_admin_maintenance_event_list') }}" class="admin-filters-form">
            <div class="form-grid-2 admin-table-top">
                <label class="label">
                    {{ 'admin.maintenance_events.filters.owner'|trans }}
                    <select class="select" name="owner_id">
                        <option value="">{{ 'admin.maintenance_events.filters.all_owners'|trans }}</option>
                        {% for owner in ownerOptions %}
                            <option value="{{ owner.id }}" {% if filters.ownerId == owner.id %}selected{% endif %}>{{ owner.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    {{ 'admin.maintenance_events.filters.vehicle'|trans }}
                    <select class="select" name="vehicle_id">
                        <option value="">{{ 'admin.maintenance_events.filters.all_vehicles'|trans }}</option>
                        {% for vehicle in vehicleOptions %}
                            <option value="{{ vehicle.id }}" {% if filters.vehicleId == vehicle.id %}selected{% endif %}>{{ vehicle.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    {{ 'admin.maintenance_events.filters.event_type'|trans }}
                    <select class="select" name="event_type">
                        <option value="">{{ 'admin.maintenance_events.filters.all'|trans }}</option>
                        {% for eventType in eventTypeOptions %}
                            <option value="{{ eventType }}" {% if filters.eventType == eventType %}selected{% endif %}>{{ eventType|upper }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    {{ 'admin.maintenance_events.filters.occurred_from'|trans }}
                    <input class="input" type="text" name="occurred_from" data-datepicker="date" value="{{ filters.occurredFrom }}" autocomplete="off">
                </label>
                <label class="label">
                    {{ 'admin.maintenance_events.filters.occurred_to'|trans }}
                    <input class="input" type="text" name="occurred_to" data-datepicker="date" value="{{ filters.occurredTo }}" autocomplete="off">
                </label>
            </div>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">{{ 'action.apply'|trans }}</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_maintenance_event_list') }}">{{ 'action.reset'|trans }}</a>
            </div>
        </form>

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.common.active_filters'|trans }}</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_list') }}">{{ 'action.reset'|trans }}</a>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if filters.vehicleId %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.maintenance_events.support_toolkit_title'|trans }}</strong>
                        <p class="muted compact-note">{{ 'admin.maintenance_events.support_toolkit_lead'|trans }}</p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_show', {id: filters.vehicleId, return_to: returnTo}) }}">{{ 'nav.vehicles'|trans }}</a>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_list', {vehicle_id: filters.vehicleId}) }}">{{ 'nav.receipts'|trans }}</a>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_reminder_list', {vehicle_id: filters.vehicleId, event_type: filters.eventType}) }}">{{ 'nav.maintenance'|trans }}</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="table-wrap admin-table-top table-min-1040">
            <table class="app-table">
                <thead>
                <tr>
                    <th>{{ 'admin.maintenance_events.table.occurred_at'|trans }}</th>
                    <th>{{ 'admin.maintenance_events.table.event_type'|trans }}</th>
                    <th>{{ 'admin.maintenance_events.table.owner_id'|trans }}</th>
                    <th>{{ 'nav.vehicles'|trans }}</th>
                    <th>{{ 'admin.maintenance_events.table.cost'|trans }}</th>
                    <th>{{ 'receipt.show.odometer'|trans }}</th>
                    <th>{{ 'maintenance.form.description'|trans }}</th>
                    <th>{{ 'common.actions'|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for event in events %}
                    <tr
                        class="table-row row-link"
                        data-controller="row-link"
                        data-action="click->row-link#navigate"
                        data-row-link-url-value="{{ path('ui_admin_maintenance_event_show', {id: event.event.id.toString, return_to: returnTo}) }}"
                        onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                    >
                        <td>{{ event.event.occurredAt|date('Y-m-d H:i') }}</td>
                        <td><span class="pill pill-energy">{{ event.event.eventType.value }}</span></td>
                        <td><code>{{ event.event.ownerId }}</code></td>
                        <td>
                            {% if event.vehicle %}
                                <div>{{ event.vehicle.name() }}</div>
                                <div class="muted compact-note"><code>{{ event.event.vehicleId }}</code></div>
                            {% else %}
                                <code>{{ event.event.vehicleId }}</code>
                            {% endif %}
                        </td>
                        <td>
                            {% if event.event.totalCostCents is not null %}
                                {{ (event.event.totalCostCents / 100)|number_format(2, '.', ' ') }} {{ event.event.currencyCode }}
                            {% else %}
                                <span class="muted">{{ 'common.na'|trans }}</span>
                            {% endif %}
                        </td>
                        <td>{{ event.event.odometerKilometers ?? ('common.na'|trans) }}</td>
                        <td>{{ event.event.description ?? ('common.na'|trans) }}</td>
                        <td class="action-cell-flex" data-row-link-ignore>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_show', {id: event.event.id.toString, return_to: returnTo}) }}" data-turbo-frame="_top">{{ 'action.open'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_edit', {id: event.event.id.toString, return_to: returnTo}) }}" data-turbo-frame="_top">{{ 'action.edit'|trans }}</a>
                            {% if event.vehicle %}
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_show', {id: event.vehicle.id().toString(), return_to: returnTo}) }}" data-turbo-frame="_top">{{ 'nav.vehicles'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_list', {vehicle_id: event.vehicle.id().toString()}) }}" data-turbo-frame="_top">{{ 'nav.receipts'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_reminder_list', {vehicle_id: event.vehicle.id().toString(), event_type: event.event.eventType.value}) }}" data-turbo-frame="_top">{{ 'admin.maintenance_events.shortcuts.reminders'|trans }}</a>
                            {% endif %}
                            <form method="post" action="{{ path('ui_admin_maintenance_event_delete', {id: event.event.id.toString}) }}" data-turbo-frame="_top" onsubmit="return confirm('{{ 'admin.maintenance_events.confirm_delete'|trans }}');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_maintenance_event_delete_' ~ event.event.id.toString) }}">
                                <input type="hidden" name="_redirect" value="{{ returnTo }}">
                                <button class="btn btn-danger btn-compact" type="submit">{{ 'action.delete'|trans }}</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="muted">{{ 'admin.maintenance_events.empty'|trans }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
