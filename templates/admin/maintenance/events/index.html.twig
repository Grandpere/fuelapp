{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Maintenance Events{% endblock %}

{% set admin_section = 'maintenance_events' %}

{% block admin_content %}
    {% set returnTo = app.request.requestUri %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">Maintenance Events</h2>
            <p class="muted">Cross-owner timeline of maintenance operations.</p>
        </div>

        <form method="get" action="{{ path('ui_admin_maintenance_event_list') }}" class="admin-filters-form">
            <div class="form-grid-2 admin-table-top">
                <label class="label">
                    Owner ID
                    <input class="input" type="text" name="owner_id" value="{{ filters.ownerId }}" placeholder="UUID v7">
                </label>
                <label class="label">
                    Vehicle ID
                    <input class="input" type="text" name="vehicle_id" value="{{ filters.vehicleId }}" placeholder="UUID v7">
                </label>
                <label class="label">
                    Event type
                    <select class="select" name="event_type">
                        <option value="">All</option>
                        {% for eventType in eventTypeOptions %}
                            <option value="{{ eventType }}" {% if filters.eventType == eventType %}selected{% endif %}>{{ eventType|upper }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    Occurred from
                    <input class="input" type="text" name="occurred_from" data-datepicker="date" value="{{ filters.occurredFrom }}" autocomplete="off">
                </label>
                <label class="label">
                    Occurred to
                    <input class="input" type="text" name="occurred_to" data-datepicker="date" value="{{ filters.occurredTo }}" autocomplete="off">
                </label>
            </div>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">Apply</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_maintenance_event_list') }}">Reset</a>
            </div>
        </form>

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>Active filters</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_list') }}">Reset</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="table-wrap admin-table-top table-min-1040">
            <table class="app-table">
                <thead>
                <tr>
                    <th>Occurred</th>
                    <th>Type</th>
                    <th>Owner ID</th>
                    <th>Vehicle</th>
                    <th>Cost</th>
                    <th>Odometer</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for event in events %}
                    <tr
                        class="table-row row-link"
                        data-controller="row-link"
                        data-action="click->row-link#navigate"
                        data-row-link-url-value="{{ path('ui_admin_maintenance_event_show', {id: event.event.id.toString, return_to: returnTo}) }}"
                        onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                    >
                        <td>{{ event.event.occurredAt|date('Y-m-d H:i') }}</td>
                        <td><span class="pill pill-energy">{{ event.event.eventType.value }}</span></td>
                        <td><code>{{ event.event.ownerId }}</code></td>
                        <td>
                            {% if event.vehicle %}
                                <div>{{ event.vehicle.name() }}</div>
                                <div class="muted compact-note"><code>{{ event.event.vehicleId }}</code></div>
                            {% else %}
                                <code>{{ event.event.vehicleId }}</code>
                            {% endif %}
                        </td>
                        <td>
                            {% if event.event.totalCostCents is not null %}
                                {{ (event.event.totalCostCents / 100)|number_format(2, '.', ' ') }} {{ event.event.currencyCode }}
                            {% else %}
                                <span class="muted">n/a</span>
                            {% endif %}
                        </td>
                        <td>{{ event.event.odometerKilometers ?? 'n/a' }}</td>
                        <td>{{ event.event.description ?? 'n/a' }}</td>
                        <td class="action-cell-flex" data-row-link-ignore>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_show', {id: event.event.id.toString, return_to: returnTo}) }}" data-turbo-frame="_top">Open</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_edit', {id: event.event.id.toString, return_to: returnTo}) }}" data-turbo-frame="_top">Edit</a>
                            {% if event.vehicle %}
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_show', {id: event.vehicle.id().toString(), return_to: returnTo}) }}" data-turbo-frame="_top">Vehicle</a>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_reminder_list', {vehicle_id: event.vehicle.id().toString()}) }}" data-turbo-frame="_top">Reminders</a>
                            {% endif %}
                            <form method="post" action="{{ path('ui_admin_maintenance_event_delete', {id: event.event.id.toString}) }}" data-turbo-frame="_top" onsubmit="return confirm('Delete this maintenance event?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_maintenance_event_delete_' ~ event.event.id.toString) }}">
                                <input type="hidden" name="_redirect" value="{{ returnTo }}">
                                <button class="btn btn-danger btn-compact" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="muted">No maintenance events found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
