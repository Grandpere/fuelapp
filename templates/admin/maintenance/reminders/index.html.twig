{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Maintenance Reminders{% endblock %}

{% set admin_section = 'maintenance_reminders' %}

{% block admin_content %}
    {% set returnTo = app.request.requestUri %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">Maintenance Reminders</h2>
            <p class="muted">Triggered reminder states produced by scheduler evaluation.</p>
        </div>

        <div class="admin-metric-grid admin-table-top">
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">Due by date</p>
                <p class="admin-metric-value">{{ metrics.date|default(0) }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">Due by odometer</p>
                <p class="admin-metric-value">{{ metrics.odometer|default(0) }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">Due by both</p>
                <p class="admin-metric-value">{{ metrics.both|default(0) }}</p>
            </article>
        </div>

        <form method="get" action="{{ path('ui_admin_maintenance_reminder_list') }}" class="admin-filters-form">
            <div class="form-grid-2 admin-table-top">
                <label class="label">
                    Owner ID
                    <input class="input" type="text" name="owner_id" value="{{ filters.ownerId }}" placeholder="UUID v7">
                </label>
                <label class="label">
                    Vehicle ID
                    <input class="input" type="text" name="vehicle_id" value="{{ filters.vehicleId }}" placeholder="UUID v7">
                </label>
                <label class="label">
                    Due by
                    <select class="select" name="due_by">
                        <option value="">All</option>
                        <option value="date" {% if filters.dueBy == 'date' %}selected{% endif %}>Date</option>
                        <option value="odometer" {% if filters.dueBy == 'odometer' %}selected{% endif %}>Odometer</option>
                        <option value="both" {% if filters.dueBy == 'both' %}selected{% endif %}>Both</option>
                    </select>
                </label>
                <label class="label">
                    Due from
                    <input class="input" type="text" name="due_from" data-datepicker="date" value="{{ filters.dueFrom }}" autocomplete="off">
                </label>
                <label class="label">
                    Due to
                    <input class="input" type="text" name="due_to" data-datepicker="date" value="{{ filters.dueTo }}" autocomplete="off">
                </label>
            </div>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">Apply</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_maintenance_reminder_list') }}">Reset</a>
            </div>
        </form>

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>Active filters</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_reminder_list') }}">Reset</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="table-wrap admin-table-top table-min-1020">
            <table class="app-table">
                <thead>
                <tr>
                    <th>Created</th>
                    <th>Rule</th>
                    <th>Owner ID</th>
                    <th>Vehicle</th>
                    <th>Due date</th>
                    <th>Due odometer</th>
                    <th>State</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for reminder in reminders %}
                    <tr
                        class="table-row row-link"
                        data-controller="row-link"
                        data-action="click->row-link#navigate"
                        data-row-link-url-value="{{ path('ui_admin_maintenance_reminder_show', {id: reminder.reminder.id.toString, return_to: returnTo}) }}"
                        onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                    >
                        <td>{{ reminder.reminder.createdAt|date('Y-m-d H:i') }}</td>
                        <td>{{ ruleNames[reminder.reminder.ruleId] ?? reminder.reminder.ruleId }}</td>
                        <td><code>{{ reminder.reminder.ownerId }}</code></td>
                        <td>
                            {% if reminder.vehicle %}
                                <div>{{ reminder.vehicle.name() }}</div>
                                <div class="muted compact-note"><code>{{ reminder.reminder.vehicleId }}</code></div>
                            {% else %}
                                <code>{{ reminder.reminder.vehicleId }}</code>
                            {% endif %}
                        </td>
                        <td>{{ reminder.reminder.dueAtDate ? reminder.reminder.dueAtDate|date('Y-m-d') : 'n/a' }}</td>
                        <td>{{ reminder.reminder.dueAtOdometerKilometers ?? 'n/a' }}</td>
                        <td>
                            <span class="pill {{ reminder.triggerLabel == 'both' ? 'pill-soft-warning' : (reminder.triggerLabel == 'odometer' ? 'pill-soft-info' : 'pill-soft-warning') }}">{{ reminder.triggerLabel }}</span>
                        </td>
                        <td>
                            <div class="action-row" data-row-link-ignore>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_reminder_show', {id: reminder.reminder.id.toString, return_to: returnTo}) }}" data-turbo-frame="_top">Open</a>
                                {% if reminder.vehicle %}
                                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_show', {id: reminder.vehicle.id().toString(), return_to: returnTo}) }}" data-turbo-frame="_top">Vehicle</a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="muted">No reminders found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
