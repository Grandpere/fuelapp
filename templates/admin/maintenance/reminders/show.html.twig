{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.maintenance_reminders.detail.title'|trans }}{% endblock %}

{% set admin_section = 'maintenance_reminders' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-head">
            <div class="admin-page-header">
                <h2 class="page-title">{{ 'admin.maintenance_reminders.detail.title'|trans }}</h2>
                <p class="muted">{{ 'admin.maintenance_reminders.detail.lead'|trans }}</p>
            </div>
            <div class="admin-page-actions">
                <a class="btn btn-secondary" href="{{ backToListUrl }}">{{ 'action.back_to_list'|trans }}</a>
            </div>
        </div>

        <dl class="admin-dl admin-detail-stack">
            <dt class="admin-dt">ID</dt>
            <dd class="admin-dd">{{ reminder.id.toString }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.table.rule'|trans }}</dt>
            <dd class="admin-dd">{{ ruleName }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.detail.rule_id'|trans }}</dt>
            <dd class="admin-dd">{{ reminder.ruleId }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.detail.trigger_mode'|trans }}</dt>
            <dd class="admin-dd">{{ ruleSummary.triggerMode ?? ('common.na'|trans) }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.filters.event_type'|trans }}</dt>
            <dd class="admin-dd">{{ ruleSummary.eventType ?? ('common.na'|trans) }}</dd>
            <dt class="admin-dt">Cadence</dt>
            <dd class="admin-dd">{{ ruleSummary.cadence ?? ('common.na'|trans) }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.table.owner_id'|trans }}</dt>
            <dd class="admin-dd">{{ reminder.ownerId }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.detail.vehicle_id'|trans }}</dt>
            <dd class="admin-dd">
                {% if vehicle %}
                    <a href="{{ path('ui_admin_vehicle_show', {id: vehicle.id().toString(), return_to: backToListUrl}) }}">{{ vehicle.name() }}</a>
                    <span class="muted compact-note">({{ reminder.vehicleId }})</span>
                {% else %}
                    {{ reminder.vehicleId }}
                {% endif %}
            </dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.table.due_date'|trans }}</dt>
            <dd class="admin-dd">{{ reminder.dueAtDate ? reminder.dueAtDate|date('Y-m-d') : ('common.na'|trans) }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.table.due_odometer'|trans }}</dt>
            <dd class="admin-dd">{{ reminder.dueAtOdometerKilometers ?? ('common.na'|trans) }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.detail.due_by_date'|trans }}</dt>
            <dd class="admin-dd">{{ reminder.dueByDate ? ('admin.maintenance_reminders.boolean.yes'|trans) : ('admin.maintenance_reminders.boolean.no'|trans) }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.detail.due_by_odometer'|trans }}</dt>
            <dd class="admin-dd">{{ reminder.dueByOdometer ? ('admin.maintenance_reminders.boolean.yes'|trans) : ('admin.maintenance_reminders.boolean.no'|trans) }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.detail.dedup_key'|trans }}</dt>
            <dd class="admin-dd">{{ reminder.dedupKey }}</dd>
            <dt class="admin-dt">{{ 'admin.maintenance_reminders.table.created_at'|trans }}</dt>
            <dd class="admin-dd">{{ reminder.createdAt|date('Y-m-d H:i:s') }}</dd>
        </dl>

        <div class="card-subtle card-subtle-block admin-detail-stack">
            <div class="admin-page-header">
                <strong>{{ 'admin.maintenance_reminders.support_continuity_title'|trans }}</strong>
                <p class="muted compact-note">{{ 'admin.maintenance_reminders.support_continuity_lead'|trans }}</p>
            </div>
        </div>

        <div class="admin-page-actions admin-detail-stack">
            {% if vehicle %}
                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_show', {id: vehicle.id().toString(), return_to: backToListUrl}) }}">{{ 'admin.maintenance_reminders.shortcuts.open_vehicle'|trans }}</a>
                <a class="btn btn-secondary btn-compact" href="{{ matchingReceiptsUrl }}">{{ 'admin.maintenance_reminders.shortcuts.vehicle_receipts'|trans }}</a>
                <a class="btn btn-secondary btn-compact" href="{{ matchingRemindersUrl }}">{{ 'admin.maintenance_reminders.shortcuts.similar_reminders'|trans }}</a>
                <a class="btn btn-secondary btn-compact" href="{{ matchingEventsUrl }}">{{ 'admin.maintenance_reminders.shortcuts.matching_events'|trans }}</a>
            {% endif %}
            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_list', {vehicle_id: reminder.vehicleId}) }}">{{ 'admin.maintenance_reminders.shortcuts.vehicle_events'|trans }}</a>
            <a class="btn btn-secondary" href="/api/admin/maintenance/reminders/{{ reminder.id.toString }}">{{ 'admin.maintenance_reminders.shortcuts.open_api'|trans }}</a>
        </div>
    </section>
{% endblock %}
