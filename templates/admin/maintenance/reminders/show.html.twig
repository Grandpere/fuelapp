{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Maintenance Reminder Detail{% endblock %}

{% set admin_section = 'maintenance_reminders' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-head">
            <div class="admin-page-header">
                <h2 class="page-title">Maintenance Reminder Detail</h2>
                <p class="muted">Read-only reminder snapshot generated by scheduler evaluation.</p>
            </div>
            <div class="admin-page-actions">
                <a class="btn btn-secondary" href="{{ backToListUrl }}">Back to list</a>
            </div>
        </div>

        <dl class="admin-dl admin-detail-stack">
            <dt class="admin-dt">ID</dt>
            <dd class="admin-dd">{{ reminder.id.toString }}</dd>
            <dt class="admin-dt">Rule</dt>
            <dd class="admin-dd">{{ ruleName }}</dd>
            <dt class="admin-dt">Rule ID</dt>
            <dd class="admin-dd">{{ reminder.ruleId }}</dd>
            <dt class="admin-dt">Owner ID</dt>
            <dd class="admin-dd">{{ reminder.ownerId }}</dd>
            <dt class="admin-dt">Vehicle ID</dt>
            <dd class="admin-dd">
                {% if vehicle %}
                    <a href="{{ path('ui_admin_vehicle_show', {id: vehicle.id().toString(), return_to: backToListUrl}) }}">{{ vehicle.name() }}</a>
                    <span class="muted compact-note">({{ reminder.vehicleId }})</span>
                {% else %}
                    {{ reminder.vehicleId }}
                {% endif %}
            </dd>
            <dt class="admin-dt">Due date</dt>
            <dd class="admin-dd">{{ reminder.dueAtDate ? reminder.dueAtDate|date('Y-m-d') : 'n/a' }}</dd>
            <dt class="admin-dt">Due odometer</dt>
            <dd class="admin-dd">{{ reminder.dueAtOdometerKilometers ?? 'n/a' }}</dd>
            <dt class="admin-dt">Due by date</dt>
            <dd class="admin-dd">{{ reminder.dueByDate ? 'yes' : 'no' }}</dd>
            <dt class="admin-dt">Due by odometer</dt>
            <dd class="admin-dd">{{ reminder.dueByOdometer ? 'yes' : 'no' }}</dd>
            <dt class="admin-dt">Dedup key</dt>
            <dd class="admin-dd">{{ reminder.dedupKey }}</dd>
            <dt class="admin-dt">Created at</dt>
            <dd class="admin-dd">{{ reminder.createdAt|date('Y-m-d H:i:s') }}</dd>
        </dl>

        <div class="admin-page-actions admin-detail-stack">
            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_event_list', {vehicle_id: reminder.vehicleId}) }}">Open vehicle events</a>
            <a class="btn btn-secondary" href="/api/admin/maintenance/reminders/{{ reminder.id.toString }}">Open API resource</a>
        </div>
    </section>
{% endblock %}
