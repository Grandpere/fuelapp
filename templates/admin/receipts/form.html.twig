{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'receipt.form.title_edit_lines'|trans({'%id%': receipt.id.toString()}) }}{% endblock %}

{% set admin_section = 'receipts' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">{{ 'receipt.form.title_edit_lines'|trans({'%id%': receipt.id.toString()}) }}</h2>
            <p class="muted">{{ 'receipt.form.lead_edit_lines'|trans({'%id%': receipt.id.toString()}) }}</p>
        </div>

        <div class="card-subtle card-subtle-block admin-detail-stack">
            <div class="compact-note">
                {% if vehicle %}
                    {{ 'receipt.show.vehicle'|trans }}: {{ vehicle.name() }}
                {% else %}
                    {{ 'receipt.show.vehicle'|trans }}: {{ 'common.na'|trans }}
                {% endif %}
                ·
                {% if station %}
                    {{ 'receipt.show.station'|trans }}: {{ station.name() }}
                {% else %}
                    {{ 'receipt.show.station'|trans }}: {{ 'common.na'|trans }}
                {% endif %}
                ·
                {{ 'receipt.action.lines'|trans }}: {{ receipt.lines|length }}
            </div>
        </div>

        {% if errors is not empty %}
            <div class="flash flash-error admin-detail-stack">
                <ul class="flash-list">
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post" class="form-stack admin-detail-stack">
            <input type="hidden" name="_token" value="{{ csrfToken }}">
            <input type="hidden" name="_return_to" value="{{ backToReceiptUrl }}">
            <div class="table-wrap table-min-860">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>{{ 'receipt.form.fuel_type'|trans }}</th>
                            <th>{{ 'admin.receipts.form.quantity_ml'|trans }}</th>
                            <th>{{ 'admin.receipts.form.unit_price_deci_cents'|trans }}</th>
                            <th>{{ 'receipt.form.vat'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for line in formLines %}
                            <tr class="table-row">
                                <td>
                                    <select class="select" name="lines[{{ loop.index0 }}][fuelType]">
                                        {% for fuelType in fuelTypes %}
                                            <option value="{{ fuelType }}" {{ line.fuelType == fuelType ? 'selected' : '' }}>{{ fuelType|upper }}</option>
                                        {% endfor %}
                                    </select>
                                </td>
                                <td><input class="input" type="number" min="1" step="1" name="lines[{{ loop.index0 }}][quantityMilliLiters]" value="{{ line.quantityMilliLiters }}"></td>
                                <td><input class="input" type="number" min="0" step="1" name="lines[{{ loop.index0 }}][unitPriceDeciCentsPerLiter]" value="{{ line.unitPriceDeciCentsPerLiter }}"></td>
                                <td><input class="input" type="number" min="0" max="100" step="1" name="lines[{{ loop.index0 }}][vatRatePercent]" value="{{ line.vatRatePercent }}"></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="actions-wrap">
                <button class="btn btn-primary" type="submit">{{ 'receipt.form.save_lines'|trans }}</button>
                <a class="btn btn-secondary" href="{{ backToReceiptUrl }}">{{ 'action.cancel'|trans }}</a>
            </div>
        </form>
    </section>

    {% if supportShortcuts is not empty %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.receipts.support_continuity_title'|trans }}</h3>
            <div class="actions-wrap admin-table-top">
                {% for item in supportShortcuts %}
                    <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {% if relatedImports is not empty %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">{{ 'admin.receipts.related_imports_title'|trans }}</h3>
            <div class="actions-wrap admin-table-top">
                {% for item in relatedImports %}
                    <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.filename }} · {{ item.status }}</a>
                {% endfor %}
            </div>
        </section>
    {% endif %}
{% endblock %}
