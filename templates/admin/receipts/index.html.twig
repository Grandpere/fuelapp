{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Receipts{% endblock %}

{% set admin_section = 'receipts' %}

{% block admin_content %}
    {% set returnTo = app.request.requestUri %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">Receipts</h2>
            <p class="muted">System-wide receipt ledger with full back-office controls.</p>
        </div>

        <div class="admin-metric-grid admin-table-top">
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">Total receipts</p>
                <p class="admin-metric-value">{{ metrics.total }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">Vehicle linked</p>
                <p class="admin-metric-value">{{ metrics.withVehicle }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">Station linked</p>
                <p class="admin-metric-value">{{ metrics.withStation }}</p>
            </article>
        </div>

        {% if supportShortcuts is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>Support shortcuts</strong>
                        <p class="muted compact-note">Jump to the freshest receipt dossier instead of scanning the whole ledger first.</p>
                    </div>
                    <div class="actions-wrap">
                        {% for shortcut in supportShortcuts %}
                            <a class="btn btn-secondary btn-compact" href="{{ shortcut.url }}">{{ shortcut.label }}</a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}

        <form method="get" action="{{ path('ui_admin_receipt_list') }}" class="admin-filters-form admin-table-top">
            <div class="form-grid-2">
                <label class="label">
                    Search
                    <input class="input" type="text" name="q" value="{{ filters.q ?? '' }}" placeholder="receipt id, vehicle, station">
                </label>
                <label class="label">
                    Vehicle
                    <select class="select" name="vehicle_id">
                        <option value="">All vehicles</option>
                        {% for vehicle in vehicleOptions %}
                            <option value="{{ vehicle.id }}" {{ filters.vehicleId == vehicle.id ? 'selected' : '' }}>{{ vehicle.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    Station
                    <select class="select" name="station_id">
                        <option value="">All stations</option>
                        {% for station in stationOptions %}
                            <option value="{{ station.id }}" {{ filters.stationId == station.id ? 'selected' : '' }}>{{ station.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    Issued from
                    <input class="input" type="text" name="issued_from" value="{{ filters.issuedFrom ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
                <label class="label">
                    Issued to
                    <input class="input" type="text" name="issued_to" value="{{ filters.issuedTo ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
            </div>
            <div class="actions-wrap">
                <button class="btn btn-primary" type="submit">Apply filters</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_receipt_list') }}">Reset</a>
            </div>
        </form>

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>Context filter active</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_list') }}">Reset</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="table-wrap admin-table-top table-min-920">
            <table class="app-table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Issued At</th>
                    <th>Context</th>
                    <th class="text-right">Lines</th>
                    <th class="text-right">Total</th>
                    <th class="text-right">VAT</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for receipt in receipts %}
                    <tr
                        class="table-row row-link"
                        data-controller="row-link"
                        data-action="click->row-link#navigate"
                        data-row-link-url-value="{{ receipt.showUrl }}"
                        onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                    >
                        <td>{{ receipt.receipt.id.toString() }}</td>
                        <td>{{ receipt.receipt.issuedAt|date('Y-m-d H:i') }}</td>
                        <td>
                            {% if receipt.vehicle or receipt.station %}
                                {% if receipt.vehicle %}
                                    <div>{{ receipt.vehicle.name() }}</div>
                                {% endif %}
                                {% if receipt.station %}
                                    <div class="muted compact-note">{{ receipt.station.name() }}</div>
                                {% endif %}
                            {% else %}
                                <span class="muted">No vehicle or station linked.</span>
                            {% endif %}
                        </td>
                        <td class="text-right">{{ receipt.receipt.lines|length }}</td>
                        <td class="text-right">{{ (receipt.receipt.totalCents / 100)|number_format(2, ',', ' ') }} EUR</td>
                        <td class="text-right">{{ (receipt.receipt.vatAmountCents / 100)|number_format(2, ',', ' ') }} EUR</td>
                        <td>
                            <div class="action-cell-flex" data-row-link-ignore>
                                <a class="btn btn-secondary btn-compact" href="{{ receipt.showUrl }}">Open</a>
                                <a class="btn btn-secondary btn-compact" href="{{ receipt.editUrl }}">Edit</a>
                                {% if receipt.vehicle %}
                                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_show', {id: receipt.vehicle.id().toString(), return_to: returnTo}) }}">Vehicle</a>
                                {% endif %}
                                {% if receipt.station %}
                                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_station_show', {id: receipt.station.id().toString(), return_to: returnTo}) }}">Station</a>
                                {% endif %}
                                <form method="post" action="{{ path('ui_admin_receipt_delete', {id: receipt.receipt.id.toString()}) }}" onsubmit="return confirm('Delete this receipt?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_receipt_delete_' ~ receipt.receipt.id.toString()) }}">
                                    <input type="hidden" name="_redirect" value="{{ returnTo }}">
                                    <button class="btn btn-danger btn-compact" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="muted">No receipts found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
