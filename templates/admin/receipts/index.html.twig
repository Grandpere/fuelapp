{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Receipts{% endblock %}

{% set admin_section = 'receipts' %}

{% block admin_content %}
    <section class="card admin-panel">
        <h2 class="page-title">Receipts</h2>
        <p class="muted">System-wide receipt ledger with full back-office controls.</p>

        <div class="table-wrap" style="margin-top: 1rem;">
            <table class="app-table" style="min-width: 920px;">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Issued At</th>
                    <th style="text-align:right;">Lines</th>
                    <th style="text-align:right;">Total</th>
                    <th style="text-align:right;">VAT</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for receipt in receipts %}
                    <tr
                        class="table-row"
                        style="cursor:pointer;"
                        data-controller="row-link"
                        data-action="click->row-link#navigate"
                        data-row-link-url-value="{{ path('ui_admin_receipt_show', {id: receipt.id.toString()}) }}"
                    >
                        <td>{{ receipt.id.toString() }}</td>
                        <td>{{ receipt.issuedAt|date('Y-m-d H:i') }}</td>
                        <td style="text-align:right;">{{ receipt.lines|length }}</td>
                        <td style="text-align:right;">{{ (receipt.totalCents / 100)|number_format(2, ',', ' ') }} EUR</td>
                        <td style="text-align:right;">{{ (receipt.vatAmountCents / 100)|number_format(2, ',', ' ') }} EUR</td>
                        <td>
                            <div class="action-row">
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_show', {id: receipt.id.toString()}) }}">Detail</a>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_edit', {id: receipt.id.toString()}) }}">Edit</a>
                                <form method="post" action="{{ path('ui_admin_receipt_delete', {id: receipt.id.toString()}) }}" onsubmit="return confirm('Delete this receipt?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_receipt_delete_' ~ receipt.id.toString()) }}">
                                    <button class="btn btn-danger btn-compact" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="muted">No receipts found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
