{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Receipt Detail{% endblock %}

{% set admin_section = 'receipts' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-head">
            <div class="admin-page-header">
                <h2 class="page-title">Receipt Detail</h2>
                <p class="muted">Inspect and control this receipt from back-office.</p>
            </div>
            <div class="admin-page-actions">
                <a class="btn btn-secondary" href="{{ path('ui_admin_receipt_edit', {id: receipt.id.toString(), return_to: app.request.requestUri}) }}">Edit</a>
                <form method="post" action="{{ path('ui_admin_receipt_delete', {id: receipt.id.toString()}) }}" onsubmit="return confirm('Delete this receipt?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_receipt_delete_' ~ receipt.id.toString()) }}">
                    <input type="hidden" name="_redirect" value="{{ backToListUrl }}">
                    <button class="btn btn-danger" type="submit">Delete</button>
                </form>
                <a class="btn btn-secondary" href="{{ backToListUrl }}">Back</a>
            </div>
        </div>

        <dl class="admin-dl admin-detail-stack">
            <dt class="admin-dt">Receipt ID</dt>
            <dd class="admin-dd">{{ receipt.id.toString() }}</dd>
            <dt class="admin-dt">Issued At</dt>
            <dd class="admin-dd">{{ receipt.issuedAt|date('Y-m-d H:i:s') }}</dd>
            <dt class="admin-dt">Total</dt>
            <dd class="admin-dd">{{ (receipt.totalCents / 100)|number_format(2, ',', ' ') }} EUR</dd>
            <dt class="admin-dt">VAT</dt>
            <dd class="admin-dd">{{ (receipt.vatAmountCents / 100)|number_format(2, ',', ' ') }} EUR</dd>
            <dt class="admin-dt">Station</dt>
            <dd class="admin-dd">
                {% if station %}
                    <a href="{{ path('ui_admin_station_show', {id: station.id().toString(), return_to: backToListUrl}) }}">{{ station.name }}</a> - {{ station.streetName }}, {{ station.postalCode }} {{ station.city }}
                {% else %}
                    n/a
                {% endif %}
            </dd>
            <dt class="admin-dt">Vehicle</dt>
            <dd class="admin-dd">
                {% if vehicle %}
                    <a href="{{ path('ui_admin_vehicle_show', {id: vehicle.id().toString(), return_to: backToListUrl}) }}">{{ vehicle.name() }}</a>
                {% else %}
                    n/a
                {% endif %}
            </dd>
        </dl>
    </section>

    {% if supportShortcuts is not empty %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">Support continuity</h3>
            <div class="actions-wrap admin-table-top">
                {% for item in supportShortcuts %}
                    <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {% if relatedImports is not empty %}
        <section class="card admin-panel admin-section-spaced">
            <h3 class="section-title">Related imports</h3>
            <p class="muted">These imports already point to this receipt, so support can jump back into the originating import flow when needed.</p>
            <div class="actions-wrap admin-table-top">
                {% for item in relatedImports %}
                    <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.filename }} · {{ item.status }}</a>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    <section class="card admin-panel admin-section-spaced">
        <h3 class="section-title">Lines</h3>
        <div class="table-wrap admin-table-top table-min-860">
            <table class="app-table">
                <thead>
                <tr>
                    <th>Fuel Type</th>
                    <th class="text-right">Quantity (L)</th>
                    <th class="text-right">Unit Price (EUR/L)</th>
                    <th class="text-right">VAT %</th>
                    <th class="text-right">VAT</th>
                    <th class="text-right">Line Total</th>
                </tr>
                </thead>
                <tbody>
                {% for line in receipt.lines %}
                    <tr class="table-row">
                        <td>{{ line.fuelType.value }}</td>
                        <td class="text-right">{{ (line.quantityMilliLiters / 1000)|number_format(3, ',', ' ') }}</td>
                        <td class="text-right">{{ (line.unitPriceDeciCentsPerLiter / 1000)|number_format(3, ',', ' ') }}</td>
                        <td class="text-right">{{ line.vatRatePercent }}</td>
                        <td class="text-right">{{ (line.vatAmountCents / 100)|number_format(2, ',', ' ') }} EUR</td>
                        <td class="text-right">{{ (line.lineTotalCents / 100)|number_format(2, ',', ' ') }} EUR</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
