{% extends 'admin/layout.html.twig' %}

{% block title %}Security Activities{% endblock %}

{% set admin_section = 'security_activities' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">Security Activities</h2>
            <p class="muted">Track login attempts and security-sensitive account changes.</p>
        </div>

        {% if supportShortcuts is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>Investigation continuity</strong>
                        <p class="muted compact-note">Stay anchored to the same actor while moving across user, identity, and audit views.</p>
                    </div>
                    <div class="actions-wrap">
                        {% for item in supportShortcuts %}
                            <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>Active filters</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_security_activity_list') }}">Reset</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <form method="get" action="{{ path('ui_admin_security_activity_list') }}" class="admin-filter-grid-5 admin-table-top">
            <label class="label">
                Action
                <input class="input" type="text" name="action" value="{{ filters.action }}" placeholder="security.login.failure">
            </label>
            <label class="label">
                Actor id
                <input class="input" type="text" name="actorId" value="{{ filters.actorId }}" placeholder="UUID">
            </label>
            <label class="label">
                From
                <input class="input" type="text" name="from" value="{{ filters.from }}" data-datepicker="date" autocomplete="off">
            </label>
            <label class="label">
                To
                <input class="input" type="text" name="to" value="{{ filters.to }}" data-datepicker="date" autocomplete="off">
            </label>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">Apply</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_security_activity_list') }}">Reset</a>
            </div>
        </form>

        <div class="table-wrap admin-table-top table-min-1080">
            <table class="app-table">
                <thead>
                <tr>
                    <th>When</th>
                    <th>Action</th>
                    <th>Actor</th>
                    <th>Target</th>
                    <th>Correlation</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for entry in entries %}
                    <tr>
                        <td>{{ entry.entry.createdAt|date('Y-m-d H:i:s') }}</td>
                        <td><code>{{ entry.entry.action }}</code></td>
                        <td>
                            {% if entry.entry.actorEmail %}
                                {{ entry.entry.actorEmail }}
                            {% else %}
                                <span class="muted">anonymous</span>
                            {% endif %}
                            {% if entry.entry.actorId %}
                                <div><small class="muted">{{ entry.entry.actorId }}</small></div>
                            {% endif %}
                        </td>
                        <td>
                            <div>{{ entry.entry.targetType }}</div>
                            <small class="muted">{{ entry.entry.targetId }}</small>
                        </td>
                        <td><small>{{ entry.entry.correlationId }}</small></td>
                        <td class="action-cell-flex">
                            {% if entry.userUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.userUrl }}">User</a>
                            {% endif %}
                            <a class="btn btn-secondary btn-compact" href="{{ entry.auditUrl }}">Audit</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="muted">No security activity found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
