{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.security.title'|trans }}{% endblock %}

{% set admin_section = 'security_activities' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">{{ 'admin.security.title'|trans }}</h2>
            <p class="muted">{{ 'admin.security.lead'|trans }}</p>
        </div>

        {% if supportShortcuts is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.security.continuity_title'|trans }}</strong>
                        <p class="muted compact-note">{{ 'admin.security.continuity_lead'|trans }}</p>
                    </div>
                    <div class="actions-wrap">
                        {% for item in supportShortcuts %}
                            <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.common.active_filters'|trans }}</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_security_activity_list') }}">{{ 'action.reset'|trans }}</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <form method="get" action="{{ path('ui_admin_security_activity_list') }}" class="admin-filter-grid-5 admin-table-top">
            <label class="label">
                {{ 'admin.security.filters.action'|trans }}
                <input class="input" type="text" name="action" value="{{ filters.action }}" placeholder="{{ 'admin.security.filters.action_placeholder'|trans }}">
            </label>
            <label class="label">
                {{ 'admin.security.filters.actor'|trans }}
                <select class="select" name="actorId">
                    <option value="">{{ 'admin.security.filters.all_actors'|trans }}</option>
                    {% for actor in actorOptions %}
                        <option value="{{ actor.id }}" {% if filters.actorId == actor.id %}selected{% endif %}>{{ actor.label }}</option>
                    {% endfor %}
                </select>
            </label>
            <label class="label">
                {{ 'admin.security.filters.from'|trans }}
                <input class="input" type="text" name="from" value="{{ filters.from }}" data-datepicker="date" autocomplete="off">
            </label>
            <label class="label">
                {{ 'admin.security.filters.to'|trans }}
                <input class="input" type="text" name="to" value="{{ filters.to }}" data-datepicker="date" autocomplete="off">
            </label>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">{{ 'action.apply'|trans }}</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_security_activity_list') }}">{{ 'action.reset'|trans }}</a>
            </div>
        </form>

        <div class="table-wrap admin-table-top table-min-1080">
            <table class="app-table">
                <thead>
                <tr>
                    <th>{{ 'admin.security.table.when'|trans }}</th>
                    <th>{{ 'admin.security.table.action'|trans }}</th>
                    <th>{{ 'admin.security.table.actor'|trans }}</th>
                    <th>{{ 'admin.security.table.target'|trans }}</th>
                    <th>{{ 'admin.security.table.correlation'|trans }}</th>
                    <th>{{ 'common.actions'|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for entry in entries %}
                    <tr>
                        <td>{{ entry.entry.createdAt|date('Y-m-d H:i:s') }}</td>
                        <td><code>{{ entry.entry.action }}</code></td>
                        <td>
                            {% if entry.entry.actorEmail %}
                                {{ entry.entry.actorEmail }}
                            {% else %}
                                <span class="muted">{{ 'admin.security.anonymous'|trans }}</span>
                            {% endif %}
                            {% if entry.entry.actorId %}
                                <div><small class="muted">{{ entry.entry.actorId }}</small></div>
                            {% endif %}
                        </td>
                        <td>
                            <div>{{ entry.entry.targetType }}</div>
                            <small class="muted">{{ entry.entry.targetId }}</small>
                        </td>
                        <td><small>{{ entry.entry.correlationId }}</small></td>
                        <td class="action-cell-flex">
                            {% if entry.userUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.userUrl }}">{{ 'admin.security.actions.user'|trans }}</a>
                            {% endif %}
                            {% if entry.identitiesUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.identitiesUrl }}">{{ 'admin.security.actions.identities'|trans }}</a>
                            {% endif %}
                            <a class="btn btn-secondary btn-compact" href="{{ entry.auditUrl }}">{{ 'admin.security.actions.audit'|trans }}</a>
                            {% if entry.correlationUrl %}
                                <a class="btn btn-secondary btn-compact" href="{{ entry.correlationUrl }}">{{ 'admin.security.actions.correlation'|trans }}</a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="muted">{{ 'admin.security.empty'|trans }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
