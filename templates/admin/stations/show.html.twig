{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Station Detail{% endblock %}

{% set admin_section = 'stations' %}

{% block admin_content %}
    {% set requestedReturnTo = app.request.query.get('return_to') %}
    {% set backToListUrl = requestedReturnTo is not empty and requestedReturnTo starts with('/') and not (requestedReturnTo starts with('//')) ? requestedReturnTo : path('ui_admin_station_list') %}
    <section class="card admin-panel">
        <div class="admin-page-head">
            <div class="admin-page-header">
                <h2 class="page-title">Station Detail</h2>
                <p class="muted">Back-office detail view with direct mutation actions.</p>
            </div>
            <div class="admin-page-actions">
                <a class="btn btn-secondary" href="{{ path('ui_admin_station_edit', {id: station.id.toString}) }}">Edit station</a>
                <form method="post" action="{{ path('ui_admin_station_delete', {id: station.id.toString}) }}" onsubmit="return confirm('Delete this station?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_station_delete_' ~ station.id.toString) }}">
                    <input type="hidden" name="_redirect" value="{{ backToListUrl }}">
                    <button class="btn btn-danger" type="submit">Delete</button>
                </form>
                <a class="btn btn-secondary" href="{{ backToListUrl }}">Back to list</a>
            </div>
        </div>

        <dl class="admin-dl admin-detail-stack">
            <dt class="admin-dt">ID</dt>
            <dd class="admin-dd">{{ station.id.toString }}</dd>
            <dt class="admin-dt">Name</dt>
            <dd class="admin-dd">{{ station.name }}</dd>
            <dt class="admin-dt">Street</dt>
            <dd class="admin-dd">{{ station.streetName }}</dd>
            <dt class="admin-dt">Postal code</dt>
            <dd class="admin-dd">{{ station.postalCode }}</dd>
            <dt class="admin-dt">City</dt>
            <dd class="admin-dd">{{ station.city }}</dd>
            <dt class="admin-dt">Geocoding status</dt>
            <dd class="admin-dd">{{ station.geocodingStatus.value }}</dd>
            <dt class="admin-dt">Coordinates</dt>
            <dd class="admin-dd">
                {% if station.latitudeMicroDegrees is not null and station.longitudeMicroDegrees is not null %}
                    {{ station.latitudeMicroDegrees }} / {{ station.longitudeMicroDegrees }}
                {% else %}
                    n/a
                {% endif %}
            </dd>
            <dt class="admin-dt">Last geocoding error</dt>
            <dd class="admin-dd">{{ station.geocodingLastError ?? 'n/a' }}</dd>
        </dl>

        <div class="admin-page-actions admin-detail-stack">
            <a class="btn btn-secondary" href="/api/admin/stations/{{ station.id.toString }}">Open API resource</a>
        </div>
    </section>
{% endblock %}
