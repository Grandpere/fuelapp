{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin.users.title'|trans }}{% endblock %}

{% set admin_section = 'users' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">{{ 'admin.users.title'|trans }}</h2>
            <p class="muted">{{ 'admin.users.lead'|trans }}</p>
        </div>

        <div class="admin-metric-grid metric-grid-spaced admin-table-top">
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.users.metrics.inactive_accounts'|trans }}</p>
                <p class="admin-metric-value">{{ metrics.inactive }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.users.metrics.unverified_emails'|trans }}</p>
                <p class="admin-metric-value">{{ metrics.unverified }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.users.metrics.missing_identities'|trans }}</p>
                <p class="admin-metric-value">{{ metrics.withoutIdentity }}</p>
            </article>
            <article class="card-subtle admin-metric-card">
                <p class="admin-metric-label">{{ 'admin.users.metrics.admins'|trans }}</p>
                <p class="admin-metric-value">{{ metrics.admins }}</p>
            </article>
        </div>

        <div class="card-subtle card-subtle-block admin-table-top">
            <div class="admin-page-head">
                <div class="admin-page-header">
                    <strong>{{ 'admin.users.attention_title'|trans }}</strong>
                    <p class="muted compact-note">{{ 'admin.users.attention_lead'|trans }}</p>
                </div>
                <div class="actions-wrap">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_user_list', {verification: 'unverified'}) }}">{{ 'admin.users.verification.unverified'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_user_list', {is_active: '0'}) }}">{{ 'admin.users.status.inactive'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_user_list', {has_identity: '0'}) }}">{{ 'admin.users.identities.missing'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_user_list', {role: 'admin'}) }}">{{ 'admin.users.roles.admin_plural'|trans }}</a>
                </div>
            </div>
        </div>

        {% if supportShortcuts is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.users.triage_speed_title'|trans }}</strong>
                        <p class="muted compact-note">{{ 'admin.users.triage_speed_lead'|trans }}</p>
                    </div>
                    <div class="actions-wrap">
                        {% for item in supportShortcuts %}
                            <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>{{ 'admin.common.active_filters'|trans }}</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_user_list') }}">{{ 'action.reset'|trans }}</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <form method="get" action="{{ path('ui_admin_user_list') }}" class="admin-filter-grid-4 admin-table-top">
            <label class="label">
                {{ 'admin.users.filters.search'|trans }}
                <input class="input" type="text" name="q" value="{{ filters.q }}" placeholder="{{ 'admin.users.filters.search_placeholder'|trans }}">
            </label>
            <label class="label">
                {{ 'admin.users.filters.role'|trans }}
                <select class="select" name="role">
                    <option value="" {% if filters.role == '' %}selected{% endif %}>{{ 'admin.users.filters.all_roles'|trans }}</option>
                    <option value="admin" {% if filters.role == 'admin' %}selected{% endif %}>{{ 'admin.users.filters.role_option_admin'|trans }}</option>
                    <option value="user" {% if filters.role == 'user' %}selected{% endif %}>{{ 'admin.users.filters.role_option_user'|trans }}</option>
                </select>
            </label>
            <label class="label">
                {{ 'admin.users.filters.status'|trans }}
                <select class="select" name="is_active">
                    <option value="" {% if filters.is_active == '' %}selected{% endif %}>{{ 'admin.common.all'|trans }}</option>
                    <option value="1" {% if filters.is_active == '1' %}selected{% endif %}>{{ 'admin.users.status.active'|trans }}</option>
                    <option value="0" {% if filters.is_active == '0' %}selected{% endif %}>{{ 'admin.users.status.inactive'|trans }}</option>
                </select>
            </label>
            <label class="label">
                {{ 'admin.users.filters.verification'|trans }}
                <select class="select" name="verification">
                    <option value="" {% if filters.verification == '' %}selected{% endif %}>{{ 'admin.common.all'|trans }}</option>
                    <option value="verified" {% if filters.verification == 'verified' %}selected{% endif %}>{{ 'admin.users.verification.verified'|trans }}</option>
                    <option value="unverified" {% if filters.verification == 'unverified' %}selected{% endif %}>{{ 'admin.users.verification.unverified'|trans }}</option>
                </select>
            </label>
            <label class="label">
                {{ 'admin.users.filters.identities'|trans }}
                <select class="select" name="has_identity">
                    <option value="" {% if filters.has_identity == '' %}selected{% endif %}>{{ 'admin.common.all'|trans }}</option>
                    <option value="1" {% if filters.has_identity == '1' %}selected{% endif %}>{{ 'admin.users.identities.linked'|trans }}</option>
                    <option value="0" {% if filters.has_identity == '0' %}selected{% endif %}>{{ 'admin.users.identities.missing'|trans }}</option>
                </select>
            </label>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">{{ 'action.apply'|trans }}</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_user_list') }}">{{ 'action.reset'|trans }}</a>
            </div>
        </form>

        <div class="table-wrap admin-table-top table-min-1120">
            <table class="app-table">
                <thead>
                <tr>
                    <th>{{ 'admin.users.table.email'|trans }}</th>
                    <th>{{ 'admin.users.table.signal'|trans }}</th>
                    <th>{{ 'admin.users.table.status'|trans }}</th>
                    <th>{{ 'admin.users.table.email_verification'|trans }}</th>
                    <th>{{ 'admin.users.table.roles'|trans }}</th>
                    <th>{{ 'admin.users.table.identities'|trans }}</th>
                    <th>{{ 'common.actions'|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.email }}</td>
                        <td>
                            <strong>{{ user.signal.headline }}</strong>
                            <div class="muted compact-note">{{ user.signal.detail }}</div>
                        </td>
                        <td>
                            <span class="pill {{ user.isActive ? 'pill-soft-success' : 'pill-soft-danger' }}">
                                {{ user.isActive ? 'admin.users.status.active'|trans : 'admin.users.status.inactive'|trans }}
                            </span>
                        </td>
                        <td>
                            <span class="pill {{ user.isEmailVerified ? 'pill-soft-success' : 'pill-soft-warning' }}">
                                {{ user.isEmailVerified ? 'admin.users.verification.verified'|trans : 'admin.users.verification.unverified'|trans }}
                            </span>
                        </td>
                        <td>{{ user.roles|join(', ') }}</td>
                        <td>{{ user.identityCount }}</td>
                        <td class="action-cell-flex">
                            <form method="post" action="{{ path('ui_admin_user_toggle_active', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_toggle_active_' ~ user.id) }}">
                                <button class="btn {{ user.isActive ? 'btn-danger' : 'btn-secondary' }} btn-compact" type="submit">
                                    {{ user.isActive ? 'admin.users.actions.deactivate'|trans : 'admin.users.actions.activate'|trans }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_user_toggle_admin', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_toggle_admin_' ~ user.id) }}">
                                <button class="btn btn-secondary btn-compact" type="submit">
                                    {{ user.isAdmin ? 'admin.users.actions.remove_admin'|trans : 'admin.users.actions.make_admin'|trans }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_user_toggle_verification', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_toggle_verification_' ~ user.id) }}">
                                <button class="btn btn-secondary btn-compact" type="submit">
                                    {{ user.isEmailVerified ? 'admin.users.actions.mark_unverified'|trans : 'admin.users.actions.mark_verified'|trans }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_user_resend_verification', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_resend_verification_' ~ user.id) }}">
                                <button class="btn btn-secondary btn-compact" type="submit">{{ 'admin.users.actions.resend_verification'|trans }}</button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_user_reset_password', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_reset_password_' ~ user.id) }}">
                                <button class="btn btn-danger btn-compact" type="submit">{{ 'admin.users.actions.reset_password'|trans }}</button>
                            </form>
                            <a class="btn btn-secondary btn-compact" href="{{ user.identitiesUrl }}">{{ 'admin.users.actions.identities'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ user.securityUrl }}">{{ 'admin.users.actions.security'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ user.auditUrl }}">{{ 'admin.users.actions.audit'|trans }}</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="muted">{{ 'admin.users.empty'|trans }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
