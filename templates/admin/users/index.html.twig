{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Users{% endblock %}

{% set admin_section = 'users' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">Users</h2>
            <p class="muted">Filter users, activate/deactivate accounts, and manage admin access.</p>
        </div>

        <form method="get" action="{{ path('ui_admin_user_list') }}" class="admin-filter-grid-4 admin-table-top">
            <label class="label">
                Search
                <input class="input" type="text" name="q" value="{{ filters.q }}" placeholder="email">
            </label>
            <label class="label">
                Role
                <select class="select" name="role">
                    <option value="" {% if filters.role == '' %}selected{% endif %}>All roles</option>
                    <option value="admin" {% if filters.role == 'admin' %}selected{% endif %}>Admin</option>
                    <option value="user" {% if filters.role == 'user' %}selected{% endif %}>User</option>
                </select>
            </label>
            <label class="label">
                Status
                <select class="select" name="is_active">
                    <option value="" {% if filters.is_active == '' %}selected{% endif %}>All</option>
                    <option value="1" {% if filters.is_active == '1' %}selected{% endif %}>Active</option>
                    <option value="0" {% if filters.is_active == '0' %}selected{% endif %}>Inactive</option>
                </select>
            </label>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">Apply</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_user_list') }}">Reset</a>
            </div>
        </form>

        <div class="table-wrap admin-table-top table-min-1120">
            <table class="app-table">
                <thead>
                <tr>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Email Verification</th>
                    <th>Roles</th>
                    <th>Identities</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.email }}</td>
                        <td>
                            <span class="pill {{ user.isActive ? 'pill-soft-success' : 'pill-soft-danger' }}">
                                {{ user.isActive ? 'active' : 'inactive' }}
                            </span>
                        </td>
                        <td>
                            <span class="pill {{ user.isEmailVerified ? 'pill-soft-success' : 'pill-soft-warning' }}">
                                {{ user.isEmailVerified ? 'verified' : 'unverified' }}
                            </span>
                        </td>
                        <td>{{ user.roles|join(', ') }}</td>
                        <td>{{ user.identityCount }}</td>
                        <td class="action-cell-flex">
                            <form method="post" action="{{ path('ui_admin_user_toggle_active', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_toggle_active_' ~ user.id) }}">
                                <button class="btn {{ user.isActive ? 'btn-danger' : 'btn-secondary' }}" type="submit">
                                    {{ user.isActive ? 'Deactivate' : 'Activate' }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_user_toggle_admin', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_toggle_admin_' ~ user.id) }}">
                                <button class="btn btn-secondary" type="submit">
                                    {{ user.isAdmin ? 'Remove admin' : 'Make admin' }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_user_toggle_verification', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_toggle_verification_' ~ user.id) }}">
                                <button class="btn btn-secondary" type="submit">
                                    {{ user.isEmailVerified ? 'Mark unverified' : 'Mark verified' }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_user_resend_verification', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_resend_verification_' ~ user.id) }}">
                                <button class="btn btn-secondary" type="submit">Resend verification</button>
                            </form>
                            <form method="post" action="{{ path('ui_admin_user_reset_password', {id: user.id}) }}" data-turbo-frame="_top">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_reset_password_' ~ user.id) }}">
                                <button class="btn btn-danger" type="submit">Reset password</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="muted">No users found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
