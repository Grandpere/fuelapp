{% extends 'admin/layout.html.twig' %}

{% block title %}Edit Admin Vehicle{% endblock %}

{% set admin_section = 'vehicles' %}

{% block admin_content %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">Edit vehicle</h2>
            <p class="muted">Admin mutation flow for owner vehicle management.</p>
        </div>

        {% if errors is not empty %}
            <div class="flash flash-error admin-detail-stack">
                <ul class="flash-list">
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post" action="" data-turbo-frame="_top" class="form-stack content-narrow admin-detail-stack">
            <input type="hidden" name="_token" value="{{ csrfToken }}">
            <input type="hidden" name="_return_to" value="{{ returnTo }}">
            <label class="label">
                Owner ID
                <input class="input" type="text" name="ownerId" value="{{ formData.ownerId }}" required>
            </label>
            <label class="label">
                Vehicle name
                <input class="input" type="text" name="name" value="{{ formData.name }}" required>
            </label>
            <label class="label">
                Plate number
                <input class="input" type="text" name="plateNumber" value="{{ formData.plateNumber }}" required>
            </label>

            <div class="actions-wrap">
                <button class="btn btn-primary" type="submit">Save changes</button>
                <a class="btn btn-secondary" href="{{ returnTo }}" data-turbo-frame="_top">Back</a>
            </div>
        </form>
    </section>
{% endblock %}
