{% extends 'admin/layout.html.twig' %}

{% block title %}Admin Vehicles{% endblock %}

{% set admin_section = 'vehicles' %}

{% block admin_content %}
    {% set returnTo = app.request.requestUri %}
    <section class="card admin-panel">
        <div class="admin-page-header">
            <h2 class="page-title">Vehicles</h2>
            <p class="muted">System-wide fleet view with direct follow-up into receipts and maintenance.</p>
        </div>

        {% if supportShortcuts is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>Queue shortcuts</strong>
                        <p class="muted compact-note">Jump straight into the next vehicle queue that likely needs support attention.</p>
                    </div>
                    <div class="actions-wrap">
                        {% for item in supportShortcuts %}
                            <a class="btn btn-secondary btn-compact" href="{{ item.url }}">{{ item.label }}</a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}

        {% if activeFilterSummary is not empty %}
            <div class="card-subtle card-subtle-block admin-table-top">
                <div class="admin-page-head">
                    <div class="admin-page-header">
                        <strong>Active filters</strong>
                        <p class="muted compact-note">
                            {% for item in activeFilterSummary %}
                                {{ item.label }}: {{ item.value }}{% if not loop.last %} · {% endif %}
                            {% endfor %}
                        </p>
                    </div>
                    <div class="admin-page-actions">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_list') }}">Reset</a>
                    </div>
                </div>
            </div>
        {% endif %}

        <form method="get" action="{{ path('ui_admin_vehicle_list') }}" class="admin-filter-grid-3 admin-table-top">
            <label class="label">
                Search
                <input class="input" type="text" name="q" value="{{ filters.q }}" placeholder="Name, plate, owner email">
            </label>
            <label class="label">
                Owner
                <select class="select" name="ownerId">
                    <option value="">All owners</option>
                    {% for owner in ownerOptions %}
                        <option value="{{ owner.id }}" {% if filters.ownerId == owner.id %}selected{% endif %}>{{ owner.label }}</option>
                    {% endfor %}
                </select>
            </label>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">Apply</button>
                <a class="btn btn-secondary" href="{{ path('ui_admin_vehicle_list') }}">Reset</a>
            </div>
        </form>

        <div class="table-wrap admin-table-top table-min-980">
            <table class="app-table table-min-980">
                <thead>
                <tr>
                    <th>Name</th>
                    <th>Plate</th>
                    <th>Owner</th>
                    <th>Signal</th>
                    <th>Receipts</th>
                    <th>Maintenance</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for row in vehicleRows %}
                    {% set vehicle = row.vehicle %}
                    <tr
                        class="table-row row-link"
                        data-controller="row-link"
                        data-action="click->row-link#navigate"
                        data-row-link-url-value="{{ path('ui_admin_vehicle_show', {id: vehicle.id.toString, return_to: returnTo}) }}"
                        onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                    >
                        <td>{{ vehicle.name }}</td>
                        <td>{{ vehicle.plateNumber }}</td>
                        <td>
                            {% if row.ownerEmail %}
                                <div>{{ row.ownerEmail }}</div>
                            {% endif %}
                            <div class="muted compact-note">{{ vehicle.ownerId }}</div>
                        </td>
                        <td>
                            <div>{{ row.signal.headline }}</div>
                            <div class="muted compact-note">{{ row.signal.detail }}</div>
                        </td>
                        <td>
                            <div>{{ row.receiptCount }} receipt{{ row.receiptCount == 1 ? '' : 's' }}</div>
                            <div class="muted compact-note">
                                {% if row.lastReceiptAt %}
                                    Last: {{ row.lastReceiptAt|date('Y-m-d H:i') }}
                                {% else %}
                                    No receipt yet
                                {% endif %}
                            </div>
                        </td>
                        <td>
                            <div>{{ row.eventCount }} event{{ row.eventCount == 1 ? '' : 's' }}</div>
                            <div class="muted compact-note">{{ row.dueReminderCount }} due reminder{{ row.dueReminderCount == 1 ? '' : 's' }}</div>
                        </td>
                        <td>{{ vehicle.updatedAt|date('Y-m-d H:i') }}</td>
                        <td class="action-cell-flex" data-row-link-ignore>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_show', {id: vehicle.id.toString, return_to: returnTo}) }}" data-turbo-frame="_top">Open</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_receipt_list', {vehicle_id: vehicle.id.toString}) }}" data-turbo-frame="_top">Receipts</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_maintenance_reminder_list', {vehicle_id: vehicle.id.toString}) }}" data-turbo-frame="_top">Maintenance</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_admin_vehicle_edit', {id: vehicle.id.toString, return_to: returnTo}) }}" data-turbo-frame="_top">Edit</a>
                            <form method="post" action="{{ path('ui_admin_vehicle_delete', {id: vehicle.id.toString}) }}" data-turbo-frame="_top" onsubmit="return confirm('Delete this vehicle?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_vehicle_delete_' ~ vehicle.id.toString) }}">
                                <input type="hidden" name="_redirect" value="{{ returnTo }}">
                                <button class="btn btn-danger btn-compact" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="muted">No vehicles found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
