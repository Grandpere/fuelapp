{% extends 'base.html.twig' %}

{% block title %}Analytics Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
    <style>
        .analytics-page {
            display: grid;
            gap: 1rem;
        }

        .analytics-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .analytics-header p {
            margin: 0.35rem 0 0;
        }

        .analytics-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .analytics-filters {
            padding: 1rem;
            display: grid;
            gap: 0.8rem;
        }

        .analytics-filters-form {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 0.7rem;
            align-items: end;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .kpi-card {
            padding: 0.95rem;
            display: grid;
            gap: 0.35rem;
        }

        .kpi-label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--text-soft);
        }

        .kpi-value {
            font-family: "Space Grotesk", sans-serif;
            font-size: 1.24rem;
            font-weight: 700;
        }

        .trend-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.85rem;
        }

        .map-card {
            padding: 1rem;
            display: grid;
            gap: 0.8rem;
            align-content: start;
        }

        .map-card h2 {
            margin: 0;
            font-size: 1.05rem;
        }

        .map-canvas {
            height: 360px;
            border-radius: 12px;
            border: 1px solid rgba(92, 133, 159, 0.35);
            overflow: hidden;
            background: rgba(6, 26, 38, 0.55);
        }

        .station-map-list {
            display: grid;
            gap: 0.5rem;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .station-map-item {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem 0.9rem;
            padding: 0.6rem 0.7rem;
            border-radius: 10px;
            border: 1px solid rgba(92, 133, 159, 0.24);
            background: rgba(8, 26, 38, 0.5);
            font-size: 0.86rem;
        }

        .station-map-item strong {
            color: #e6f0f6;
        }

        .trend-card {
            padding: 1rem;
            display: grid;
            gap: 0.8rem;
            align-content: start;
        }

        .trend-card h2 {
            margin: 0;
            font-size: 1.05rem;
        }

        .trend-card-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: start;
            gap: 0.8rem;
        }

        .trend-card-header h2 {
            margin: 0;
            min-width: 0;
        }

        .trend-view-switch {
            display: inline-flex;
            gap: 0.35rem;
            padding: 0.22rem;
            border: 1px solid rgba(92, 133, 159, 0.28);
            border-radius: 999px;
            background: rgba(8, 26, 38, 0.42);
        }

        .trend-view-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 68px;
            padding: 0.4rem 0.7rem;
            border-radius: 999px;
            border: 0;
            background: transparent;
            color: var(--text-soft);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            transition: background 120ms ease, color 120ms ease, transform 120ms ease;
        }

        .trend-view-link:hover {
            color: #f4fbff;
            transform: translateY(-1px);
        }

        .trend-view-link.is-active {
            background: linear-gradient(135deg, rgba(247, 181, 0, 0.92), rgba(240, 138, 0, 0.96));
            color: #08141c;
        }

        .trend-list {
            display: grid;
            gap: 0.55rem;
        }

        .trend-row {
            display: grid;
            grid-template-columns: 68px minmax(0, 1fr) auto;
            align-items: center;
            gap: 0.55rem;
        }

        .trend-month {
            color: var(--text-soft);
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.02em;
        }

        .trend-bar-wrap {
            background: rgba(6, 26, 38, 0.55);
            border: 1px solid rgba(92, 133, 159, 0.32);
            border-radius: 999px;
            height: 12px;
            overflow: hidden;
        }

        .trend-bar {
            height: 100%;
            border-radius: 999px;
        }

        .trend-bar-cost {
            background: linear-gradient(120deg, rgba(247, 181, 0, 0.88), rgba(240, 138, 0, 0.94));
        }

        .trend-bar-consumption {
            background: linear-gradient(120deg, rgba(97, 221, 255, 0.88), rgba(38, 167, 241, 0.94));
        }

        .trend-bar-price {
            background: linear-gradient(120deg, rgba(189, 255, 121, 0.88), rgba(76, 207, 78, 0.94));
        }

        .trend-bar-fuel {
            background: linear-gradient(120deg, rgba(247, 181, 0, 0.88), rgba(240, 138, 0, 0.94));
        }

        .trend-bar-maintenance {
            background: linear-gradient(120deg, rgba(255, 143, 170, 0.88), rgba(226, 75, 126, 0.94));
        }

        .trend-bar-total {
            background: linear-gradient(120deg, rgba(97, 221, 255, 0.88), rgba(38, 167, 241, 0.94));
        }

        .compared-trend-grid {
            display: grid;
            gap: 0.55rem;
        }

        .compared-trend-row {
            display: grid;
            gap: 0.45rem;
            padding: 0.55rem 0.6rem;
            border: 1px solid rgba(92, 133, 159, 0.25);
            border-radius: 10px;
            background: rgba(8, 26, 38, 0.5);
        }

        .compared-trend-label {
            color: var(--text-soft);
            font-size: 0.82rem;
            font-weight: 600;
        }

        .compared-trend-track {
            display: grid;
            grid-template-columns: 88px minmax(0, 1fr) auto;
            align-items: center;
            gap: 0.5rem;
        }

        .trend-value {
            font-size: 0.82rem;
            color: #d6e5ef;
            font-weight: 600;
            white-space: nowrap;
        }

        .trend-line-chart {
            display: grid;
            gap: 0.35rem;
        }

        .trend-chart-shell {
            position: relative;
            height: 236px;
            padding: 0.75rem 0.85rem 0.55rem;
            border-radius: 14px;
            border: 1px solid rgba(92, 133, 159, 0.26);
            background: linear-gradient(180deg, rgba(13, 39, 55, 0.92), rgba(8, 25, 37, 0.76));
        }

        .trend-chart-shell.compared {
            height: 252px;
        }

        .trend-chart-canvas {
            width: 100%;
            height: 100%;
        }

        .trend-line-shell {
            position: relative;
            height: 236px;
            padding: 0.85rem 0.7rem 1rem 2.9rem;
            border-radius: 14px;
            border: 1px solid rgba(92, 133, 159, 0.26);
            background:
                linear-gradient(to top, rgba(147, 178, 198, 0.06) 1px, transparent 1px) 0 0 / 100% 25%,
                linear-gradient(180deg, rgba(13, 39, 55, 0.92), rgba(8, 25, 37, 0.76));
        }

        .trend-line-shell.compared {
            height: 252px;
        }

        .trend-line-svg {
            width: 100%;
            height: 100%;
            overflow: visible;
        }

        .trend-line-path {
            fill: none;
            stroke-width: 1.45;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .trend-line-area {
            stroke: none;
            opacity: 0.1;
        }

        .trend-line-point {
            stroke-width: 1;
            fill: #08141c;
        }

        .trend-line-point.is-subtle {
            opacity: 0.75;
        }

        .trend-line-axis {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }

        .trend-line-axis-line {
            stroke: rgba(147, 178, 198, 0.42);
            stroke-width: 0.7;
        }

        .trend-line-grid-line {
            stroke: rgba(147, 178, 198, 0.18);
            stroke-width: 0.5;
            stroke-dasharray: 1.8 2.4;
        }

        .trend-line-y-axis {
            position: absolute;
            inset: 0.8rem auto 1rem 0.5rem;
            width: 2rem;
            color: rgba(214, 229, 239, 0.78);
            font-size: 0.66rem;
            font-weight: 600;
            letter-spacing: 0.01em;
        }

        .trend-line-y-axis-unit {
            position: absolute;
            top: -0.1rem;
            left: 0;
            color: rgba(230, 240, 246, 0.92);
            font-size: 0.64rem;
            text-transform: uppercase;
        }

        .trend-line-y-axis-label {
            position: absolute;
            left: 0;
            transform: translateY(50%);
            white-space: nowrap;
        }

        .trend-line-y-axis-label.is-top {
            top: 0;
            transform: none;
        }

        .trend-line-y-axis-label.is-mid {
            top: 50%;
            transform: translateY(-50%);
        }

        .trend-line-y-axis-label.is-bottom {
            bottom: 0;
            transform: none;
        }

        .trend-line-x-axis {
            display: grid;
            gap: 0.35rem;
            padding: 0 0.35rem 0 2.9rem;
            align-items: start;
        }

        .trend-line-x-axis-label {
            text-align: center;
            color: rgba(214, 229, 239, 0.72);
            font-size: 0.68rem;
            line-height: 1.15;
            font-weight: 600;
        }

        .trend-line-x-axis-label span {
            display: block;
            color: rgba(147, 178, 198, 0.86);
            font-size: 0.62rem;
            font-weight: 500;
        }

        .trend-line-axis-caption {
            display: flex;
            justify-content: space-between;
            gap: 0.7rem;
            padding: 0 0.35rem 0 2.9rem;
            color: rgba(147, 178, 198, 0.9);
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .trend-line-price {
            stroke: #9bff76;
        }

        .trend-line-price-fill {
            fill: #9bff76;
        }

        .trend-line-cost {
            stroke: #f7b500;
        }

        .trend-line-cost-fill {
            fill: #f7b500;
        }

        .trend-line-consumption {
            stroke: #61ddff;
        }

        .trend-line-consumption-fill {
            fill: #61ddff;
        }

        .trend-line-maintenance {
            stroke: #ff8faa;
        }

        .trend-line-maintenance-fill {
            fill: #ff8faa;
        }

        .trend-line-total {
            stroke: #4ccf4e;
        }

        .trend-line-total-fill {
            fill: #4ccf4e;
        }

        .empty-state {
            padding: 0.8rem;
            border: 1px dashed rgba(147, 178, 198, 0.35);
            border-radius: 10px;
            color: var(--text-soft);
        }

        .trend-mode {
            display: none;
        }

        .trend-card[data-chart-view="bars"] .trend-mode-bars,
        .trend-card[data-chart-view="line"] .trend-mode-line {
            display: grid;
        }

        @media (max-width: 980px) {
            .analytics-filters-form,
            .kpi-grid,
            .trend-grid {
                grid-template-columns: 1fr;
            }

            .trend-card-header {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell analytics-page">
        <section class="analytics-header">
            <div>
                <h1 class="page-title">Analytics Dashboard</h1>
                <p class="muted">Pilot fuel spend and consumption trends across your selected period.</p>
            </div>
            <div class="analytics-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_export', exportQueryParams) }}">Export CSV</a>
                <a class="btn btn-secondary" href="{{ path('ui_receipt_export', exportQueryParams|merge({ format: 'xlsx' })) }}">Export XLSX</a>
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}">Receipts</a>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_index') }}">Maintenance</a>
            </div>
        </section>

        <section class="card analytics-filters">
            <form class="analytics-filters-form" method="get" action="{{ path('ui_analytics_dashboard') }}">
                <label class="label">
                    From
                    <input class="input" type="date" name="from" value="{{ fromFilter ?? '' }}">
                </label>
                <label class="label">
                    To
                    <input class="input" type="date" name="to" value="{{ toFilter ?? '' }}">
                </label>
                <label class="label">
                    Vehicle
                    <select class="select" name="vehicle_id">
                        <option value="">All vehicles</option>
                        {% for optionId, optionLabel in vehicleOptions %}
                            <option value="{{ optionId }}" {% if vehicleFilter == optionId %}selected{% endif %}>{{ optionLabel }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    Station
                    <select class="select" name="station_id">
                        <option value="">All stations</option>
                        {% for stationOption in stationOptions %}
                            <option value="{{ stationOption.id }}" {% if stationFilter == stationOption.id %}selected{% endif %}>{{ stationOption.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    Fuel type
                    <select class="select" name="fuel_type">
                        <option value="">All fuel types</option>
                        {% for fuelTypeChoice in fuelTypeChoices %}
                            <option value="{{ fuelTypeChoice }}" {% if fuelTypeFilter == fuelTypeChoice %}selected{% endif %}>{{ fuelTypeChoice }}</option>
                        {% endfor %}
                    </select>
                </label>
                <div style="display:flex; gap:0.6rem; flex-wrap:wrap;">
                    <button class="btn btn-primary" type="submit">Apply filters</button>
                    <a class="btn btn-secondary" href="{{ path('ui_analytics_dashboard') }}">Reset</a>
                </div>
            </form>
        </section>

        <section class="kpi-grid">
            <article class="card-subtle kpi-card">
                <div class="kpi-label">Total cost</div>
                <div class="kpi-value">{{ (totalCostCents / 100)|number_format(2, '.', ' ') }} EUR</div>
            </article>
            <article class="card-subtle kpi-card">
                <div class="kpi-label">Fuel volume</div>
                <div class="kpi-value">{{ (totalQuantityMilliLiters / 1000)|number_format(2, '.', ' ') }} L</div>
            </article>
            <article class="card-subtle kpi-card">
                <div class="kpi-label">Average fuel price</div>
                <div class="kpi-value">
                    {% if averagePriceDeciCentsPerLiter is not null %}
                        {{ (averagePriceDeciCentsPerLiter / 1000)|number_format(3, '.', ' ') }} EUR/L
                    {% else %}
                        n/a
                    {% endif %}
                </div>
            </article>
        </section>

        <section class="card map-card">
            <h2>Visited stations map</h2>
            {% if stationMapPoints is empty %}
                <div class="empty-state">No geocoded station data for current filters.</div>
            {% else %}
                <div class="map-canvas" id="analytics-station-map"></div>
                <ul class="station-map-list">
                    {% for point in stationMapPoints %}
                        <li class="station-map-item">
                            <strong>{{ point.stationName }}</strong>
                            <span>{{ point.address }}</span>
                            <span>{{ (point.totalCostCents / 100)|number_format(2, '.', ' ') }} EUR</span>
                            <span>{{ (point.totalQuantityMilliLiters / 1000)|number_format(2, '.', ' ') }} L</span>
                            <span>{{ point.receiptCount }} receipt(s)</span>
                        </li>
                    {% endfor %}
                </ul>
                <script type="application/json" id="analytics-station-map-data">{{ stationMapPoints|json_encode|raw }}</script>
            {% endif %}
        </section>

        <section class="trend-grid">
            <article class="card trend-card" data-controller="analytics-chart" data-chart-key="cost" data-default-view="bars">
                <div class="trend-card-header">
                    <h2>Cost trend by month</h2>
                    <div class="trend-view-switch">
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="bars">Bars</button>
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="line">Lines</button>
                    </div>
                </div>
                {% if costTrend is empty %}
                    <div class="empty-state">No cost data for current filters.</div>
                {% else %}
                    {% set costChartLabels = [] %}
                    {% set costChartValues = [] %}
                    {% for item in costTrend %}
                        {% set costChartLabels = costChartLabels|merge([item.month]) %}
                        {% set costChartValues = costChartValues|merge([(item.value / 100)|round(2)]) %}
                    {% endfor %}
                    <script type="application/json" data-analytics-chart-target="config">{{ {
                        key: 'cost',
                        defaultView: 'bars',
                        yAxisLabel: 'EUR',
                        valueFormat: 'currency',
                        labels: costChartLabels,
                        datasets: [
                            {
                                label: 'Cost',
                                data: costChartValues,
                                borderColor: '#f7b500',
                                fillColor: 'rgba(247, 181, 0, 0.16)',
                                barColor: 'rgba(247, 181, 0, 0.88)'
                            }
                        ]
                    }|json_encode|raw }}</script>
                    <div class="trend-mode trend-mode-line trend-line-chart">
                        <div class="trend-chart-shell">
                            <canvas class="trend-chart-canvas" data-analytics-chart-target="canvas"></canvas>
                        </div>
                    </div>
                    <div class="trend-mode trend-mode-bars trend-list">
                        {% for item in costTrend %}
                            <div class="trend-row">
                                <span class="trend-month">{{ item.month }}</span>
                                <div class="trend-bar-wrap">
                                    <div class="trend-bar trend-bar-cost" style="width: {{ item.ratio }}%;"></div>
                                </div>
                                <span class="trend-value">{{ (item.value / 100)|number_format(2, '.', ' ') }} EUR</span>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>

            <article class="card trend-card" data-controller="analytics-chart" data-chart-key="consumption" data-default-view="bars">
                <div class="trend-card-header">
                    <h2>Consumption trend by month</h2>
                    <div class="trend-view-switch">
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="bars">Bars</button>
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="line">Lines</button>
                    </div>
                </div>
                {% if consumptionTrend is empty %}
                    <div class="empty-state">No consumption data for current filters.</div>
                {% else %}
                    {% set consumptionChartLabels = [] %}
                    {% set consumptionChartValues = [] %}
                    {% for item in consumptionTrend %}
                        {% set consumptionChartLabels = consumptionChartLabels|merge([item.month]) %}
                        {% set consumptionChartValues = consumptionChartValues|merge([(item.value / 1000)|round(2)]) %}
                    {% endfor %}
                    <script type="application/json" data-analytics-chart-target="config">{{ {
                        key: 'consumption',
                        defaultView: 'bars',
                        yAxisLabel: 'L',
                        valueFormat: 'liters',
                        labels: consumptionChartLabels,
                        datasets: [
                            {
                                label: 'Consumption',
                                data: consumptionChartValues,
                                borderColor: '#61ddff',
                                fillColor: 'rgba(97, 221, 255, 0.16)',
                                barColor: 'rgba(97, 221, 255, 0.88)'
                            }
                        ]
                    }|json_encode|raw }}</script>
                    <div class="trend-mode trend-mode-line trend-line-chart">
                        <div class="trend-chart-shell">
                            <canvas class="trend-chart-canvas" data-analytics-chart-target="canvas"></canvas>
                        </div>
                    </div>
                    <div class="trend-mode trend-mode-bars trend-list">
                        {% for item in consumptionTrend %}
                            <div class="trend-row">
                                <span class="trend-month">{{ item.month }}</span>
                                <div class="trend-bar-wrap">
                                    <div class="trend-bar trend-bar-consumption" style="width: {{ item.ratio }}%;"></div>
                                </div>
                                <span class="trend-value">{{ (item.value / 1000)|number_format(2, '.', ' ') }} L</span>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>

            <article class="card trend-card" data-controller="analytics-chart" data-chart-key="fuel-price" data-default-view="line">
                <div class="trend-card-header">
                    <h2>Fuel price trend by month</h2>
                    <div class="trend-view-switch">
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="bars">Bars</button>
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="line">Lines</button>
                    </div>
                </div>
                {% if fuelPriceTrend is empty %}
                    <div class="empty-state">No fuel price data for current filters.</div>
                {% else %}
                    {% set fuelPriceChartLabels = [] %}
                    {% set fuelPriceChartValues = [] %}
                    {% for item in fuelPriceTrend %}
                        {% set fuelPriceChartLabels = fuelPriceChartLabels|merge([[item.month, item.fuelType]]) %}
                        {% set fuelPriceChartValues = fuelPriceChartValues|merge([((item.averagePriceDeciCentsPerLiter ?? 0) / 1000)|round(3)]) %}
                    {% endfor %}
                    <script type="application/json" data-analytics-chart-target="config">{{ {
                        key: 'fuel-price',
                        defaultView: 'line',
                        yAxisLabel: 'EUR/L',
                        valueFormat: 'fuel_price',
                        labels: fuelPriceChartLabels,
                        datasets: [
                            {
                                label: 'Fuel price',
                                data: fuelPriceChartValues,
                                borderColor: '#9bff76',
                                fillColor: 'rgba(155, 255, 118, 0.12)',
                                barColor: 'rgba(155, 255, 118, 0.86)',
                                subtlePoints: true
                            }
                        ]
                    }|json_encode|raw }}</script>
                    <div class="trend-mode trend-mode-line trend-line-chart">
                        <div class="trend-chart-shell">
                            <canvas class="trend-chart-canvas" data-analytics-chart-target="canvas"></canvas>
                        </div>
                    </div>
                    <div class="trend-mode trend-mode-bars trend-list">
                        {% for item in fuelPriceTrend %}
                            <div class="trend-row">
                                <span class="trend-month">{{ item.month }} · {{ item.fuelType }}</span>
                                <div class="trend-bar-wrap">
                                    <div class="trend-bar trend-bar-price" style="width: {{ item.ratio }}%;"></div>
                                </div>
                                <span class="trend-value">
                                    {% if item.averagePriceDeciCentsPerLiter is not null %}
                                        {{ (item.averagePriceDeciCentsPerLiter / 1000)|number_format(3, '.', ' ') }} EUR/L
                                    {% else %}
                                        n/a
                                    {% endif %}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>

            <article class="card trend-card" data-controller="analytics-chart" data-chart-key="compared-cost" data-default-view="bars">
                <div class="trend-card-header">
                    <h2>Compared cost trend (fuel vs maintenance vs total)</h2>
                    <div class="trend-view-switch">
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="bars">Bars</button>
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="line">Lines</button>
                    </div>
                </div>
                {% if comparedCostTrend is empty %}
                    <div class="empty-state">No compared cost data for current filters.</div>
                {% else %}
                    {% set comparedLabels = [] %}
                    {% set comparedFuelValues = [] %}
                    {% set comparedMaintenanceValues = [] %}
                    {% set comparedTotalValues = [] %}
                    {% for item in comparedCostTrend %}
                        {% set comparedLabels = comparedLabels|merge([item.month]) %}
                        {% set comparedFuelValues = comparedFuelValues|merge([(item.fuelCostCents / 100)|round(2)]) %}
                        {% set comparedMaintenanceValues = comparedMaintenanceValues|merge([(item.maintenanceCostCents / 100)|round(2)]) %}
                        {% set comparedTotalValues = comparedTotalValues|merge([(item.totalCostCents / 100)|round(2)]) %}
                    {% endfor %}
                    <script type="application/json" data-analytics-chart-target="config">{{ {
                        key: 'compared-cost',
                        defaultView: 'bars',
                        yAxisLabel: 'EUR',
                        valueFormat: 'currency',
                        labels: comparedLabels,
                        datasets: [
                            {
                                label: 'Fuel',
                                data: comparedFuelValues,
                                borderColor: '#f7b500',
                                fillColor: 'rgba(247, 181, 0, 0.1)',
                                barColor: 'rgba(247, 181, 0, 0.88)',
                                fill: false,
                                subtlePoints: true
                            },
                            {
                                label: 'Maintenance',
                                data: comparedMaintenanceValues,
                                borderColor: '#ff8faa',
                                fillColor: 'rgba(255, 143, 170, 0.1)',
                                barColor: 'rgba(255, 143, 170, 0.88)',
                                fill: false,
                                subtlePoints: true
                            },
                            {
                                label: 'Total',
                                data: comparedTotalValues,
                                borderColor: '#4ccf4e',
                                fillColor: 'rgba(76, 207, 78, 0.1)',
                                barColor: 'rgba(76, 207, 78, 0.88)',
                                fill: false,
                                subtlePoints: true
                            }
                        ]
                    }|json_encode|raw }}</script>
                    <div class="trend-mode trend-mode-line trend-line-chart">
                        <div class="trend-chart-shell compared">
                            <canvas class="trend-chart-canvas" data-analytics-chart-target="canvas"></canvas>
                        </div>
                    </div>
                    <div class="trend-mode trend-mode-bars compared-trend-grid">
                        {% for item in comparedCostTrend %}
                            <div class="compared-trend-row">
                                <div class="compared-trend-label">{{ item.month }}</div>
                                <div class="compared-trend-track">
                                    <span class="trend-month">Fuel</span>
                                    <div class="trend-bar-wrap"><div class="trend-bar trend-bar-fuel" style="width: {{ item.fuelRatio }}%;"></div></div>
                                    <span class="trend-value">{{ (item.fuelCostCents / 100)|number_format(2, '.', ' ') }} EUR</span>
                                </div>
                                <div class="compared-trend-track">
                                    <span class="trend-month">Maint.</span>
                                    <div class="trend-bar-wrap"><div class="trend-bar trend-bar-maintenance" style="width: {{ item.maintenanceRatio }}%;"></div></div>
                                    <span class="trend-value">{{ (item.maintenanceCostCents / 100)|number_format(2, '.', ' ') }} EUR</span>
                                </div>
                                <div class="compared-trend-track">
                                    <span class="trend-month">Total</span>
                                    <div class="trend-bar-wrap"><div class="trend-bar trend-bar-total" style="width: {{ item.totalRatio }}%;"></div></div>
                                    <span class="trend-value">{{ (item.totalCostCents / 100)|number_format(2, '.', ' ') }} EUR</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>
        </section>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script>
        const initAnalyticsStationMap = () => {
            const mapContainer = document.getElementById('analytics-station-map');
            const dataContainer = document.getElementById('analytics-station-map-data');
            if (!mapContainer || !dataContainer || typeof L === 'undefined') {
                return;
            }
            if (mapContainer.dataset.mapInitialized === '1') {
                return;
            }

            let points = [];
            try {
                points = JSON.parse(dataContainer.textContent || '[]');
            } catch (error) {
                points = [];
            }

            if (!Array.isArray(points) || points.length === 0) {
                return;
            }

            const map = L.map(mapContainer, {scrollWheelZoom: false});
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 18,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const escapeHtml = (value) => String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');

            const bounds = [];
            points.forEach((point) => {
                if (typeof point.latitude !== 'number' || typeof point.longitude !== 'number') {
                    return;
                }

                const marker = L.marker([point.latitude, point.longitude]).addTo(map);
                const stationName = escapeHtml(point.stationName);
                const address = escapeHtml(point.address);
                marker.bindPopup(
                    `<strong>${stationName}</strong><br>` +
                    `${address}<br>` +
                    `${(point.totalCostCents / 100).toFixed(2)} EUR · ${(point.totalQuantityMilliLiters / 1000).toFixed(2)} L`
                );
                bounds.push([point.latitude, point.longitude]);
            });

            if (bounds.length === 1) {
                map.setView(bounds[0], 12);
            } else if (bounds.length > 1) {
                map.fitBounds(bounds, {padding: [20, 20]});
            } else {
                map.setView([46.603354, 1.888334], 5);
            }

            mapContainer.dataset.mapInitialized = '1';
            setTimeout(() => map.invalidateSize(), 0);
        };

        document.addEventListener('DOMContentLoaded', initAnalyticsStationMap);
        document.addEventListener('turbo:load', initAnalyticsStationMap);
    </script>
{% endblock %}
