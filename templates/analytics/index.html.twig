                                <div class="compared-trend-track">
                                    <span class="trend-month">Total</span>
                                    <div class="trend-bar-wrap"><div class="trend-bar trend-bar-total" style="width: {{ item.totalRatio }}%;"></div></div>
                                    <span class="trend-value">{{ (item.totalCostCents / 100)|number_format(2, '.', ' ') }} EUR</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>
        </section>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script id="leaflet-script" src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script>
        const initAnalyticsStationMap = () => {
            const mapContainer = document.getElementById('analytics-station-map');
            const dataContainer = document.getElementById('analytics-station-map-data');
            if (!mapContainer || !dataContainer) {
                return;
            }
            if (mapContainer.dataset.mapInitialized === '1') {
                return;
            }

            if (typeof L === 'undefined') {
                const leafletScript = document.getElementById('leaflet-script');
                if (leafletScript && leafletScript.dataset.analyticsMapBound !== '1') {
                    leafletScript.addEventListener('load', initAnalyticsStationMap, { once: true });
                    leafletScript.dataset.analyticsMapBound = '1';
                }

                return;
            }

            let mapData = { visitedPoints: [], publicPoints: [], nearbyPublicPoints: [] };
            try {
                mapData = JSON.parse(dataContainer.textContent || '{"visitedPoints":[],"publicPoints":[],"nearbyPublicPoints":[]}');
            } catch (error) {
                mapData = { visitedPoints: [], publicPoints: [], nearbyPublicPoints: [] };
            }

            const visitedPoints = Array.isArray(mapData.visitedPoints) ? mapData.visitedPoints : [];
            const publicPoints = Array.isArray(mapData.publicPoints) ? mapData.publicPoints : [];
            const nearbyPublicPoints = Array.isArray(mapData.nearbyPublicPoints) ? mapData.nearbyPublicPoints : [];

            if (visitedPoints.length === 0 && publicPoints.length === 0 && nearbyPublicPoints.length === 0) {
                return;
            }

            const map = L.map(mapContainer, {scrollWheelZoom: false});
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 18,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const escapeHtml = (value) => String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');

            const bounds = [];
            const visitedLayer = L.layerGroup();
            const publicLayer = L.layerGroup();
            const nearbyLayer = L.layerGroup();

            const visitedIcon = L.divIcon({
                className: 'analytics-map-visited-icon',
                html: '<span style="display:block;width:14px;height:14px;border-radius:999px;background:#f7b500;border:2px solid #24364b;box-shadow:0 0 0 2px rgba(255,255,255,0.72)"></span>',
                iconSize: [14, 14],
                iconAnchor: [7, 7],
            });

            visitedPoints.forEach((point) => {
                if (typeof point.latitude !== 'number' || typeof point.longitude !== 'number') {
                    return;
                }

                const marker = L.marker([point.latitude, point.longitude], { icon: visitedIcon }).addTo(visitedLayer);
                const stationName = escapeHtml(point.stationName);
                const address = escapeHtml(point.address);
                const publicMatch = point.publicMatch && typeof point.publicMatch === 'object' ? point.publicMatch : null;
                const publicMatchHtml = publicMatch
                    ? `<div class="popup-meta">Public match</div>` +
                        `<div>${escapeHtml(publicMatch.address)}, ${escapeHtml(publicMatch.postalCode)} ${escapeHtml(publicMatch.city)}</div>` +
                        (typeof publicMatch.distanceMeters === 'number' ? `<div class="popup-meta">${publicMatch.distanceMeters} m away · ${escapeHtml(publicMatch.confidence)}</div>` : `<div class="popup-meta">${escapeHtml(publicMatch.confidence)}</div>`) +
                        (Array.isArray(publicMatch.availableFuelLabels) && publicMatch.availableFuelLabels.length > 0 ? `<div class="popup-highlight">${escapeHtml(publicMatch.availableFuelLabels.join(', '))}</div>` : '')
                    : '';
                marker.bindPopup(
                    `<div class="analytics-map-popup">` +
                    `<div class="popup-kicker">Visited station</div>` +
                    `<strong>${stationName}</strong>` +
                    `<div>${address}</div>` +
                    `<div class="popup-highlight">${(point.totalCostCents / 100).toFixed(2)} EUR · ${(point.totalQuantityMilliLiters / 1000).toFixed(2)} L</div>` +
                    `<div class="popup-meta">${point.receiptCount} receipt(s)</div>` +
                    publicMatchHtml +
                    `</div>`
                );
                bounds.push([point.latitude, point.longitude]);
            });

            publicPoints.forEach((point) => {
                if (typeof point.latitude !== 'number' || typeof point.longitude !== 'number') {
                    return;
                }

                const marker = L.circleMarker([point.latitude, point.longitude], {
                    radius: 8,
                    color: '#24364b',
                    weight: 2,
                    fillColor: '#61ddff',
                    fillOpacity: 0.82,
                }).addTo(publicLayer);

                marker.bindPopup(
                    `<div class="analytics-map-popup">` +
                    `<div class="popup-kicker">Public station</div>` +
                    `<strong>${escapeHtml(point.address)}</strong>` +
                    `<div>${escapeHtml(point.postalCode)} ${escapeHtml(point.city)}</div>` +
                    `<div class="popup-meta">${escapeHtml(point.confidence)} match` +
                    (typeof point.distanceMeters === 'number' ? ` · ${point.distanceMeters} m` : '') +
                    `</div>` +
                    (Array.isArray(point.availableFuelLabels) && point.availableFuelLabels.length > 0 ? `<div class="popup-highlight">${escapeHtml(point.availableFuelLabels.join(', '))}</div>` : '') +
                    (Array.isArray(point.matchedStationNames) && point.matchedStationNames.length > 0 ? `<div class="popup-meta">Linked to: ${escapeHtml(point.matchedStationNames.join(', '))}</div>` : '') +
                    `</div>`
                );

                bounds.push([point.latitude, point.longitude]);
            });

            nearbyPublicPoints.forEach((point) => {
                if (typeof point.latitude !== 'number' || typeof point.longitude !== 'number') {
                    return;
                }

                const marker = L.circleMarker([point.latitude, point.longitude], {
                    radius: 7,
                    color: '#24364b',
                    weight: 2,
                    dashArray: '3 2',
                    fillColor: '#9bff76',
                    fillOpacity: 0.82,
                }).addTo(nearbyLayer);

                marker.bindPopup(
                    `<div class="analytics-map-popup">` +
                    `<div class="popup-kicker">Nearby public station</div>` +
                    `<strong>${escapeHtml(point.address)}</strong>` +
                    `<div>${escapeHtml(point.postalCode)} ${escapeHtml(point.city)}</div>` +
                    `<div class="popup-meta">${point.distanceMeters} m from visited context</div>` +
                    (Array.isArray(point.availableFuelLabels) && point.availableFuelLabels.length > 0 ? `<div class="popup-highlight">${escapeHtml(point.availableFuelLabels.join(', '))}</div>` : '') +
                    (Array.isArray(point.nearbyStationNames) && point.nearbyStationNames.length > 0 ? `<div class="popup-meta">Nearby: ${escapeHtml(point.nearbyStationNames.join(', '))}</div>` : '') +
                    `</div>`
                );

                bounds.push([point.latitude, point.longitude]);
            });

            visitedLayer.addTo(map);
            if (publicPoints.length > 0) {
                publicLayer.addTo(map);
            }
            if (nearbyPublicPoints.length > 0) {
                nearbyLayer.addTo(map);
            }
            if (publicPoints.length > 0 || nearbyPublicPoints.length > 0) {
                L.control.layers({}, {
                    'Visited stations': visitedLayer,
                    'Matched public stations': publicLayer,
                    'Nearby public stations': nearbyLayer,
                }, { collapsed: false }).addTo(map);
            }

            if (bounds.length === 1) {
                map.setView(bounds[0], 12);
            } else if (bounds.length > 1) {
                map.fitBounds(bounds, {padding: [20, 20]});
            } else {
                map.setView([46.603354, 1.888334], 5);
            }

            mapContainer.dataset.mapInitialized = '1';
            setTimeout(() => map.invalidateSize(), 0);
        };

        document.addEventListener('DOMContentLoaded', initAnalyticsStationMap);
        document.addEventListener('turbo:load', initAnalyticsStationMap);
    </script>
{% endblock %}
