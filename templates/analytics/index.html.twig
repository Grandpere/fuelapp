{% extends 'base.html.twig' %}

{% block title %}Analytics Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
    <style>
        .analytics-page {
            display: grid;
            gap: 1rem;
        }

        .analytics-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .analytics-header p {
            margin: 0.35rem 0 0;
        }

        .analytics-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .analytics-filter-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .analytics-shortcuts {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .analytics-active-filters {
            display: flex;
            gap: 0.55rem;
            flex-wrap: wrap;
        }

        .analytics-context-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .analytics-filters {
            padding: 1rem;
            display: grid;
            gap: 0.8rem;
        }

        .analytics-filters-form {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 0.7rem;
            align-items: end;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .kpi-card {
            padding: 0.95rem;
            display: grid;
            gap: 0.35rem;
        }

        .kpi-label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--text-soft);
        }

        .kpi-value {
            font-family: var(--font-display);
            font-size: 1.24rem;
            font-weight: 700;
        }

        .trend-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.85rem;
        }

        .map-card {
            padding: 1rem;
            display: grid;
            gap: 0.8rem;
            align-content: start;
        }

        .map-card h2 {
            margin: 0;
            font-size: 1.05rem;
        }

        .map-card-head {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .map-card-head p {
            margin: 0.2rem 0 0;
        }

        .map-card-badges {
            display: flex;
            gap: 0.45rem;
            flex-wrap: wrap;
        }

        .map-legend {
            display: flex;
            gap: 0.65rem 1rem;
            flex-wrap: wrap;
            align-items: center;
            padding: 0.7rem 0.85rem;
            border-radius: 12px;
            border: 1px solid var(--surface-soft-border);
            background: var(--surface-soft-bg);
            font-size: 0.82rem;
            color: var(--text-soft);
        }

        .map-legend-item {
            display: inline-flex;
            gap: 0.45rem;
            align-items: center;
        }

        .map-legend-dot {
            display: inline-block;
            width: 0.9rem;
            height: 0.9rem;
            border-radius: 999px;
            border: 2px solid #24364b;
        }

        .map-legend-dot.visited {
            background: #f7b500;
            box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.72);
        }

        .map-legend-dot.public {
            background: #61ddff;
        }

        .map-legend-dot.nearby {
            background: #9bff76;
        }

        .map-canvas {
            height: 360px;
            border-radius: 12px;
            border: 1px solid var(--surface-soft-border-strong);
            overflow: hidden;
            background: var(--surface-soft-bg-strong);
        }

        .station-map-list {
            display: grid;
            gap: 0.5rem;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .station-map-item {
            display: grid;
            gap: 0.45rem;
            padding: 0.6rem 0.7rem;
            border-radius: 10px;
            border: 1px solid var(--surface-soft-border);
            background: var(--surface-soft-bg);
            font-size: 0.86rem;
        }

        .station-map-item-head,
        .station-map-item-row,
        .station-map-item-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem 0.8rem;
            align-items: center;
        }

        .station-map-item strong {
            color: var(--text-strong);
        }

        .station-map-item-match {
            color: var(--text-soft);
            font-size: 0.82rem;
        }

        .analytics-map-popup {
            display: grid;
            gap: 0.32rem;
            min-width: 220px;
            line-height: 1.35;
        }

        .analytics-map-popup strong {
            color: var(--text-strong);
        }

        .analytics-map-popup .popup-kicker {
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--text-soft);
        }

        .analytics-map-popup .popup-meta {
            color: var(--text-soft);
            font-size: 0.82rem;
        }

        .analytics-map-popup .popup-highlight {
            color: var(--text-strong);
            font-weight: 600;
        }

        .trend-card {
            padding: 1rem;
            display: grid;
            gap: 0.8rem;
            align-content: start;
        }

        .trend-card h2 {
            margin: 0;
            font-size: 1.05rem;
        }

        .trend-card-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: start;
            gap: 0.8rem;
        }

        .trend-card-header h2 {
            margin: 0;
            min-width: 0;
        }

        .trend-view-switch {
            display: inline-flex;
            gap: 0.35rem;
            padding: 0.22rem;
            border: 1px solid var(--surface-soft-border);
            border-radius: 999px;
            background: var(--surface-soft-bg);
        }

        .trend-view-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 68px;
            padding: 0.4rem 0.7rem;
            border-radius: 999px;
            border: 0;
            background: transparent;
            color: var(--text-soft);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            transition: background 120ms ease, color 120ms ease, transform 120ms ease;
        }

        .trend-view-link:hover {
            color: var(--text-strong);
            transform: translateY(-1px);
        }

        .trend-view-link.is-active {
            background: linear-gradient(135deg, rgba(247, 181, 0, 0.92), rgba(240, 138, 0, 0.96));
            color: var(--nav-active-text);
        }

        .trend-list {
            display: grid;
            gap: 0.55rem;
        }

        .trend-row {
            display: grid;
            grid-template-columns: 68px minmax(0, 1fr) auto;
            align-items: center;
            gap: 0.55rem;
        }

        .trend-month {
            color: var(--text-soft);
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.02em;
        }

        .trend-bar-wrap {
            background: var(--surface-soft-bg-strong);
            border: 1px solid var(--surface-soft-border-strong);
            border-radius: 999px;
            height: 12px;
            overflow: hidden;
        }

        .trend-bar {
            height: 100%;
            border-radius: 999px;
        }

        .trend-bar-cost {
            background: linear-gradient(120deg, rgba(247, 181, 0, 0.88), rgba(240, 138, 0, 0.94));
        }

        .trend-bar-consumption {
            background: linear-gradient(120deg, rgba(97, 221, 255, 0.88), rgba(38, 167, 241, 0.94));
        }

        .trend-bar-price {
            background: linear-gradient(120deg, rgba(189, 255, 121, 0.88), rgba(76, 207, 78, 0.94));
        }

        .trend-bar-fuel {
            background: linear-gradient(120deg, rgba(247, 181, 0, 0.88), rgba(240, 138, 0, 0.94));
        }

        .trend-bar-maintenance {
            background: linear-gradient(120deg, rgba(255, 143, 170, 0.88), rgba(226, 75, 126, 0.94));
        }

        .trend-bar-total {
            background: linear-gradient(120deg, rgba(97, 221, 255, 0.88), rgba(38, 167, 241, 0.94));
        }

        .compared-trend-grid {
            display: grid;
            gap: 0.55rem;
        }

        .compared-trend-row {
            display: grid;
            gap: 0.45rem;
            padding: 0.55rem 0.6rem;
            border: 1px solid var(--surface-soft-border);
            border-radius: 10px;
            background: var(--surface-soft-bg);
        }

        .compared-trend-label {
            color: var(--text-soft);
            font-size: 0.82rem;
            font-weight: 600;
        }

        .compared-trend-track {
            display: grid;
            grid-template-columns: 88px minmax(0, 1fr) auto;
            align-items: center;
            gap: 0.5rem;
        }

        .trend-value {
            font-size: 0.82rem;
            color: var(--chart-text);
            font-weight: 600;
            white-space: nowrap;
        }

        .trend-line-chart {
            display: grid;
            gap: 0.35rem;
        }

        .trend-chart-shell {
            position: relative;
            height: 236px;
            padding: 0.75rem 0.85rem 0.55rem;
            border-radius: 14px;
            border: 1px solid var(--surface-soft-border);
            background: var(--surface-chart-bg);
        }

        .trend-chart-shell.compared {
            height: 252px;
        }

        .trend-chart-canvas {
            width: 100%;
            height: 100%;
        }

        .trend-line-shell {
            position: relative;
            height: 236px;
            padding: 0.85rem 0.7rem 1rem 2.9rem;
            border-radius: 14px;
            border: 1px solid var(--surface-soft-border);
            background:
                linear-gradient(to top, var(--surface-chart-grid) 1px, transparent 1px) 0 0 / 100% 25%,
                var(--surface-chart-bg);
        }

        .trend-line-shell.compared {
            height: 252px;
        }

        .trend-line-svg {
            width: 100%;
            height: 100%;
            overflow: visible;
        }

        .trend-line-path {
            fill: none;
            stroke-width: 1.45;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .trend-line-area {
            stroke: none;
            opacity: 0.1;
        }

        .trend-line-point {
            stroke-width: 1;
            fill: var(--chart-point-fill);
        }

        .trend-line-point.is-subtle {
            opacity: 0.75;
        }

        .trend-line-axis {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }

        .trend-line-axis-line {
            stroke: var(--chart-axis);
            stroke-width: 0.7;
        }

        .trend-line-grid-line {
            stroke: var(--chart-grid-line);
            stroke-width: 0.5;
            stroke-dasharray: 1.8 2.4;
        }

        .trend-line-y-axis {
            position: absolute;
            inset: 0.8rem auto 1rem 0.5rem;
            width: 2.25rem;
            color: var(--chart-text);
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.01em;
        }

        .trend-line-y-axis-unit {
            position: absolute;
            top: -0.1rem;
            left: 0;
            color: var(--chart-text-strong);
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .trend-line-y-axis-label {
            position: absolute;
            left: 0;
            transform: translateY(50%);
            white-space: nowrap;
        }

        .trend-line-y-axis-label.is-top {
            top: 0;
            transform: none;
        }

        .trend-line-y-axis-label.is-mid {
            top: 50%;
            transform: translateY(-50%);
        }

        .trend-line-y-axis-label.is-bottom {
            bottom: 0;
            transform: none;
        }

        .trend-line-x-axis {
            display: grid;
            gap: 0.35rem;
            padding: 0 0.35rem 0 3rem;
            align-items: start;
        }

        .trend-line-x-axis-label {
            text-align: center;
            color: var(--chart-text-soft);
            font-size: 0.74rem;
            line-height: 1.15;
            font-weight: 700;
        }

        .trend-line-x-axis-label span {
            display: block;
            color: var(--chart-text-muted);
            font-size: 0.68rem;
            font-weight: 600;
        }

        .trend-line-axis-caption {
            display: flex;
            justify-content: space-between;
            gap: 0.7rem;
            padding: 0 0.35rem 0 3rem;
            color: var(--chart-axis-caption);
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .trend-line-price {
            stroke: #9bff76;
        }

        .trend-line-price-fill {
            fill: #9bff76;
        }

        .trend-line-cost {
            stroke: #f7b500;
        }

        .trend-line-cost-fill {
            fill: #f7b500;
        }

        .trend-line-consumption {
            stroke: #61ddff;
        }

        .trend-line-consumption-fill {
            fill: #61ddff;
        }

        .trend-line-maintenance {
            stroke: #ff8faa;
        }

        .trend-line-maintenance-fill {
            fill: #ff8faa;
        }

        .trend-line-total {
            stroke: #4ccf4e;
        }

        .trend-line-total-fill {
            fill: #4ccf4e;
        }

        .empty-state {
            padding: 0.8rem;
            border: 1px dashed var(--table-wrap-border);
            border-radius: 10px;
            color: var(--text-soft);
        }

        .trend-mode {
            display: none;
        }

        .trend-card[data-chart-view="bars"] .trend-mode-bars,
        .trend-card[data-chart-view="line"] .trend-mode-line {
            display: grid;
        }

        @media (max-width: 980px) {
            .analytics-filters-form,
            .kpi-grid,
            .trend-grid {
                grid-template-columns: 1fr;
            }

            .trend-card-header {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell analytics-page">
        <section class="analytics-header">
            <div>
                <h1 class="page-title">Analytics Dashboard</h1>
                <p class="muted">Pilot fuel spend and consumption trends across your selected period.</p>
            </div>
            <div class="analytics-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_export', exportQueryParams) }}">Export CSV</a>
                <a class="btn btn-secondary" href="{{ path('ui_receipt_export', exportQueryParams|merge({ format: 'xlsx' })) }}">Export XLSX</a>
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}">Receipts</a>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_index') }}">Maintenance</a>
            </div>
        </section>
        <p class="muted">Exports keep the current analytics scope so shared files match the dashboard you are looking at.</p>

        <section class="card analytics-filters">
            <div class="analytics-shortcuts">
                {% for shortcut in dateShortcuts %}
                    <a class="btn {{ shortcut.isActive ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ path('ui_analytics_dashboard', shortcut.params) }}">{{ shortcut.label }}</a>
                {% endfor %}
            </div>
            <form class="analytics-filters-form" method="get" action="{{ path('ui_analytics_dashboard') }}">
                <label class="label">
                    From
                    <input class="input" type="text" name="from" value="{{ fromFilter ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
                <label class="label">
                    To
                    <input class="input" type="text" name="to" value="{{ toFilter ?? '' }}" data-datepicker="date" autocomplete="off">
                </label>
                <label class="label">
                    Vehicle
                    <select class="select" name="vehicle_id">
                        <option value="">All vehicles</option>
                        {% for optionId, optionLabel in vehicleOptions %}
                            <option value="{{ optionId }}" {% if vehicleFilter == optionId %}selected{% endif %}>{{ optionLabel }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    Station
                    <select class="select" name="station_id">
                        <option value="">All stations</option>
                        {% for stationOption in stationOptions %}
                            <option value="{{ stationOption.id }}" {% if stationFilter == stationOption.id %}selected{% endif %}>{{ stationOption.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    Fuel type
                    <select class="select" name="fuel_type">
                        <option value="">All fuel types</option>
                        {% for fuelTypeChoice in fuelTypeChoices %}
                            <option value="{{ fuelTypeChoice }}" {% if fuelTypeFilter == fuelTypeChoice %}selected{% endif %}>{{ fuelTypeChoice }}</option>
                        {% endfor %}
                    </select>
                </label>
                <div class="analytics-filter-actions">
                    <button class="btn btn-primary" type="submit">Apply filters</button>
                    <a class="btn btn-secondary" href="{{ path('ui_analytics_dashboard') }}">Reset</a>
                </div>
            </form>
            {% if activeFilterBadges is not empty %}
                <div class="analytics-active-filters">
                    {% for badge in activeFilterBadges %}
                        <span class="pill pill-date">{{ badge }}</span>
                    {% endfor %}
                </div>
            {% endif %}
            <div class="analytics-context-actions">
                <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', receiptQueryParams) }}">Open matching receipts</a>
                {% if selectedVehicleLabel and vehicleFilter %}
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicleFilter}) }}">Open vehicle maintenance</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_vehicle_show', {id: vehicleFilter}) }}">Open vehicle</a>
                {% else %}
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index') }}">Open maintenance</a>
                {% endif %}
                {% if selectedStationLabel and stationFilter %}
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_station_show', {id: stationFilter, return_to: path('ui_analytics_dashboard', analyticsQueryParams)}) }}">Open station</a>
                {% endif %}
            </div>
        </section>

        <section class="kpi-grid">
            <article class="card-subtle kpi-card">
                <div class="kpi-label">Total cost</div>
                <div class="kpi-value">{{ (totalCostCents / 100)|number_format(2, '.', ' ') }} EUR</div>
            </article>
            <article class="card-subtle kpi-card">
                <div class="kpi-label">Fuel volume</div>
                <div class="kpi-value">{{ (totalQuantityMilliLiters / 1000)|number_format(2, '.', ' ') }} L</div>
            </article>
            <article class="card-subtle kpi-card">
                <div class="kpi-label">Average fuel price</div>
                <div class="kpi-value">
                    {% if averagePriceDeciCentsPerLiter is not null %}
                        {{ (averagePriceDeciCentsPerLiter / 1000)|number_format(3, '.', ' ') }} EUR/L
                    {% else %}
                        n/a
                    {% endif %}
                </div>
            </article>
        </section>

        <section class="card map-card">
            <div class="map-card-head">
                <div>
                    <h2>Visited and matched public stations</h2>
                    <p class="muted">Your receipt history stays primary. Public stations appear as a separate helper layer when a close match exists.</p>
                </div>
                <div class="map-card-badges">
                    <span class="pill">{{ stationMap.visitedPoints|length }} visited</span>
                    <span class="pill">{{ stationMap.matchedVisitedCount }} with public match</span>
                    <span class="pill">{{ stationMap.nearbyVisitedCount }} with nearby public</span>
                    <span class="pill">{{ stationMap.publicPoints|length }} public marker{{ stationMap.publicPoints|length == 1 ? '' : 's' }}</span>
                    <span class="pill">{{ stationMap.nearbyPublicPoints|length }} nearby marker{{ stationMap.nearbyPublicPoints|length == 1 ? '' : 's' }}</span>
                </div>
            </div>
            {% if stationMap.visitedPoints is empty %}
                <div class="empty-state">No geocoded station data for current filters.</div>
            {% else %}
                <div class="map-legend">
                    <span class="map-legend-item"><span class="map-legend-dot visited"></span>Visited station from your receipt history</span>
                    <span class="map-legend-item"><span class="map-legend-dot public"></span>Matched public station from the official cache</span>
                    <span class="map-legend-item"><span class="map-legend-dot nearby"></span>Nearby public station not yet visited</span>
                </div>
                <div class="map-canvas" id="analytics-station-map"></div>
                <ul class="station-map-list">
                    {% for point in stationMap.visitedPoints %}
                        <li class="station-map-item">
                            <div class="station-map-item-head">
                                <strong>{{ point.stationName }}</strong>
                                <span class="pill">Visited</span>
                                {% if point.publicMatch is not null %}
                                    <span class="pill">Public match · {{ point.publicMatch.confidence }}</span>
                                {% endif %}
                            </div>
                            <div class="station-map-item-row">
                                <span>{{ point.address }}</span>
                                <span>{{ (point.totalCostCents / 100)|number_format(2, '.', ' ') }} EUR</span>
                                <span>{{ (point.totalQuantityMilliLiters / 1000)|number_format(2, '.', ' ') }} L</span>
                                <span>{{ point.receiptCount }} receipt(s)</span>
                            </div>
                            {% if point.publicMatch is not null %}
                                <div class="station-map-item-match">
                                    {{ point.publicMatch.address }}, {{ point.publicMatch.postalCode }} {{ point.publicMatch.city }}
                                    {% if point.publicMatch.distanceMeters is not null %} · {{ point.publicMatch.distanceMeters }} m away{% endif %}
                                    {% if point.publicMatch.availableFuelLabels is not empty %} · {{ point.publicMatch.availableFuelLabels|join(', ') }}{% endif %}
                                </div>
                            {% endif %}
                            {% if point.nearbyPublicStations is not empty %}
                                <div class="station-map-item-match">
                                    Nearby public:
                                    {% for nearby in point.nearbyPublicStations %}
                                        {{ nearby.address }}, {{ nearby.postalCode }} {{ nearby.city }} · {{ nearby.distanceMeters }} m{% if nearby.availableFuelLabels is not empty %} · {{ nearby.availableFuelLabels|join(', ') }}{% endif %}{% if not loop.last %} | {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
                <script type="application/json" id="analytics-station-map-data">{{ stationMap|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_QUOT'))|raw }}</script>
            {% endif %}
        </section>

        <section class="trend-grid">
            <article class="card trend-card" data-controller="analytics-chart" data-chart-key="cost" data-chart-storage-key="analytics.chartView.cost" data-default-view="bars" data-chart-view="bars" data-chart-runtime-state="idle">
                <div class="trend-card-header">
                    <h2>Cost trend by month</h2>
                    <div class="trend-view-switch">
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="bars">Bars</button>
                        <button class="trend-view-link" type="button" data-action="analytics-chart#switch" data-analytics-chart-target="button" data-view="line">Lines</button>
                    </div>
                </div>
                {% if costTrend is empty %}
                    <div class="empty-state">No cost data for current filters.</div>
                {% else %}
                    {% set costChartLabels = [] %}
                    {% set costChartValues = [] %}
                    {% for item in costTrend %}
                        {% set costChartLabels = costChartLabels|merge([item.month]) %}
                        {% set costChartValues = costChartValues|merge([(item.value / 100)|round(2)]) %}
                    {% endfor %}
                    <script type="application/json" data-analytics-chart-target="config">{{ {
                        key: 'cost',
                        defaultView: 'bars',
                        yAxisLabel: 'EUR',
                        valueFormat: 'currency',
                        labels: costChartLabels,
                        datasets: [
                            {
                                label: 'Cost',
                                data: costChartValues,
                                borderColor: '#f7b500',
                                fillColor: 'rgba(247, 181, 0, 0.16)',
                                barColor: 'rgba(247, 181, 0, 0.88)'
                            }
                        ]
                    }|json_encode|raw }}</script>
                    <div class="trend-mode trend-mode-line trend-line-chart">
                        <div class="trend-chart-shell">
                            <canvas class="trend-chart-canvas" data-analytics-chart-target="canvas"></canvas>
