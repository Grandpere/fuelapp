                    --flash-error-border: rgba(255, 95, 86, 0.5);
                    --flash-error-bg: rgba(103, 33, 40, 0.4);
                    --flash-error-bg-soft: rgba(103, 33, 40, 0.3);
                    --flash-error-text: #ffd6d4;
                    --calendar-bg: #0f2738;
                    --calendar-border: rgba(126, 164, 190, 0.35);
                    --calendar-shadow: 0 18px 40px rgba(0, 0, 0, 0.38);
                    --calendar-weekday: #acc2d1;
                    --calendar-day: #dce7ef;
                    --calendar-day-hover: rgba(247, 181, 0, 0.2);
                    --calendar-time-hover: rgba(250, 250, 250, 0.06);
                    --calendar-arrow: #dbe8f2;
                    --theme-toggle-bg: rgba(17, 40, 58, 0.72);
                    --theme-toggle-border: rgba(147, 178, 200, 0.35);
                    --theme-toggle-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
                    --surface-soft-bg: rgba(8, 26, 38, 0.5);
                    --surface-soft-bg-strong: rgba(6, 26, 38, 0.55);
                    --surface-soft-border: rgba(92, 133, 159, 0.28);
                    --surface-soft-border-strong: rgba(92, 133, 159, 0.35);
                    --surface-chart-bg: linear-gradient(180deg, rgba(13, 39, 55, 0.92), rgba(8, 25, 37, 0.76));
                    --surface-chart-grid: rgba(147, 178, 198, 0.06);
                    --chart-axis: rgba(180, 204, 220, 0.5);
                    --chart-grid-line: rgba(180, 204, 220, 0.24);
                    --chart-point-fill: #08141c;
                    --chart-text: rgba(230, 240, 246, 0.92);
                    --chart-text-strong: rgba(244, 251, 255, 0.98);
                    --chart-text-soft: rgba(230, 240, 246, 0.88);
                    --chart-text-muted: rgba(184, 206, 220, 0.92);
                    --chart-axis-caption: rgba(184, 206, 220, 0.94);
                    --pill-date-bg: rgba(247, 181, 0, 0.2);
                    --pill-date-text: #ffd27a;
                    --pill-odometer-bg: rgba(54, 180, 252, 0.2);
                    --pill-odometer-text: #9fdefe;
                    --radius: 14px;
                    --radius-sm: 10px;
                    --shadow: 0 16px 40px rgba(0, 0, 0, 0.28);
                }

                :root[data-theme="light"] {
                    --bg: #f4f0e8;
                    --bg-muted: #e4edf5;
                    --panel: #ffffff;
                    --panel-strong: #f3f8fc;
                    --page-accent-one: rgba(247, 181, 0, 0.18);
                    --page-accent-two: rgba(54, 180, 252, 0.12);
                    --page-gradient-start: #f7f3eb;
                    --page-gradient-mid: #eef5fb;
                    --page-gradient-end: #f4f8fb;
                    --line: #c6d4de;
                    --text: #173245;
                    --text-soft: #60798b;
                    --text-strong: #102736;
                    --brand-text: #9b5f00;
                    --link-accent: #aa6a00;
                    --nav-surface: rgba(255, 255, 255, 0.82);
                    --nav-border: rgba(112, 139, 160, 0.22);
                    --nav-link-text: #1c3d52;
                    --nav-link-hover-bg: rgba(200, 218, 230, 0.55);
                    --nav-active-text: #0b1d2b;
                    --card-gradient-start: rgba(255, 255, 255, 0.96);
                    --card-gradient-end: rgba(241, 247, 251, 0.96);
                    --card-border: rgba(118, 150, 172, 0.2);
                    --card-subtle-bg: rgba(244, 248, 251, 0.95);
                    --card-subtle-border: rgba(118, 150, 172, 0.18);
                    --btn-secondary-bg: rgba(247, 250, 252, 0.96);
                    --btn-secondary-border: rgba(118, 150, 172, 0.28);
                    --btn-danger-text: #9f2f35;
                    --btn-danger-bg: rgba(255, 233, 234, 0.95);
                    --btn-danger-border: rgba(217, 91, 96, 0.28);
                    --input-bg: rgba(255, 255, 255, 0.98);
                    --input-border: rgba(118, 150, 172, 0.32);
                    --table-wrap-bg: rgba(255, 255, 255, 0.92);
                    --table-wrap-border: rgba(118, 150, 172, 0.22);
                    --table-head-border: rgba(118, 150, 172, 0.2);
                    --table-row-border: rgba(118, 150, 172, 0.14);
                    --table-row-hover: rgba(227, 236, 243, 0.72);
                    --flash-success-border: rgba(66, 169, 113, 0.35);
                    --flash-success-bg: rgba(223, 247, 232, 0.9);
                    --flash-success-text: #14633a;
                    --flash-error-border: rgba(217, 91, 96, 0.32);
                    --flash-error-bg: rgba(255, 235, 236, 0.92);
                    --flash-error-bg-soft: rgba(255, 240, 241, 0.96);
                    --flash-error-text: #9f2f35;
                    --calendar-bg: #ffffff;
                    --calendar-border: rgba(118, 150, 172, 0.24);
                    --calendar-shadow: 0 18px 40px rgba(55, 82, 105, 0.14);
                    --calendar-weekday: #5f7788;
                    --calendar-day: #173245;
                    --calendar-day-hover: rgba(247, 181, 0, 0.16);
                    --calendar-time-hover: rgba(17, 40, 58, 0.06);
                    --calendar-arrow: #5f7788;
                    --theme-toggle-bg: rgba(255, 255, 255, 0.96);
                    --theme-toggle-border: rgba(118, 150, 172, 0.24);
                    --theme-toggle-shadow: 0 10px 24px rgba(55, 82, 105, 0.12);
                    --surface-soft-bg: rgba(247, 250, 252, 0.95);
                    --surface-soft-bg-strong: rgba(241, 247, 251, 0.96);
                    --surface-soft-border: rgba(118, 150, 172, 0.18);
                    --surface-soft-border-strong: rgba(118, 150, 172, 0.24);
                    --surface-chart-bg: linear-gradient(180deg, rgba(243, 248, 252, 0.98), rgba(229, 238, 245, 0.98));
                    --surface-chart-grid: rgba(96, 121, 139, 0.12);
                    --chart-axis: rgba(96, 121, 139, 0.58);
                    --chart-grid-line: rgba(96, 121, 139, 0.28);
                    --chart-point-fill: #ffffff;
                    --chart-text: rgba(16, 39, 54, 0.96);
                    --chart-text-strong: rgba(10, 28, 40, 0.99);
                    --chart-text-soft: rgba(23, 50, 69, 0.92);
                    --chart-text-muted: rgba(61, 85, 103, 0.98);
                    --chart-axis-caption: rgba(61, 85, 103, 0.98);
                    --pill-date-bg: rgba(247, 181, 0, 0.18);
                    --pill-date-text: #8f6400;
                    --pill-odometer-bg: rgba(54, 180, 252, 0.16);
                    --pill-odometer-text: #0f678a;
                    --shadow: 0 18px 44px rgba(55, 82, 105, 0.12);
                }

                * {
                    box-sizing: border-box;
                }

                html,
                body {
                    margin: 0;
                    min-height: 100%;
                }

                body {
                    font-family: var(--font-body);
                    background:
                        radial-gradient(circle at 16% -2%, var(--page-accent-one), transparent 32%),
                        radial-gradient(circle at 92% 0%, var(--page-accent-two), transparent 24%),
                        linear-gradient(180deg, var(--page-gradient-start) 0%, var(--page-gradient-mid) 45%, var(--page-gradient-end) 100%);
                    color: var(--text);
                    line-height: 1.45;
                    transition: background 180ms ease, color 180ms ease;
                }

                a {
                    color: inherit;
                }

                .app-shell {
                    max-width: 1360px;
                    margin: 0 auto;
                    padding: 1.25rem 1rem 2.5rem;
                }

                .topbar {
                    max-width: 1360px;
                    margin: 0 auto;
                    padding: 0.75rem 1rem 0;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    gap: 0.8rem;
                }

                .topbar-brand {
                    font-family: var(--font-display);
                    font-size: 1rem;
                    letter-spacing: 0.03em;
                    color: var(--brand-text);
                    text-decoration: none;
                }

                .topbar-right {
                    display: inline-flex;
                    align-items: center;
                    gap: 0.6rem;
                    color: var(--text-soft);
                    font-size: 0.82rem;
                }

                .topbar-nav {
                    display: inline-flex;
                    align-items: center;
                    gap: 0.35rem;
                    padding: 0.2rem;
                    border: 1px solid var(--nav-border);
                    border-radius: 999px;
                    background: var(--nav-surface);
                }

                .topbar-nav-link {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: 0.35rem 0.72rem;
                    font-size: 0.8rem;
                    font-weight: 700;
                    line-height: 1;
                    color: var(--nav-link-text);
                    text-decoration: none;
                    border-radius: 999px;
                    border: 1px solid transparent;
                    transition: background-color 120ms ease, border-color 120ms ease, color 120ms ease, transform 120ms ease;
                }

                .topbar-nav-link:hover {
                    transform: translateY(-1px);
                    background: var(--nav-link-hover-bg);
                }

                .topbar-nav-link.is-active {
                    color: var(--nav-active-text);
                    background: linear-gradient(120deg, var(--primary) 0%, var(--primary-strong) 100%);
                    border-color: rgba(240, 138, 0, 0.42);
                }

                .page-title {
                    margin: 0;
                    font-family: var(--font-display);
                    font-size: clamp(1.45rem, 2.8vw, 2.2rem);
                    letter-spacing: 0.01em;
                }

                .muted {
                    color: var(--text-soft);
                }

                .card {
                    background: linear-gradient(170deg, var(--card-gradient-start), var(--card-gradient-end));
                    border: 1px solid var(--card-border);
                    border-radius: var(--radius);
                    box-shadow: var(--shadow);
                }

                .card-subtle {
                    background: var(--card-subtle-bg);
                    border: 1px solid var(--card-subtle-border);
                    border-radius: var(--radius-sm);
                }

                .btn {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 0.4rem;
                    white-space: nowrap;
                    border-radius: 999px;
                    padding: 0.56rem 1rem;
                    border: 1px solid transparent;
                    text-decoration: none;
                    font-weight: 700;
                    font-size: 0.9rem;
                    cursor: pointer;
                    transition: transform 120ms ease, box-shadow 150ms ease, border-color 120ms ease, background-color 120ms ease;
                }

                .btn:hover {
                    transform: translateY(-1px);
                }

                .btn:active {
                    transform: translateY(0);
                }

                .btn-primary {
                    color: #0b1d2b;
                    background: linear-gradient(120deg, var(--primary) 0%, var(--primary-strong) 100%);
                    box-shadow: 0 8px 18px rgba(240, 138, 0, 0.28);
                }

                .btn-secondary {
                    color: var(--text);
                    border-color: var(--btn-secondary-border);
                    background: var(--btn-secondary-bg);
                }

                .btn-danger {
                    color: var(--btn-danger-text);
                    border-color: var(--btn-danger-border);
                    background: var(--btn-danger-bg);
                }

                .btn-compact {
                    padding: 0.35rem 0.7rem;
                    font-size: 0.8rem;
                }

                .action-row {
                    display: inline-flex;
                    gap: 0.45rem;
                    align-items: center;
                    flex-wrap: wrap;
                }

                .page-stack {
                    display: grid;
                    gap: 1rem;
                }

                .page-narrow {
                    max-width: 760px;
                    margin: 0 auto;
                }

                .page-medium {
                    max-width: 1080px;
                    margin: 0 auto;
                }

                .content-narrow {
                    max-width: 560px;
                }

                .page-header {
                    display: grid;
                    gap: 0.35rem;
                }

                .page-header-split {
                    display: grid;
                    grid-template-columns: minmax(0, 1fr) auto;
                    gap: 0.8rem;
                    align-items: start;
                }

                .section-card {
                    padding: 1rem;
                    display: grid;
                    gap: 0.8rem;
                }

                .section-header {
                    display: flex;
                    justify-content: space-between;
                    align-items: flex-start;
                    gap: 0.6rem;
                    flex-wrap: wrap;
                }

                .section-title {
                    margin: 0;
                    font-size: 1.05rem;
                    font-family: var(--font-display);
                }

                .section-lead {
                    margin: 0;
                }

                .actions-wrap {
                    display: flex;
                    gap: 0.6rem;
                    flex-wrap: wrap;
                }

                .page-actions {
                    display: flex;
                    gap: 0.6rem;
                    flex-wrap: wrap;
                    align-items: center;
                }

                .form-stack {
                    display: grid;
                    gap: 0.9rem;
                }

                .form-block {
                    padding: 0.9rem;
                    border: 1px solid var(--table-wrap-border);
                }

                .stack-sm {
                    display: grid;
                    gap: 0.5rem;
                }

                .inline-meta {
                    font-size: 0.78rem;
                }

                .flash-list {
                    margin: 0;
                    padding-left: 1.15rem;
                }

                .shell-compact {
                    padding-bottom: 1.5rem;
                }

                .kv-grid {
                    display: grid;
                    grid-template-columns: 180px 1fr;
                    gap: 0.35rem 0.8rem;
                    margin: 0;
                }

                .kv-grid dd {
                    margin: 0;
                }

                .text-right {
                    text-align: right;
                }

                .action-cell {
                    white-space: nowrap;
                }

                .action-cell .action-row {
                    white-space: normal;
                }

                .action-cell-flex {
                    display: flex;
                    gap: 0.45rem;
                    flex-wrap: wrap;
                }

                .row-link {
                    cursor: pointer;
                }

                .status-pill {
                    background: rgba(142, 175, 199, 0.18);
                    border: 1px solid rgba(142, 175, 199, 0.3);
                    color: #1d1405;
                    box-shadow: inset 0 0 0 1px rgba(7, 21, 31, 0.08);
                }

                .status-pill.status-queued,
                .status-pill.status-processing,
                .status-pill.status-processed {
                    background: #b5f05c;
                    border-color: rgba(109, 171, 24, 0.55);
                }

                .status-pill.status-needs_review {
                    background: #ffd27a;
                    border-color: rgba(224, 157, 24, 0.55);
                }

                .status-pill.status-failed {
                    background: #ff7373;
                    border-color: rgba(203, 67, 53, 0.55);
                }

                .status-pill.status-duplicate {
                    background: #9fdefe;
                    border-color: rgba(54, 180, 252, 0.55);
                }

                .text-block-title {
                    margin: 0 0 0.5rem;
                    font-weight: 700;
                }

                .preformatted-block {
                    margin: 0;
                    overflow: auto;
                    white-space: pre-wrap;
                    font-size: 0.82rem;
                }

                .preformatted-block-inline {
                    margin-top: 0.4rem;
                    font-size: 0.78rem;
                }

                .compact-note {
                    font-size: 0.78rem;
                }

                .input,
                .select {
                    width: 100%;
                    appearance: none;
                    border: 1px solid var(--input-border);
                    border-radius: 10px;
                    background: var(--input-bg);
                    color: var(--text);
                    padding: 0.56rem 0.7rem;
                    font: inherit;
                }

                .input:focus,
                .select:focus {
                    outline: none;
                    border-color: rgba(247, 181, 0, 0.85);
                    box-shadow: 0 0 0 3px rgba(247, 181, 0, 0.2);
                }

                .label {
                    display: grid;
                    gap: 0.3rem;
                    align-content: start;
                    font-size: 0.82rem;
                    color: var(--text-soft);
                    font-weight: 600;
                }

                .pill {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    border-radius: 999px;
                    padding: 0.22rem 0.56rem;
                    font-size: 0.73rem;
                    font-weight: 700;
                    line-height: 1;
                    letter-spacing: 0.04em;
                    text-transform: uppercase;
                    border: 1px solid rgba(7, 21, 31, 0.08);
                }

                .pill-energy {
                    color: #1a2b08;
                    background: linear-gradient(120deg, #b5f05c, #86d81a);
                }

                .table-wrap {
                    overflow-x: auto;
                    border-radius: 12px;
                    border: 1px solid var(--table-wrap-border);
                    background: var(--table-wrap-bg);
                }

                table.app-table {
                    width: 100%;
                    border-collapse: collapse;
                    min-width: 980px;
                }

                table.app-table th {
                    text-align: left;
                    font-size: 0.73rem;
                    text-transform: uppercase;
                    letter-spacing: 0.06em;
                    color: var(--text-soft);
                    padding: 0.72rem;
                    border-bottom: 1px solid var(--table-head-border);
                }

                table.app-table td {
                    padding: 0.72rem;
                    border-bottom: 1px solid var(--table-row-border);
                    vertical-align: middle;
                }

                .table-row {
                    transition: background-color 110ms ease;
                }

                .table-row:hover {
                    background: var(--table-row-hover);
                }

                .flash {
                    padding: 0.85rem 1rem;
                    border-radius: 10px;
                    margin-bottom: 1rem;
                    border: 1px solid var(--flash-success-border);
                    background: var(--flash-success-bg);
                    color: var(--flash-success-text);
                }

                .flash.flash-error {
                    border-color: var(--flash-error-border);
                    background: var(--flash-error-bg);
                    color: var(--flash-error-text);
                }

                .flash.flash-error-soft {
                    border-color: var(--flash-error-border);
                    background: var(--flash-error-bg-soft);
                    color: var(--flash-error-text);
                }

                .flash-shell {
                    padding-bottom: 0;
                }

                .card-subtle-block {
                    padding: 0.9rem;
                }

                .metric-grid-spaced {
                    margin-top: 1rem;
                }

                .table-min-740 table.app-table,
                table.app-table.table-min-740 {
                    min-width: 740px;
                }

                .table-min-760 table.app-table,
                table.app-table.table-min-760 {
                    min-width: 760px;
                }

                .table-min-780 table.app-table,
                table.app-table.table-min-780 {
                    min-width: 780px;
                }

                .table-min-860 table.app-table,
                table.app-table.table-min-860 {
                    min-width: 860px;
                }

                .table-min-920 table.app-table,
                table.app-table.table-min-920 {
                    min-width: 920px;
                }

                .table-min-1020 table.app-table,
                table.app-table.table-min-1020 {
                    min-width: 1020px;
                }

                .table-min-1040 table.app-table,
                table.app-table.table-min-1040 {
                    min-width: 1040px;
                }

                .table-min-1080 table.app-table,
                table.app-table.table-min-1080 {
                    min-width: 1080px;
                }

                .table-min-1120 table.app-table,
                table.app-table.table-min-1120 {
                    min-width: 1120px;
                }

                .table-min-1150 table.app-table,
                table.app-table.table-min-1150 {
                    min-width: 1150px;
                }

                .table-min-1180 table.app-table,
                table.app-table.table-min-1180 {
                    min-width: 1180px;
                }

                .pill-soft-success {
                    background: rgba(46, 204, 113, 0.2);
                    color: #84f7b4;
                }

                .pill-soft-danger {
                    background: rgba(255, 95, 86, 0.2);
                    color: #ffb8b3;
                }

                .pill-soft-warning {
                    background: rgba(247, 181, 0, 0.2);
                    color: #ffd17a;
                }

                .pill-soft-info {
                    background: rgba(54, 180, 252, 0.2);
                    color: #9fdefe;
                }

                .icon-btn {
                    padding: 0.35rem 0.7rem;
                    font-size: 0.8rem;
                }

                @media (max-width: 700px) {
                    .kv-grid {
                        grid-template-columns: 1fr;
                    }
                }

                .flatpickr-calendar {
                    background: var(--calendar-bg);
                    border: 1px solid var(--calendar-border);
                    box-shadow: var(--calendar-shadow);
                    border-radius: 12px;
                    color: var(--text);
                }

                .flatpickr-months .flatpickr-month,
                .flatpickr-weekdays,
                .flatpickr-current-month .flatpickr-monthDropdown-months,
                .flatpickr-current-month input.cur-year {
                    color: var(--text);
                    background: transparent;
                }

                .flatpickr-weekday {
                    color: var(--calendar-weekday);
                    font-weight: 600;
                }

                .flatpickr-day {
                    color: var(--calendar-day);
                    border-radius: 8px;
                }

                .flatpickr-day:hover {
                    background: var(--calendar-day-hover);
                    border-color: var(--calendar-day-hover);
                }

                .flatpickr-day.selected,
                .flatpickr-day.startRange,
                .flatpickr-day.endRange {
                    background: linear-gradient(135deg, var(--primary), var(--primary-strong));
                    border-color: var(--primary-strong);
                    color: #0b1d2b;
                }

                .flatpickr-time input,
                .flatpickr-time .flatpickr-am-pm {
                    color: var(--text);
                }

                .flatpickr-time input:hover,
                .flatpickr-time .flatpickr-am-pm:hover {
                    background: var(--calendar-time-hover);
                }

                .numInputWrapper span.arrowUp:after {
                    border-bottom-color: var(--calendar-arrow);
                }

                .numInputWrapper span.arrowDown:after {
                    border-top-color: var(--calendar-arrow);
                }

                .theme-toggle {
                    background: var(--theme-toggle-bg);
                    border-color: var(--theme-toggle-border);
                    box-shadow: var(--theme-toggle-shadow);
                }

                .theme-toggle-label {
                    min-width: 3.9rem;
                }

                .theme-toggle-icon {
                    font-size: 0.95rem;
                    line-height: 1;
                }

                .theme-toggle-floating {
                    position: fixed;
                    top: 1rem;
                    right: 1rem;
                    z-index: 20;
                }

                .form-grid-2 {
                    display: grid;
                    gap: 0.8rem;
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                    align-items: start;
                }

                @media (max-width: 980px) {
                    .app-shell {
                        padding-top: 0.85rem;
                    }

                    .topbar {
                        flex-direction: column;
                        align-items: flex-start;
                    }

                    .topbar-right {
                        flex-wrap: wrap;
                    }

                    .theme-toggle-floating {
                        top: 0.8rem;
                        right: 0.8rem;
                    }
                }

                @media (max-width: 720px) {
                    .form-grid-2 {
                        grid-template-columns: 1fr;
                    }

                    .page-header-split {
                        grid-template-columns: 1fr;
                    }

                    .action-row {
                        flex-direction: column;
                        align-items: stretch;
                    }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% if app.user %}
            {% set currentRoute = app.request.attributes.get('_route')|default('') %}
            <header class="topbar">
                <a class="topbar-brand" href="{{ path('ui_dashboard') }}">FuelApp</a>
                <div class="topbar-right">
                    <nav class="topbar-nav">
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_dashboard' ? 'is-active' : '' }}" href="{{ path('ui_dashboard') }}">Dashboard</a>
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_receipt_' ? 'is-active' : '' }}" href="{{ path('ui_receipt_index') }}">Receipts</a>
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_import_' ? 'is-active' : '' }}" href="{{ path('ui_import_index') }}">Import</a>
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_vehicle_' ? 'is-active' : '' }}" href="{{ path('ui_vehicle_list') }}">Vehicles</a>
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_station_' ? 'is-active' : '' }}" href="{{ path('ui_station_list') }}">Stations</a>
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_public_fuel_station_' ? 'is-active' : '' }}" href="{{ path('ui_public_fuel_station_map') }}">Fuel Map</a>
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_maintenance_' ? 'is-active' : '' }}" href="{{ path('ui_maintenance_index') }}">Maintenance</a>
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_analytics_' ? 'is-active' : '' }}" href="{{ path('ui_analytics_dashboard') }}">Analytics</a>
                        <a class="topbar-nav-link {{ currentRoute starts with 'ui_contact' ? 'is-active' : '' }}" href="{{ path('ui_contact') }}">Contact</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a class="topbar-nav-link {{ currentRoute starts with 'ui_admin_' ? 'is-active' : '' }}" href="{{ path('ui_admin_dashboard') }}">Back-office</a>
                        {% endif %}
                    </nav>
                    <button class="btn btn-secondary btn-compact theme-toggle" type="button" data-theme-toggle>
                        <span class="theme-toggle-icon" data-theme-toggle-icon>🌙</span>
                        <span class="theme-toggle-label" data-theme-toggle-label>Dark</span>
                    </button>
                    <span>{{ app.user.userIdentifier }}</span>
                    <form method="post" action="{{ path('ui_logout') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                        <button class="btn btn-secondary btn-compact" type="submit">Sign out</button>
                    </form>
                </div>
            </header>
        {% else %}
            <button class="btn btn-secondary btn-compact theme-toggle theme-toggle-floating" type="button" data-theme-toggle>
                <span class="theme-toggle-icon" data-theme-toggle-icon>🌙</span>
                <span class="theme-toggle-label" data-theme-toggle-label>Dark</span>
            </button>
        {% endif %}

        {% for label in ['success', 'error'] %}
            {% for message in app.flashes(label) %}
                <section class="app-shell flash-shell">
                    <div class="flash {{ label == 'error' ? 'flash-error' : '' }}">{{ message }}</div>
                </section>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
        <script>
            (function () {
                const storageKey = 'fuelapp-theme';
                const root = document.documentElement;
                const buttons = document.querySelectorAll('[data-theme-toggle]');
                const prefersDarkMedia = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;

                function resolveTheme() {
                    let storedTheme = null;

                    try {
                        storedTheme = window.localStorage.getItem(storageKey);
                    } catch (error) {
                        storedTheme = null;
                    }

                    if (storedTheme === 'light' || storedTheme === 'dark') {
                        return storedTheme;
                    }

                    return prefersDarkMedia && prefersDarkMedia.matches ? 'dark' : 'light';
                }

                function persistTheme(theme) {
                    try {
                        window.localStorage.setItem(storageKey, theme);
                    } catch (error) {
                    }
                }

                function paintTheme(theme) {
                    root.dataset.theme = theme;
                    root.dataset.themeReady = '1';
                    root.style.colorScheme = theme;

                    buttons.forEach(function (button) {
                        const icon = button.querySelector('[data-theme-toggle-icon]');
                        const label = button.querySelector('[data-theme-toggle-label]');
                        const isDark = theme === 'dark';

                        if (icon) {
                            icon.textContent = isDark ? '🌙' : '☀️';
                        }

                        if (label) {
                            label.textContent = isDark ? 'Dark' : 'Light';
                        }

                        button.title = isDark ? 'Switch to light theme' : 'Switch to dark theme';
                        button.setAttribute('aria-label', button.title);
                    });

                    window.dispatchEvent(new CustomEvent('fuelapp:theme-changed', {
                        detail: { theme },
                    }));
                }

                let activeTheme = resolveTheme();
                paintTheme(activeTheme);

                buttons.forEach(function (button) {
                    button.addEventListener('click', function () {
                        activeTheme = activeTheme === 'dark' ? 'light' : 'dark';
                        persistTheme(activeTheme);
                        paintTheme(activeTheme);
                    });
                });

                if (prefersDarkMedia) {
                    const updateFromSystem = function () {
                        let storedTheme = null;

                        try {
                            storedTheme = window.localStorage.getItem(storageKey);
                        } catch (error) {
                            storedTheme = null;
                        }

                        if (storedTheme === 'light' || storedTheme === 'dark') {
                            return;
                        }

                        activeTheme = prefersDarkMedia.matches ? 'dark' : 'light';
                        paintTheme(activeTheme);
                    };

                    if (typeof prefersDarkMedia.addEventListener === 'function') {
                        prefersDarkMedia.addEventListener('change', updateFromSystem);
                    } else if (typeof prefersDarkMedia.addListener === 'function') {
                        prefersDarkMedia.addListener(updateFromSystem);
                    }
                }

                document.addEventListener('turbo:render', function () {
                    paintTheme(activeTheme);
                });
            })();
        </script>
    </body>
</html>
