                    --btn-danger-text: #ffd6d4;
                    --btn-danger-bg: rgba(103, 33, 40, 0.45);
                    --btn-danger-border: rgba(255, 95, 86, 0.45);
                    --input-bg: rgba(5, 20, 30, 0.6);
                    --input-border: rgba(142, 175, 199, 0.34);
                    --table-wrap-bg: rgba(4, 16, 25, 0.36);
                    --table-wrap-border: rgba(108, 149, 176, 0.27);
                    --table-head-border: rgba(118, 155, 179, 0.26);
                    --table-row-border: rgba(98, 137, 162, 0.22);
                    --table-row-hover: rgba(56, 92, 114, 0.22);
