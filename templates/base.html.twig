                    --page-accent-two: rgba(54, 180, 252, 0.18);
                    --page-gradient-start: #07151f;
                    --page-gradient-mid: #081a26;
                    --page-gradient-end: #06131c;
                    --line: #2e5067;
                    --text: #e5eef5;
                    --text-soft: #9bb1c2;
                    --text-strong: #f4fbff;
                    --primary: #f7b500;
                    --primary-strong: #f08a00;
                    --success: #2ecc71;
                    --danger: #ff5f56;
                    --brand-text: #f7c866;
                    --link-accent: #ffd27a;
                    --nav-surface: rgba(9, 28, 42, 0.5);
                    --nav-border: rgba(147, 178, 200, 0.22);
                    --nav-link-text: #d3e4f0;
                    --nav-link-hover-bg: rgba(40, 70, 90, 0.35);
                    --nav-active-text: #0b1d2b;
                    --card-gradient-start: rgba(24, 58, 83, 0.9);
                    --card-gradient-end: rgba(13, 37, 54, 0.9);
