{% extends 'base.html.twig' %}

{% block title %}Import Receipts{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .import-signal {
            display: grid;
            gap: 0.2rem;
            min-width: 210px;
        }

        .import-signal strong {
            font-size: 0.9rem;
        }

        .import-signal span {
            color: var(--text-soft);
            font-size: 0.82rem;
        }

        .import-quick-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
        }

        .import-quick-filters .pill {
            text-decoration: none;
        }

        .import-follow-up {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            align-items: center;
            justify-content: space-between;
        }

        .import-follow-up .actions-wrap {
            margin-top: 0;
        }
    </style>
{% endblock %}

{% block body %}
    {% set uploadSummaries = app.flashes('import_summary') %}
    {% set uploadSummary = uploadSummaries|length > 0 ? uploadSummaries|last : null %}
    {% set returnTo = app.request.requestUri %}
    <main class="app-shell page-stack">
        <header class="page-header-split">
            <div class="page-header">
                <h1 class="page-title">Import Receipts</h1>
                <p class="muted section-lead">Upload a receipt file and let the async OCR pipeline process it.</p>
            </div>
            <div class="page-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}" data-turbo-frame="_top">Receipts</a>
                <a class="btn btn-secondary" href="{{ path('ui_analytics_dashboard') }}" data-turbo-frame="_top">Analytics</a>
            </div>
        </header>

        <section id="import-upload-card" class="card section-card">
            <form method="post" enctype="multipart/form-data" data-turbo-frame="_top" class="form-stack content-narrow">
                <input type="hidden" name="_token" value="{{ csrf_token('ui_import_upload') }}">
                <label class="label">
                    Receipt files (PDF/JPEG/PNG/WEBP) or ZIP archive
                    <input class="input" type="file" name="files[]" accept=".pdf,.zip,image/jpeg,image/png,image/webp" multiple required>
                </label>
                <p class="muted section-lead">
                    Limits: allowed formats are PDF/JPEG/PNG/WEBP, max size is 8 MB for images and 1 MB for PDF, ZIP supports up to 50 entries, and unsafe ZIP paths are rejected.
                </p>
                <div class="actions-wrap">
                    <button class="btn btn-primary" type="submit">Upload and process</button>
                    <a class="btn btn-secondary" href="{{ path('ui_import_index') }}" data-turbo-frame="_top">Refresh</a>
                </div>
            </form>
        </section>

        {% if uploadSummary is iterable %}
            <section class="card section-card">
                <div class="section-header">
                    <div>
                        <h2 class="section-title">Last upload summary</h2>
                        <p class="muted section-lead">
                            {{ uploadSummary.acceptedCount }} queued, {{ uploadSummary.rejectedCount }} rejected.
                        </p>
                    </div>
                </div>

                {% if uploadSummary.accepted|length > 0 %}
                    <div class="form-stack">
                        <p class="text-block-title">Accepted</p>
                        <ul class="flash-list">
                            {% for accepted in uploadSummary.accepted %}
                                <li class="flash">
                                    <strong>{{ accepted.filename }}</strong>
                                    {% if accepted.source != accepted.filename %}
                                        <span class="muted">({{ accepted.source }})</span>
                                    {% endif %}
                                    <span class="muted">queued as {{ accepted.status }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {% if uploadSummary.rejected|length > 0 %}
                    <div class="form-stack">
                        <p class="text-block-title">Rejected</p>
                        <ul class="flash-list">
                            {% for rejected in uploadSummary.rejected %}
                                <li class="flash flash-error">
                                    <strong>{{ rejected.filename }}</strong>
                                    {% if rejected.source != rejected.filename %}
                                        <span class="muted">({{ rejected.source }})</span>
                                    {% endif %}
                                    <span>{{ rejected.reason }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}
            </section>
        {% endif %}

        <section class="card section-card">
            <div class="section-header">
                <div>
                    <h2 class="section-title">My import jobs</h2>
                    <p class="muted section-lead">Track OCR progress, review incomplete imports, and remove stale uploads.</p>
                </div>
            </div>

            <div class="form-stack">
                <div class="import-quick-filters">
                    {% for filter in statusQuickFilters %}
                        <a
                            class="pill {{ filter.isActive ? 'pill-date' : '' }}"
                            href="{{ filter.url }}"
                            data-turbo-frame="_top"
                        >
                            {{ filter.label }}: {{ filter.count }}
                        </a>
                    {% endfor %}
                </div>

                {% if followUpShortcuts|length > 0 %}
                    <div class="card section-card import-follow-up">
                        <div>
                            <p class="text-block-title">Follow up now</p>
                            <p class="muted section-lead">
                                {% if statusFilter %}
                                    Filtered on <strong>{{ statusLabels[statusFilter] ?? statusFilter }}</strong>.
                                {% else %}
                                    Jump straight to the next import that needs attention.
                                {% endif %}
                            </p>
                            <p class="muted section-lead">If an import looks unrecoverable, jump back to the upload box and send a replacement file right away.</p>
                        </div>
                        <div class="actions-wrap">
                            {% for shortcut in followUpShortcuts %}
                                <a class="btn btn-{{ shortcut.variant }} btn-compact" href="{{ shortcut.url }}" data-turbo-frame="_top">{{ shortcut.label }}</a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>

            <div class="table-wrap">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Status</th>
                            <th>Filename</th>
                            <th>MIME</th>
                            <th>Size</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th>Signal</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in jobs %}
                            {% set job = row.job %}
                            <tr
                                class="table-row row-link"
                                data-controller="row-link"
                                data-action="click->row-link#navigate"
                                data-row-link-url-value="{{ path('ui_import_show', {id: job.id.toString, return_to: returnTo}) }}"
                                onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                            >
                                <td>{{ job.id.toString }}</td>
                                <td>
                                    <span class="pill status-pill status-{{ job.status.value }}">
                                        {{ statusLabels[job.status.value] ?? job.status.value }}
                                    </span>
                                </td>
                                <td>{{ job.originalFilename }}</td>
                                <td>{{ job.mimeType }}</td>
                                <td>{{ job.fileSizeBytes }} bytes</td>
                                <td>{{ job.createdAt|date('Y-m-d H:i:s') }}</td>
                                <td>{{ job.updatedAt|date('Y-m-d H:i:s') }}</td>
                                <td>
                                    <div class="import-signal">
                                        <strong>{{ row.summary.headline }}</strong>
                                        <span>{{ row.summary.detail }}</span>
                                    </div>
                                </td>
                                <td class="action-cell">
                                    <div class="action-row" data-row-link-ignore>
                                        <a class="btn btn-{{ row.primaryAction.variant }} btn-compact" href="{{ row.primaryAction.url }}" data-turbo-frame="_top">{{ row.primaryAction.label }}</a>
                                        {% if row.secondaryAction %}
                                            <a class="btn btn-{{ row.secondaryAction.variant }} btn-compact" href="{{ row.secondaryAction.url }}" data-turbo-frame="_top">{{ row.secondaryAction.label }}</a>
                                        {% endif %}
                                        <form method="post" action="{{ path('ui_import_delete', {id: job.id.toString}) }}" data-turbo-frame="_top" onsubmit="return confirm('Delete this import file?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('ui_import_delete_' ~ job.id.toString) }}">
                                            <input type="hidden" name="_redirect" value="{{ returnTo }}">
                                            <button class="btn btn-danger btn-compact" type="submit">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="muted">No imports yet.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
