{% extends 'base.html.twig' %}

{% block title %}{{ 'import.show.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .import-station-suggestion-option {
            display: grid;
            gap: 0.45rem;
            padding: 0.95rem 1rem;
            border-radius: 18px;
            border: 1px solid var(--surface-soft-border);
            background: var(--surface-soft-bg);
            transition: border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
        }

        .import-station-suggestion-option:hover {
            border-color: var(--accent-border);
            background: var(--surface-bg);
        }

        .import-station-suggestion-option.is-selected {
            border-color: var(--accent-border);
            background: color-mix(in srgb, var(--accent-soft-bg) 72%, white 28%);
            box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent-border) 38%, transparent);
        }

        .import-station-suggestion-option .compact-note {
            margin: 0;
        }

        .import-station-suggestion-title {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .import-station-suggestion-selected-badge {
            display: none;
            width: fit-content;
            padding: 0.18rem 0.5rem;
            border-radius: 999px;
            background: color-mix(in srgb, var(--accent-border) 20%, white 80%);
            color: var(--text-strong);
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .import-station-suggestion-option.is-selected .import-station-suggestion-selected-badge {
            display: inline-flex;
        }

        .import-station-selection-state {
            display: none;
            gap: 0.4rem;
            padding: 1rem 1rem 1.05rem;
            border-radius: 18px;
            border: 1px solid color-mix(in srgb, var(--accent-border) 65%, white 35%);
            background: color-mix(in srgb, var(--accent-soft-bg) 78%, white 22%);
        }

        .import-station-selection-state.is-visible {
            display: grid;
        }

        .import-station-selection-label {
            color: var(--text-strong);
            font-size: 0.82rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .import-station-selection-title {
            margin: 0;
            color: var(--text-strong);
            font-size: 1rem;
            font-weight: 700;
            line-height: 1.35;
        }

        .import-station-selection-copy {
            margin: 0;
            color: var(--text-soft);
            line-height: 1.5;
        }

        .import-station-selection-copy strong {
            color: var(--text-strong);
        }

        .import-station-selection-reset {
            width: fit-content;
            margin-top: 0.15rem;
        }

        .import-station-manual-fields {
            overflow: hidden;
            transition: opacity 160ms ease, max-height 220ms ease, transform 220ms ease, margin-top 220ms ease;
            max-height: 40rem;
        }

        .import-station-manual-fields.is-collapsed {
            opacity: 0.42;
            max-height: 0;
            margin-top: -0.2rem;
            transform: translateY(-0.2rem);
            pointer-events: none;
        }
    </style>
{% endblock %}

{% block body %}
    {% set backToImportsUrl = backToImportsUrl is defined and backToImportsUrl is not empty ? backToImportsUrl : path('ui_import_index') %}
    {% set issueList = parsedDraft is not null and parsedDraft.issues is defined and parsedDraft.issues is iterable ? parsedDraft.issues : [] %}
    {% set issuedAtMissing = 'issued_at_missing' in issueList %}
    {% set reviewLines = reviewLines is defined and reviewLines is iterable ? reviewLines : [] %}
    {% set selectedSuggestionValue = selectedSuggestionValue|default('') %}
    {% set finalizedReceiptId = payloadData is not null and payloadData.finalizedReceiptId is defined and payloadData.finalizedReceiptId is not null ? payloadData.finalizedReceiptId : null %}
    {% set duplicateOfImportJobId = payloadData is not null and payloadData.duplicateOfImportJobId is defined and payloadData.duplicateOfImportJobId is not null ? payloadData.duplicateOfImportJobId : null %}
    {% set duplicateOfReceiptId = payloadData is not null and payloadData.duplicateOfReceiptId is defined and payloadData.duplicateOfReceiptId is not null ? payloadData.duplicateOfReceiptId : null %}
    <main class="app-shell page-stack">
        <section class="card section-card">
            <div class="section-header">
                <div>
                    <h1 class="page-title">{{ 'import.show.title'|trans }}</h1>
                    <p class="muted section-lead">{{ 'import.show.lead'|trans }}</p>
                </div>
                <div class="actions-wrap">
                    <a class="btn btn-secondary" href="{{ backToImportsUrl }}" data-turbo-frame="_top">{{ 'import.action.back_to_imports'|trans }}</a>
                    {% if job.status.value == 'needs_review' %}
                        <form id="import-reparse-form" method="post" action="{{ path('ui_import_reparse', {id: job.id.toString}) }}" data-turbo-frame="_top">
                            <input type="hidden" name="_token" value="{{ csrf_token('ui_import_reparse_' ~ job.id.toString) }}">
                            <input type="hidden" name="_return_to" value="{{ backToImportsUrl }}">
                            <button class="btn btn-secondary" type="submit">{{ 'import.show.reparse'|trans }}</button>
                        </form>
                    {% endif %}
                    <form method="post" action="{{ path('ui_import_delete', {id: job.id.toString}) }}" data-turbo-frame="_top" onsubmit="return confirm('{{ 'import.confirm.delete'|trans|e('js') }}');">
                        <input type="hidden" name="_token" value="{{ csrf_token('ui_import_delete_' ~ job.id.toString) }}">
                        <input type="hidden" name="_redirect" value="{{ backToImportsUrl }}">
                        <button class="btn btn-danger" type="submit">{{ 'import.show.delete_import'|trans }}</button>
                    </form>
                </div>
            </div>

            <dl class="kv-grid">
                <dt class="muted">{{ 'import.show.import_id'|trans }}</dt>
                <dd>{{ job.id.toString }}</dd>
                <dt class="muted">{{ 'import.index.col_status'|trans }}</dt>
                <dd>
                    <span class="pill status-pill status-{{ job.status.value }}">
                        {{ ('import.status.' ~ job.status.value)|trans }}
                    </span>
                </dd>
                <dt class="muted">{{ 'import.index.col_filename'|trans }}</dt>
                <dd>{{ job.originalFilename }}</dd>
            </dl>
        </section>

        <section class="card section-card">
            <div class="section-header">
                <div>
                    <p class="text-block-title">{{ 'import.show.what_happened'|trans }}</p>
                    <p class="muted section-lead">{{ statusSummary.lead }}</p>
                </div>
                <span class="pill status-pill status-{{ statusSummary.badge }}">{{ statusSummary.title }}</span>
            </div>
            {% if statusSummary.keyDetails is not empty %}
                <div class="form-stack">
                    <p class="text-block-title">{{ 'import.show.key_details'|trans }}</p>
                    <ul class="flash-list compact-list">
                        {% for detail in statusSummary.keyDetails %}
                            <li>{{ detail }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
            {% if statusSummary.nextSteps is not empty %}
                <div class="form-stack">
                    <p class="text-block-title">{{ 'import.show.what_you_can_do_now'|trans }}</p>
                    <ul class="flash-list compact-list">
                        {% for step in statusSummary.nextSteps %}
                            <li>{{ step }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
            {% if statusActions is not empty %}
                <div class="actions-wrap">
                    {% for action in statusActions %}
                        <a class="btn btn-{{ action.variant }} btn-compact" href="{{ action.url }}" data-turbo-frame="_top">{{ action.label }}</a>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        {% if receiptContinuity is not null %}
            <section class="card section-card">
                <div class="section-header">
                    <div>
                        <p class="text-block-title">{{ receiptContinuity.title }}</p>
                        <p class="muted section-lead">{{ receiptContinuity.lead }}</p>
                    </div>
                </div>
                <ul class="flash-list compact-list">
                    {% for detail in receiptContinuity.details %}
                        <li>{{ detail }}</li>
                    {% endfor %}
                </ul>
                <div class="actions-wrap">
                    {% for action in receiptContinuity.actions %}
                        <a class="btn btn-{{ action.variant }} btn-compact" href="{{ action.url }}" data-turbo-frame="_top">{{ action.label }}</a>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {% if reviewQueue is not null %}
            <section class="card section-card" data-import-review-shortcuts data-previous-url="{{ reviewQueue.previousUrl ?? '' }}" data-next-url="{{ reviewQueue.nextUrl ?? '' }}">
                <div class="section-header">
                    <div>
                        <p class="text-block-title">{{ 'import.show.review_queue'|trans }}</p>
                        <p class="muted section-lead">{{ 'import.show.review_queue_lead'|trans({'%position%': reviewQueue.position, '%total%': reviewQueue.total}) }}</p>
                    </div>
                    <div class="actions-wrap">
                        {% if reviewQueue.previousUrl is not null %}
                            <a class="btn btn-secondary btn-compact" href="{{ reviewQueue.previousUrl }}" data-turbo-frame="_top">{{ 'import.show.previous_review'|trans }}</a>
                        {% endif %}
                        {% if reviewQueue.nextUrl is not null %}
                            <a class="btn btn-secondary btn-compact" href="{{ reviewQueue.nextUrl }}" data-turbo-frame="_top">{{ 'import.show.next_review'|trans }}</a>
                        {% endif %}
                    </div>
                </div>
                <p class="muted compact-note">
                    {{ 'import.show.shortcuts'|trans|raw }}
                </p>
                {% if reviewQueue.previousLabel is not null or reviewQueue.nextLabel is not null %}
                    <div class="actions-wrap">
                        {% if reviewQueue.previousLabel is not null %}
                            <span class="muted compact-note">{{ 'import.show.previous_label'|trans({'%label%': reviewQueue.previousLabel}) }}</span>
                        {% endif %}
                        {% if reviewQueue.nextLabel is not null %}
                            <span class="muted compact-note">{{ 'import.show.next_label'|trans({'%label%': reviewQueue.nextLabel}) }}</span>
                        {% endif %}
                    </div>
                {% endif %}
            </section>
        {% endif %}

        {% if issueList|length > 0 %}
            <section class="card section-card">
                <p class="text-block-title">{{ 'import.show.detected_issues'|trans }}</p>
                <p class="muted section-lead">{{ issueList|join(', ') }}</p>
            </section>
        {% endif %}

        {% if issuedAtMissing %}
            <section class="card section-card">
                <p class="text-block-title">{{ 'import.show.date_required'|trans }}</p>
                <p class="muted section-lead">{{ 'import.show.date_required_lead'|trans }}</p>
            </section>
        {% endif %}

        {% if payloadData is not null and payloadData.fallbackReason is defined %}
            <section class="card section-card">
                <p class="text-block-title">{{ 'import.show.ocr_fallback'|trans }}</p>
                <p class="muted section-lead">
                    {{ payloadData.fallbackNotice is defined ? payloadData.fallbackNotice : ('import.show.ocr_fallback_default'|trans) }}
                </p>
                <div class="actions-wrap">
                    <span class="pill status-pill status-needs_review">{{ payloadData.fallbackStrategy is defined ? payloadData.fallbackStrategy|replace({'_': ' '}) : ('import.show.manual_review'|trans) }}</span>
                    <span class="muted compact-note">{{ payloadData.fallbackReason }}</span>
                </div>
            </section>
        {% endif %}

        {% if job.status.value == 'processed' %}
            <section class="card section-card">
                <p class="text-block-title">{{ 'import.show.import_completed'|trans }}</p>
                <p class="muted section-lead">{{ 'import.show.import_completed_lead'|trans }}</p>
                <div class="actions-wrap">
                    {% if resolvedFinalizedReceiptId is not null %}
                        <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_show', {id: resolvedFinalizedReceiptId}) }}" data-turbo-frame="_top">{{ 'import.action.open_created_receipt'|trans }}</a>
                    {% endif %}
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index') }}" data-turbo-frame="_top">{{ 'action.back_to_receipts'|trans }}</a>
                </div>
            </section>
        {% elseif job.status.value == 'duplicate' %}
            <section class="card section-card">
                <p class="text-block-title">{{ 'import.show.duplicate_import'|trans }}</p>
                <p class="muted section-lead">{{ 'import.show.duplicate_import_lead'|trans }}</p>
                <div class="actions-wrap">
                    {% if resolvedDuplicateReceiptId is not null %}
                        <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_show', {id: resolvedDuplicateReceiptId}) }}" data-turbo-frame="_top">{{ 'import.action.open_existing_receipt'|trans }}</a>
                    {% elseif resolvedDuplicateOriginalImportId is not null %}
                        <a class="btn btn-primary btn-compact" href="{{ path('ui_import_show', {id: resolvedDuplicateOriginalImportId}) }}" data-turbo-frame="_top">{{ (duplicateOfReceiptId is not null ? 'import.action.open_original_import_instead' : 'import.action.open_original_import')|trans }}</a>
                    {% endif %}
                    <a class="btn btn-secondary btn-compact" href="{{ backToImportsUrl }}" data-turbo-frame="_top">{{ 'import.action.back_to_imports'|trans }}</a>
                </div>
            </section>
        {% endif %}

        {% if job.status.value == 'needs_review' %}
            <section class="card section-card">
                <h2 class="section-title">{{ 'import.show.fix_and_finalize'|trans }}</h2>
                <p class="muted section-lead">{{ 'import.show.fix_and_finalize_lead'|trans }}</p>
                <form id="import-finalize-form" method="post" action="{{ path('ui_import_finalize', {id: job.id.toString}) }}" data-turbo-frame="_top" class="form-stack">
                    <input type="hidden" name="_token" value="{{ csrf_token('ui_import_finalize_' ~ job.id.toString) }}">
                    <input type="hidden" name="_return_to" value="{{ backToImportsUrl }}">

                    <div class="form-grid-2">
                        <label class="label">
                            {{ 'import.show.issued_at'|trans }}
                            <span class="muted compact-note">{{ (issuedAtMissing ? 'import.show.issued_at_required_hint' : 'import.show.issued_at_hint')|trans }}</span>
                            <input class="input" type="datetime-local" name="issuedAt" value="{{ creationPayload is not null and creationPayload.issuedAt is defined and creationPayload.issuedAt is not null ? creationPayload.issuedAt|date('Y-m-d\\TH:i') : (parsedDraft is not null and parsedDraft.issuedAt is defined and parsedDraft.issuedAt is not null ? parsedDraft.issuedAt|date('Y-m-d\\TH:i') : '') }}">
                        </label>
                        <label class="label">
                            {{ 'import.show.existing_station_optional'|trans }}
                            <input class="input" type="text" name="stationSearch" value="{{ stationSearch|default('') }}" readonly>
                            <span class="muted compact-note">{{ 'import.show.station_hint'|trans }}</span>
                        </label>
                    </div>

                    {% set existingStationSuggestions = existingStationSuggestions|default([]) %}
                    {% set publicStationSuggestions = publicStationSuggestions|default([]) %}
                    {% if existingStationSuggestions is not empty or publicStationSuggestions is not empty %}
                        <div class="form-stack card-subtle card-subtle-block">
                            <div class="import-station-selection-state {{ selectedStationSuggestion is not null ? 'is-visible' : '' }}" data-import-station-selection-state>
                                <span class="import-station-selection-label">{{ 'receipt.form.station_selection_active'|trans }}</span>
                                <p class="import-station-selection-title" data-import-station-selection-title>{{ selectedStationSuggestion is not null ? selectedStationSuggestion.title : '' }}</p>
                                <p class="import-station-selection-copy" data-import-station-selection-copy>{% if selectedStationSuggestion is not null %}{% if selectedStationSuggestion.kind == 'public' %}<strong>{{ 'import.show.public_selection_prefix'|trans }}</strong> {{ selectedStationSuggestion.meta }} {{ 'import.show.public_selection_suffix'|trans }}{% else %}<strong>{{ 'import.show.existing_selection_prefix'|trans }}</strong> {{ selectedStationSuggestion.meta }} {{ 'import.show.existing_selection_suffix'|trans }}{% endif %}{% endif %}</p>
                                <button class="btn btn-secondary btn-compact import-station-selection-reset" type="button" data-import-station-selection-reset>{{ 'receipt.form.station_selection_reset'|trans }}</button>
                            </div>
                            {% if existingStationSuggestions is not empty %}
                                <p class="text-block-title">{{ 'receipt.form.station_suggestions_existing'|trans }}</p>
                                {% for candidate in existingStationSuggestions %}
                                    {% set candidateValue = 'station:' ~ candidate.sourceId %}
                                    {% set isSelected = selectedSuggestionValue == candidateValue %}
                                    <label class="label import-station-suggestion-option {{ isSelected ? 'is-selected' : '' }}" data-import-suggestion-kind="existing" data-import-suggestion-title="{{ candidate.name }}" data-import-suggestion-meta="{{ candidate.streetName }}, {{ candidate.postalCode }} {{ candidate.city }}">
                                        <span class="import-station-suggestion-title">
                                            <input type="radio" name="selectedSuggestion" value="{{ candidateValue }}" {% if isSelected %}checked{% endif %}>
                                            <strong>{{ 'receipt.form.station_suggestion_existing_badge'|trans }}</strong> {{ candidate.name }} - {{ candidate.streetName }}, {{ candidate.postalCode }} {{ candidate.city }}
                                        </span>
                                        <span class="import-station-suggestion-selected-badge">{{ 'receipt.form.station_suggestion_selected_badge'|trans }}</span>
                                    </label>
                                {% endfor %}
                            {% endif %}
                            {% if publicStationSuggestions is not empty %}
                                <p class="text-block-title">{{ 'receipt.form.station_suggestions_public'|trans }}</p>
                                {% for candidate in publicStationSuggestions %}
                                    {% set candidateValue = 'public:' ~ candidate.sourceId %}
                                    {% set isSelected = selectedSuggestionValue == candidateValue %}
                                    <label class="label import-station-suggestion-option {{ isSelected ? 'is-selected' : '' }}" data-import-suggestion-kind="public" data-import-suggestion-title="{{ candidate.name }}" data-import-suggestion-meta="{{ candidate.postalCode }} {{ candidate.city }}">
                                        <span class="import-station-suggestion-title">
                                            <input type="radio" name="selectedSuggestion" value="{{ candidateValue }}" {% if isSelected %}checked{% endif %}>
                                            <strong>{{ 'receipt.form.station_suggestion_public_badge'|trans }}</strong> {{ candidate.name }}, {{ candidate.postalCode }} {{ candidate.city }}
                                        </span>
                                        <span class="import-station-suggestion-selected-badge">{{ 'receipt.form.station_suggestion_selected_badge'|trans }}</span>
                                        <span class="muted compact-note">{{ 'import.show.public_station_help'|trans }}</span>
                                    </label>
                                {% endfor %}
                            {% endif %}
                            <label class="label">
                                <span class="muted compact-note">
                                    <input type="radio" name="selectedSuggestion" value="" {% if selectedSuggestionValue == '' %}checked{% endif %}>
                                    {{ 'import.show.keep_manual_station_fields'|trans }}
                                </span>
                            </label>
                        </div>
                    {% else %}
                        <input type="hidden" name="selectedSuggestion" value="">
                        <input type="hidden" name="selectedStationId" value="">
                    {% endif %}

                    <div class="form-grid-2 import-station-manual-fields" data-import-station-manual-fields>
                        <label class="label">
                            {{ 'receipt.form.station_name'|trans }}
                            <input class="input" type="text" name="stationName" value="{{ creationPayload is not null and creationPayload.stationName is defined ? creationPayload.stationName : (parsedDraft is not null and parsedDraft.stationName is defined ? parsedDraft.stationName : '') }}">
                        </label>
                        <label class="label">
                            {{ 'receipt.form.station_street_name'|trans }}
                            <input class="input" type="text" name="stationStreetName" value="{{ creationPayload is not null and creationPayload.stationStreetName is defined ? creationPayload.stationStreetName : (parsedDraft is not null and parsedDraft.stationStreetName is defined ? parsedDraft.stationStreetName : '') }}">
                        </label>
                        <label class="label">
                            {{ 'receipt.form.station_postal_code'|trans }}
                            <input class="input" type="text" name="stationPostalCode" value="{{ creationPayload is not null and creationPayload.stationPostalCode is defined ? creationPayload.stationPostalCode : (parsedDraft is not null and parsedDraft.stationPostalCode is defined ? parsedDraft.stationPostalCode : '') }}">
                        </label>
                        <label class="label">
                            {{ 'receipt.form.station_city'|trans }}
                            <input class="input" type="text" name="stationCity" value="{{ creationPayload is not null and creationPayload.stationCity is defined ? creationPayload.stationCity : (parsedDraft is not null and parsedDraft.stationCity is defined ? parsedDraft.stationCity : '') }}">
                        </label>
                        <label class="label">
                            {{ 'import.show.latitude_micro_degrees'|trans }}
                            <input class="input" type="number" name="latitudeMicroDegrees" value="{{ creationPayload is not null and creationPayload.latitudeMicroDegrees is defined ? creationPayload.latitudeMicroDegrees : '' }}" step="1">
                        </label>
                        <label class="label">
                            {{ 'import.show.longitude_micro_degrees'|trans }}
                            <input class="input" type="number" name="longitudeMicroDegrees" value="{{ creationPayload is not null and creationPayload.longitudeMicroDegrees is defined ? creationPayload.longitudeMicroDegrees : '' }}" step="1">
                        </label>
                        <label class="label">
                            {{ 'receipt.form.odometer'|trans }}
                            <input class="input" type="number" name="odometerKilometers" value="{{ creationPayload is not null and creationPayload.odometerKilometers is defined ? creationPayload.odometerKilometers : (parsedDraft is not null and parsedDraft.odometerKilometers is defined ? parsedDraft.odometerKilometers : '') }}" min="0" step="1">
                        </label>
                    </div>

                    <div class="form-stack">
                        <p class="text-block-title">{{ 'import.show.receipt_lines'|trans }}</p>
                        {% if reviewLines|length > 0 %}
                            {% for line in reviewLines %}
                                <section class="card-subtle card-subtle-block">
                                    <p class="compact-note muted">{{ 'import.show.line_number'|trans({'%index%': loop.index}) }}</p>
                                    <div class="form-grid-2">
                                        <label class="label">
                                            {{ 'receipt.form.fuel_type'|trans }}
                                            <input class="input" type="text" name="lines[{{ loop.index0 }}][fuelType]" value="{{ line.fuelType is defined ? line.fuelType : '' }}" placeholder="diesel">
                                        </label>
                                        <label class="label">
                                            {{ 'import.show.quantity_ml'|trans }}
                                            <input class="input" type="number" name="lines[{{ loop.index0 }}][quantityMilliLiters]" value="{{ line.quantityMilliLiters is defined and line.quantityMilliLiters is not null ? line.quantityMilliLiters : '' }}" min="1" step="1">
                                        </label>
                                        <label class="label">
                                            {{ 'import.show.unit_price_deci_cents'|trans }}
                                            <input class="input" type="number" name="lines[{{ loop.index0 }}][unitPriceDeciCentsPerLiter]" value="{{ line.unitPriceDeciCentsPerLiter is defined and line.unitPriceDeciCentsPerLiter is not null ? line.unitPriceDeciCentsPerLiter : '' }}" min="0" step="1">
                                        </label>
                                        <label class="label">
                                            {{ 'import.show.vat_rate'|trans }}
                                            <input class="input" type="number" name="lines[{{ loop.index0 }}][vatRatePercent]" value="{{ line.vatRatePercent is defined and line.vatRatePercent is not null ? line.vatRatePercent : '' }}" min="0" max="100" step="1">
                                        </label>
                                    </div>
                                </section>
                            {% endfor %}
                        {% else %}
                            <section class="card-subtle card-subtle-block">
                                <p class="muted section-lead">{{ 'import.show.no_fuel_lines'|trans }}</p>
                                <div class="form-grid-2">
                                    <label class="label">
                                        {{ 'receipt.form.fuel_type'|trans }}
                                        <input class="input" type="text" name="lines[0][fuelType]" value="" placeholder="diesel">
                                    </label>
                                    <label class="label">
                                        {{ 'import.show.quantity_ml'|trans }}
                                        <input class="input" type="number" name="lines[0][quantityMilliLiters]" value="" min="1" step="1">
                                    </label>
                                    <label class="label">
                                        {{ 'import.show.unit_price_deci_cents'|trans }}
                                        <input class="input" type="number" name="lines[0][unitPriceDeciCentsPerLiter]" value="" min="0" step="1">
                                    </label>
                                    <label class="label">
                                        {{ 'import.show.vat_rate'|trans }}
                                        <input class="input" type="number" name="lines[0][vatRatePercent]" value="" min="0" max="100" step="1">
                                    </label>
                                </div>
                            </section>
                        {% endif %}
                    </div>

                    <div class="actions-wrap">
                        <button class="btn btn-primary" type="submit">{{ 'import.show.finalize_import'|trans }}</button>
                        {% if reviewQueue is not null and reviewQueue.nextUrl is not null %}
                            <button class="btn btn-secondary" type="submit" name="_continue" value="1">{{ 'import.show.finalize_and_open_next'|trans }}</button>
                        {% endif %}
                        <a class="btn btn-secondary" href="{{ backToImportsUrl }}" data-turbo-frame="_top">{{ 'action.cancel'|trans }}</a>
                    </div>
                </form>
            </section>
        {% else %}
            <section class="card section-card">
                <p class="muted section-lead">{{ 'import.show.not_reviewable'|trans }}</p>
            </section>
        {% endif %}

        {% if payloadData is not null %}
            {% if text is not null %}
                <section class="card section-card">
                    <p class="text-block-title">{{ 'import.show.text'|trans }}</p>
                    <pre class="preformatted-block">{{ text }}</pre>
                </section>
            {% endif %}

            <section class="card section-card">
                <p class="text-block-title">{{ 'import.show.raw_payload'|trans }}</p>
                <pre class="preformatted-block">{{ payloadData|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
            </section>
        {% endif %}

        {% if job.status.value == 'needs_review' %}
            <script>
                (() => {
                    const root = document.querySelector('[data-import-review-shortcuts]');
                    if (!root || root.dataset.bound === '1') {
                        return;
                    }

                    root.dataset.bound = '1';

                    const isTypingTarget = (target) => target instanceof HTMLElement
                        && (target.matches('input, textarea, select') || target.isContentEditable);

                    const finalizeForm = document.getElementById('import-finalize-form');
                    const reparseForm = document.getElementById('import-reparse-form');
                    const previousUrl = root.dataset.previousUrl || '';
                    const nextUrl = root.dataset.nextUrl || '';
                    const abortController = new AbortController();

                    document.addEventListener('keydown', (event) => {
                        const typing = isTypingTarget(event.target);

                        if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
                            event.preventDefault();
                            finalizeForm?.requestSubmit();
                            return;
                        }

                        if (typing) {
                            return;
                        }

                        if (event.shiftKey && event.key.toLowerCase() === 'r') {
                            event.preventDefault();
                            reparseForm?.requestSubmit();
                            return;
                        }

                        if (event.key.toLowerCase() === 'j' && nextUrl !== '') {
                            event.preventDefault();
                            window.location.assign(nextUrl);
                            return;
                        }

                        if (event.key.toLowerCase() === 'k' && previousUrl !== '') {
                            event.preventDefault();
                            window.location.assign(previousUrl);
                        }
                    }, { signal: abortController.signal });

                    const radios = Array.from(document.querySelectorAll('#import-finalize-form input[name="selectedSuggestion"]'));
                    const manualFieldsWrapper = document.querySelector('[data-import-station-manual-fields]');
                    const state = document.querySelector('[data-import-station-selection-state]');
                    const stateTitle = document.querySelector('[data-import-station-selection-title]');
                    const stateCopy = document.querySelector('[data-import-station-selection-copy]');
                    const resetButton = document.querySelector('[data-import-station-selection-reset]');
                    const manualRadio = radios.find((radio) => radio.value === '') ?? null;
                    const publicSelectionPrefix = {{ 'import.show.public_selection_prefix'|trans|json_encode|raw }};
                    const publicSelectionSuffix = {{ 'import.show.public_selection_suffix'|trans|json_encode|raw }};
                    const existingSelectionPrefix = {{ 'import.show.existing_selection_prefix'|trans|json_encode|raw }};
                    const existingSelectionSuffix = {{ 'import.show.existing_selection_suffix'|trans|json_encode|raw }};

                    const syncSelectedSuggestionState = () => {
                        if (radios.length === 0 || !manualFieldsWrapper) {
                            return;
                        }

                        const selected = radios.find((radio) => radio.checked);
                        const useSuggestion = !!selected && selected.value !== '';
                        const manualFields = Array.from(manualFieldsWrapper.querySelectorAll('input, select, textarea'));

                        for (const radio of radios) {
                            radio.closest('.import-station-suggestion-option')?.classList.toggle('is-selected', radio.checked && radio.value !== '');
                        }

                        manualFieldsWrapper.classList.toggle('is-collapsed', useSuggestion);

                        for (const field of manualFields) {
                            field.disabled = useSuggestion;
                        }

                        if (!state || !stateTitle || !stateCopy) {
                            return;
                        }

                        if (!useSuggestion) {
                            state.classList.remove('is-visible');
                            stateTitle.textContent = '';
                            stateCopy.textContent = '';

                            return;
                        }

                        const option = selected?.closest('[data-import-suggestion-kind]');
                        const title = option?.dataset.importSuggestionTitle ?? '';
                        const meta = option?.dataset.importSuggestionMeta ?? '';
                        const kind = option?.dataset.importSuggestionKind ?? '';

                        state.classList.add('is-visible');
                        stateTitle.textContent = title;

                        if (kind === 'public') {
                            stateCopy.innerHTML = `<strong>${publicSelectionPrefix}</strong> ${meta} ${publicSelectionSuffix}`;
                        } else {
                            stateCopy.innerHTML = `<strong>${existingSelectionPrefix}</strong> ${meta} ${existingSelectionSuffix}`;
                        }
                    };

                    for (const radio of radios) {
                        radio.addEventListener('change', syncSelectedSuggestionState);
                    }

                    resetButton?.addEventListener('click', () => {
                        if (manualRadio) {
                            manualRadio.checked = true;
                            syncSelectedSuggestionState();
                        }
                    });

                    syncSelectedSuggestionState();

                    document.addEventListener('turbo:before-cache', () => {
                        abortController.abort();
                    }, { once: true });
                })();
            </script>
        {% endif %}
    </main>
{% endblock %}
