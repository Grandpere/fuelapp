{% extends 'base.html.twig' %}

{% block title %}Maintenance{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .maintenance-page {
            display: grid;
            gap: 1rem;
        }

        .maintenance-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .maintenance-header p {
            margin: 0.35rem 0 0;
        }

        .maintenance-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .kpi {
            padding: 0.95rem;
        }

        .kpi-label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--text-soft);
        }

        .kpi-value {
            margin-top: 0.3rem;
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 700;
        }

        .maintenance-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.9fr);
            gap: 1rem;
            align-items: start;
        }

        .panel {
            padding: 1rem;
            display: grid;
            gap: 0.9rem;
        }

        .panel h2 {
            margin: 0;
            font-size: 1.08rem;
        }

        .inline-filter {
            display: flex;
            gap: 0.6rem;
            align-items: end;
            flex-wrap: wrap;
        }

        .inline-filter .label {
            min-width: 250px;
        }

        .timeline-list,
        .planner-list {
            display: grid;
            gap: 0.65rem;
        }

        .timeline-item,
        .planner-item {
            padding: 0.78rem;
            display: grid;
            gap: 0.45rem;
        }

        .item-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.6rem;
            flex-wrap: wrap;
            font-size: 0.94rem;
        }

        .item-sub {
            color: var(--text-soft);
            font-size: 0.83rem;
        }

        .item-meta {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            font-size: 0.8rem;
            color: var(--text-soft);
        }

        .empty-state {
            padding: 0.8rem;
            border: 1px dashed var(--table-wrap-border);
            border-radius: 10px;
            color: var(--text-soft);
        }

        .planner-section {
            display: grid;
            gap: 0.8rem;
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .rule-grid {
            display: grid;
            gap: 0.65rem;
        }

        .rule-item {
            padding: 0.78rem;
            display: grid;
            gap: 0.45rem;
        }

        .pill-reminder-date {
            background: var(--pill-date-bg);
            color: var(--pill-date-text);
        }

        .pill-reminder-odometer {
            background: var(--pill-odometer-bg);
            color: var(--pill-odometer-text);
        }

        .pill-reminder-due {
            background: color-mix(in srgb, var(--accent-strong) 18%, transparent);
            color: var(--accent-strong);
        }

        @media (max-width: 1100px) {
            .maintenance-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 760px) {
            .kpi-grid {
                grid-template-columns: 1fr;
            }

            .inline-filter {
                flex-direction: column;
                align-items: stretch;
            }

            .inline-filter .label {
                min-width: 0;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell maintenance-page">
        <section class="maintenance-header">
            <div>
                <h1 class="page-title">Maintenance</h1>
                <p class="muted">Timeline des interventions, planning à venir et rappels actifs.</p>
            </div>
            <div class="maintenance-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}">Receipts</a>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_plan_new') }}">Add plan</a>
                <a class="btn btn-primary" href="{{ path('ui_maintenance_event_new') }}">Add event</a>
            </div>
        </section>

        {% for message in app.flashes('success') %}
            <div class="flash">{{ message }}</div>
        {% endfor %}

        <section class="card panel">
            <form class="inline-filter" method="get" action="{{ path('ui_maintenance_index') }}">
                <label class="label">
                    Vehicle filter
                    <select class="select" name="vehicle_id">
                        <option value="">All vehicles</option>
                        {% for optionId, optionLabel in vehicleOptions %}
                            <option value="{{ optionId }}" {% if vehicleFilter == optionId %}selected{% endif %}>{{ optionLabel }}</option>
                        {% endfor %}
                    </select>
                </label>
                <button class="btn btn-primary" type="submit">Apply</button>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_index') }}">Reset</a>
            </form>

            <div class="kpi-grid">
                <article class="card-subtle kpi">
                    <div class="kpi-label">Planned ({{ monthStart|date('m/Y') }})</div>
                    <div class="kpi-value">{{ (variance.plannedCostCents / 100)|number_format(2, '.', ' ') }} EUR</div>
                </article>
                <article class="card-subtle kpi">
                    <div class="kpi-label">Actual ({{ monthStart|date('m/Y') }})</div>
                    <div class="kpi-value">{{ (variance.actualCostCents / 100)|number_format(2, '.', ' ') }} EUR</div>
                </article>
                <article class="card-subtle kpi">
                    <div class="kpi-label">Variance ({{ monthStart|date('m/Y') }})</div>
                    <div class="kpi-value">{{ (variance.varianceCents / 100)|number_format(2, '.', ' ') }} EUR</div>
                </article>
            </div>
        </section>

        <section class="maintenance-grid">
            <article class="card panel">
                <h2>Timeline events</h2>
                {% if events is empty %}
                    <div class="empty-state">
                        <p>No maintenance event yet.</p>
                        <div class="actions-wrap">
                            <a class="btn btn-primary" href="{{ path('ui_maintenance_event_new') }}">Add first event</a>
                        </div>
                    </div>
                {% else %}
                    <div class="timeline-list">
                        {% for event in events %}
                            <div class="card-subtle timeline-item">
                                <div class="item-title">
                                    <strong>{{ event.eventType.value|upper }}</strong>
                                    <span class="muted">{{ event.occurredAt|date('d/m/Y H:i') }}</span>
                                </div>
                                <div class="item-sub">{{ vehicleOptions[event.vehicleId] ?? event.vehicleId }}</div>
                                <div class="item-meta">
                                    {% if event.odometerKilometers is not null %}<span>Odometer: {{ event.odometerKilometers }} km</span>{% endif %}
                                    {% if event.totalCostCents is not null %}<span>Cost: {{ (event.totalCostCents / 100)|number_format(2, '.', ' ') }} {{ event.currencyCode }}</span>{% endif %}
                                </div>
                                {% if event.description %}<div class="item-sub">{{ event.description }}</div>{% endif %}
                                <div>
                                    <a class="btn btn-secondary" href="{{ path('ui_maintenance_event_edit', {id: event.id.toString}) }}">Edit</a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>

            <article class="planner-section">
                <section class="card panel">
                    <div class="panel-header">
                        <h2>Planner (upcoming)</h2>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_plan_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">Add plan</a>
                    </div>
                    {% if upcomingPlans is empty %}
                        <div class="empty-state">
                            <p>No upcoming planned cost.</p>
                            <div class="actions-wrap">
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_plan_new') }}">Add first plan</a>
                            </div>
                        </div>
                    {% else %}
                        <div class="planner-list">
                            {% for plan in upcomingPlans|slice(0, 8) %}
                                <div class="card-subtle planner-item">
                                    <div class="item-title">
                                        <strong>{{ plan.label }}</strong>
                                        <span class="muted">{{ plan.plannedFor|date('d/m/Y') }}</span>
                                    </div>
                                    <div class="item-sub">{{ vehicleOptions[plan.vehicleId] ?? plan.vehicleId }}</div>
                                    <div class="item-meta">
                                        <span>Budget: {{ (plan.plannedCostCents / 100)|number_format(2, '.', ' ') }} {{ plan.currencyCode }}</span>
                                        {% if plan.eventType is not null %}<span>Type: {{ plan.eventType.value|upper }}</span>{% endif %}
                                    </div>
                                    {% if plan.notes %}<div class="item-sub">{{ plan.notes }}</div>{% endif %}
                                    <div>
                                        <a class="btn btn-secondary" href="{{ path('ui_maintenance_plan_edit', {id: plan.id.toString}) }}">Edit</a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>

                <section class="card panel">
                    <div class="panel-header">
                        <h2>Reminder rules</h2>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_rule_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">Add rule</a>
                    </div>
                    {% if reminderRules is empty %}
                        <div class="empty-state">
                            <p>No reminder rule yet. Add one to start generating due reminders from time or mileage.</p>
                            <div class="actions-wrap">
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_rule_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">Add first rule</a>
                            </div>
                        </div>
                    {% else %}
                        <div class="rule-grid">
                            {% for rule in reminderRules %}
                                <div class="card-subtle rule-item">
                                    <div class="item-title">
                                        <strong>{{ rule.name }}</strong>
                                        <span class="muted">{{ vehicleOptions[rule.vehicleId] ?? rule.vehicleId }}</span>
                                    </div>
                                    {% set insight = ruleInsights[rule.id.toString] ?? null %}
                                    <div class="item-meta">
                                        <span>Trigger: {{ rule.triggerMode.value|replace({'_': ' '})|upper }}</span>
                                        {% if rule.intervalDays is not null %}<span>Every {{ rule.intervalDays }} day{% if rule.intervalDays > 1 %}s{% endif %}</span>{% endif %}
                                        {% if rule.intervalKilometers is not null %}<span>Every {{ rule.intervalKilometers }} km</span>{% endif %}
                                        {% if rule.eventType is not null %}<span>Suggested event: {{ rule.eventType.value|upper }}</span>{% endif %}
                                        {% if insight and insight.isDue %}<span class="pill pill-reminder-due">Due now</span>{% endif %}
                                    </div>
                                    {% if insight and insight.message %}
                                        <div class="item-sub">{{ insight.message }}</div>
                                    {% endif %}
                                    {% if insight and insight.lastEventSummary %}
                                        <div class="item-sub">{{ insight.lastEventSummary }}</div>
                                    {% endif %}
                                    <div class="actions-wrap">
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_rule_edit', {id: rule.id.toString}) }}">Edit</a>
                                        <form method="post" action="{{ path('ui_maintenance_rule_delete', {id: rule.id.toString}) }}" data-turbo-confirm="Delete reminder rule '{{ rule.name }}'?" style="display:inline-flex;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('maintenance_rule_delete_' ~ rule.id.toString) }}">
                                            <button class="btn btn-secondary btn-compact" type="submit">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>

                <section class="card panel">
                    <div class="panel-header">
                        <h2>Triggered reminders</h2>
                        {% if reminderRules is not empty %}
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_rule_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">Add another rule</a>
                        {% endif %}
                    </div>
                    {% if reminders is empty %}
                        <div class="empty-state">
                            {% if reminderRules is empty %}
                                <p>No triggered reminder yet because no reminder rule is configured for this scope.</p>
                            {% elseif dueRuleCount > 0 %}
                                <p>No triggered reminder is listed yet, but at least one rule is already due. They will appear here as soon as reminders are generated.</p>
                            {% else %}
                                <p>No triggered reminder yet. Your rules are being tracked, but none is due right now.</p>
                            {% endif %}
                            <div class="actions-wrap">
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_rule_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">Add a rule</a>
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_plan_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">Add a plan</a>
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_event_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">Add an event</a>
                            </div>
                        </div>
                    {% else %}
                        <div class="planner-list">
                            {% for reminder in reminders|slice(0, 8) %}
                                <div class="card-subtle planner-item">
                                    <div class="item-title">
                                        <strong>{{ ruleNames[reminder.ruleId] ?? reminder.ruleId }}</strong>
                                        <span class="muted">{{ reminder.createdAt|date('d/m/Y H:i') }}</span>
                                    </div>
                                    <div class="item-sub">{{ vehicleOptions[reminder.vehicleId] ?? reminder.vehicleId }}</div>
                                    <div class="item-meta">
                                        {% if reminder.dueAtDate is not null %}<span>Due date: {{ reminder.dueAtDate|date('d/m/Y') }}</span>{% endif %}
                                        {% if reminder.dueAtOdometerKilometers is not null %}<span>Due odometer: {{ reminder.dueAtOdometerKilometers }} km</span>{% endif %}
                                        {% if reminder.dueByDate %}<span class="pill pill-reminder-date">Date due</span>{% endif %}
                                        {% if reminder.dueByOdometer %}<span class="pill pill-reminder-odometer">Odometer due</span>{% endif %}
                                    </div>
                                    {% set ruleDetail = ruleDetails[reminder.ruleId] ?? null %}
                                    {% if ruleDetail %}
                                        <div class="item-sub">
                                            Trigger: {{ ruleDetail.triggerMode|replace({'_': ' '})|upper }}
                                            {% if ruleDetail.intervalDays %}
                                                · every {{ ruleDetail.intervalDays }} day{% if ruleDetail.intervalDays > 1 %}s{% endif %}
                                            {% endif %}
                                            {% if ruleDetail.intervalKilometers %}
                                                · every {{ ruleDetail.intervalKilometers }} km
                                            {% endif %}
                                            {% if ruleDetail.eventType %}
                                                · suggested event {{ ruleDetail.eventType|upper }}
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    {% set logEventParams = {vehicle_id: reminder.vehicleId} %}
                                    {% if ruleDetail and ruleDetail.eventType %}
                                        {% set logEventParams = logEventParams|merge({event_type: ruleDetail.eventType}) %}
                                    {% endif %}
                                    <div class="actions-wrap">
                                        <a class="btn btn-primary btn-compact" href="{{ path('ui_maintenance_event_new', logEventParams) }}">Log event now</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_vehicle_show', {id: reminder.vehicleId}) }}">Open vehicle</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: reminder.vehicleId}) }}">Vehicle timeline</a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>
            </article>
        </section>
    </main>
{% endblock %}
