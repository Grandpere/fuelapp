{% extends 'base.html.twig' %}

{% block title %}{{ 'maintenance_dashboard.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .maintenance-page {
            display: grid;
            gap: 1rem;
        }

        .maintenance-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .maintenance-header p {
            margin: 0.35rem 0 0;
        }

        .maintenance-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .scan-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .lifecycle-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .kpi {
            padding: 0.95rem;
        }

        .scan-card {
            padding: 0.95rem;
            display: grid;
            gap: 0.45rem;
        }

        .scan-card.is-alert {
            border-color: color-mix(in srgb, var(--accent-strong) 38%, var(--table-wrap-border));
            box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent-strong) 14%, transparent);
        }

        .scan-copy {
            color: var(--text-soft);
            font-size: 0.88rem;
        }

        .lifecycle-copy {
            color: var(--text-soft);
            font-size: 0.82rem;
        }

        .kpi-label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--text-soft);
        }

        .kpi-value {
            margin-top: 0.3rem;
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 700;
        }

        .maintenance-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.9fr);
            gap: 1rem;
            align-items: start;
        }

        .panel {
            padding: 1rem;
            display: grid;
            gap: 0.9rem;
        }

        .panel h2 {
            margin: 0;
            font-size: 1.08rem;
        }

        .inline-filter {
            display: flex;
            gap: 0.6rem;
            align-items: end;
            flex-wrap: wrap;
        }

        .inline-filter .label {
            min-width: 250px;
        }

        .timeline-list,
        .planner-list {
            display: grid;
            gap: 0.65rem;
        }

        .timeline-item,
        .planner-item {
            padding: 0.78rem;
            display: grid;
            gap: 0.45rem;
        }

        .item-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.6rem;
            flex-wrap: wrap;
            font-size: 0.94rem;
        }

        .item-sub {
            color: var(--text-soft);
            font-size: 0.83rem;
        }

        .item-meta {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            font-size: 0.8rem;
            color: var(--text-soft);
        }

        .empty-state {
            padding: 0.8rem;
            border: 1px dashed var(--table-wrap-border);
            border-radius: 10px;
            color: var(--text-soft);
        }

        .planner-section {
            display: grid;
            gap: 0.8rem;
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .rule-grid {
            display: grid;
            gap: 0.65rem;
        }

        .rule-item {
            padding: 0.78rem;
            display: grid;
            gap: 0.45rem;
        }

        .pill-reminder-date {
            background: var(--pill-date-bg);
            color: var(--pill-date-text);
        }

        .pill-reminder-odometer {
            background: var(--pill-odometer-bg);
            color: var(--pill-odometer-text);
        }

        .pill-reminder-due {
            background: color-mix(in srgb, var(--accent-strong) 18%, transparent);
            color: var(--accent-strong);
        }

        .pill-maintenance-recent {
            background: color-mix(in srgb, var(--success) 16%, transparent);
            color: var(--success);
        }

        .pill-maintenance-soon {
            background: color-mix(in srgb, var(--warning) 18%, transparent);
            color: var(--warning);
        }

        .pill-maintenance-later {
            background: color-mix(in srgb, var(--text-soft) 16%, transparent);
            color: var(--text-soft);
        }

        @media (max-width: 1100px) {
            .maintenance-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 760px) {
            .kpi-grid {
                grid-template-columns: 1fr;
            }

            .scan-grid {
                grid-template-columns: 1fr;
            }

            .lifecycle-grid {
                grid-template-columns: 1fr;
            }

            .inline-filter {
                flex-direction: column;
                align-items: stretch;
            }

            .inline-filter .label {
                min-width: 0;
            }
        }
    </style>
{% endblock %}

{% block body %}
    {% set maintenanceReturnTo = app.request.requestUri %}
    <main class="app-shell maintenance-page">
        <section class="maintenance-header">
            <div>
                <h1 class="page-title">{{ 'maintenance_dashboard.title'|trans }}</h1>
                <p class="muted">{{ 'maintenance_dashboard.lead'|trans }}</p>
            </div>
            <div class="maintenance-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}">{{ 'nav.receipts'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_plan_new') }}">{{ 'maintenance.plan_form.title_new'|trans }}</a>
                <a class="btn btn-primary" href="{{ path('ui_maintenance_event_new') }}">{{ 'maintenance.event_form.title_new'|trans }}</a>
            </div>
        </section>

        {% for message in app.flashes('success') %}
            <div class="flash">{{ message|trans }}</div>
        {% endfor %}

        <section class="card panel">
            <form class="inline-filter" method="get" action="{{ path('ui_maintenance_index') }}">
                <label class="label">
                    {{ 'maintenance_dashboard.vehicle_filter'|trans }}
                    <select class="select" name="vehicle_id">
                        <option value="">{{ 'analytics.vehicle_all'|trans }}</option>
                        {% for optionId, optionLabel in vehicleOptions %}
                            <option value="{{ optionId }}" {% if vehicleFilter == optionId %}selected{% endif %}>{{ optionLabel }}</option>
                        {% endfor %}
                    </select>
                </label>
                <button class="btn btn-primary" type="submit">{{ 'action.apply'|trans }}</button>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_index') }}">{{ 'action.reset'|trans }}</a>
            </form>

            <div class="kpi-grid">
                <article class="card-subtle kpi">
                    <div class="kpi-label">{{ 'maintenance_dashboard.planned_month'|trans({'%month%': monthStart|date('m/Y')}) }}</div>
                    <div class="kpi-value">{{ (variance.plannedCostCents / 100)|number_format(2, '.', ' ') }} EUR</div>
                </article>
                <article class="card-subtle kpi">
                    <div class="kpi-label">{{ 'maintenance_dashboard.actual_month'|trans({'%month%': monthStart|date('m/Y')}) }}</div>
                    <div class="kpi-value">{{ (variance.actualCostCents / 100)|number_format(2, '.', ' ') }} EUR</div>
                </article>
                <article class="card-subtle kpi">
                    <div class="kpi-label">{{ 'maintenance_dashboard.variance_month'|trans({'%month%': monthStart|date('m/Y')}) }}</div>
                    <div class="kpi-value">{{ (variance.varianceCents / 100)|number_format(2, '.', ' ') }} EUR</div>
                </article>
            </div>

            <div class="scan-grid">
                <article class="card-subtle scan-card {% if reminders|length > 0 %}is-alert{% endif %}">
                    <div class="kpi-label">{{ 'maintenance_dashboard.attention_now'|trans }}</div>
                    <div class="kpi-value">{{ reminders|length }}</div>
                    <div class="scan-copy">
                        {% if reminders|length > 0 %}
                            {{ (reminders|length > 1 ? 'maintenance_dashboard.attention_now_plural' : 'maintenance_dashboard.attention_now_single')|trans }}
                        {% else %}
                            {{ 'maintenance_dashboard.attention_now_empty'|trans }}
                        {% endif %}
                    </div>
                </article>
                <article class="card-subtle scan-card {% if dueSoonPlanCount > 0 %}is-alert{% endif %}">
                    <div class="kpi-label">{{ 'maintenance_dashboard.due_soon'|trans }}</div>
                    <div class="kpi-value">{{ dueSoonPlanCount }}</div>
                    <div class="scan-copy">
                        {{ 'maintenance_dashboard.due_soon_items'|trans({'%plural%': dueSoonPlanCount > 1 ? 's' : '', '%suffix%': dueSoonPlanCount > 1 ? 's' : ''}) }}
                    </div>
                </article>
                <article class="card-subtle scan-card">
                    <div class="kpi-label">{{ 'maintenance_dashboard.recently_handled'|trans }}</div>
                    <div class="kpi-value">{{ recentEventCount }}</div>
                    <div class="scan-copy">
                        {{ 'maintenance_dashboard.recently_handled_items'|trans({'%suffix%': recentEventCount > 1 ? 's' : ''}) }}
                    </div>
                </article>
            </div>

            <div class="lifecycle-grid">
                <article class="card-subtle scan-card">
                    <div class="kpi-label">{{ 'maintenance_dashboard.configured'|trans }}</div>
                    <div class="kpi-value">{{ configuredRuleCount }}</div>
                    <div class="lifecycle-copy">{{ 'maintenance_dashboard.configured_lead'|trans }}</div>
                </article>
                <article class="card-subtle scan-card">
                    <div class="kpi-label">{{ 'maintenance_dashboard.watching'|trans }}</div>
                    <div class="kpi-value">{{ watchingRuleCount }}</div>
                    <div class="lifecycle-copy">{{ 'maintenance_dashboard.watching_lead'|trans }}</div>
                </article>
                <article class="card-subtle scan-card {% if dueSoonRuleCount > 0 %}is-alert{% endif %}">
                    <div class="kpi-label">{{ 'maintenance_dashboard.due_soon'|trans }}</div>
                    <div class="kpi-value">{{ dueSoonRuleCount }}</div>
                    <div class="lifecycle-copy">{{ 'maintenance_dashboard.due_soon_lead'|trans }}</div>
                </article>
                <article class="card-subtle scan-card {% if dueRuleCount > 0 %}is-alert{% endif %}">
                    <div class="kpi-label">{{ 'maintenance_dashboard.due_now'|trans }}</div>
                    <div class="kpi-value">{{ dueRuleCount }}</div>
                    <div class="lifecycle-copy">{{ 'maintenance_dashboard.due_now_lead'|trans }}</div>
                </article>
            </div>
        </section>

        <section class="maintenance-grid">
            <article class="card panel">
                <h2>{{ 'maintenance_dashboard.timeline_events'|trans }}</h2>
                {% if events is empty %}
                        <div class="empty-state">
                            <p>{{ 'maintenance_dashboard.no_maintenance_event_yet'|trans }}</p>
                            <div class="actions-wrap">
                                <a class="btn btn-primary" href="{{ path('ui_maintenance_event_new', vehicleFilter ? {vehicle_id: vehicleFilter, return_to: maintenanceReturnTo} : {return_to: maintenanceReturnTo}) }}">{{ 'vehicle.show.add_first_event'|trans }}</a>
                                {% if vehicleFilter %}
                                    <a class="btn btn-secondary" href="{{ path('ui_vehicle_show', {id: vehicleFilter}) }}">{{ 'analytics.open_vehicle'|trans }}</a>
                                {% endif %}
                            </div>
                        </div>
                {% else %}
                    <div class="timeline-list">
                        {% for event in events %}
                            <div class="card-subtle timeline-item">
                                <div class="item-title">
                                    <strong>{{ event.eventType.value|upper }}</strong>
                                    <div class="show-action-list">
                                        {% if event.occurredAt >= recentEventCutoff %}
                                            <span class="pill pill-maintenance-recent">{{ 'maintenance_dashboard.handled_recently'|trans }}</span>
                                        {% endif %}
                                        <span class="muted">{{ event.occurredAt|date('d/m/Y H:i') }}</span>
                                    </div>
                                </div>
                                <div class="item-sub">{{ vehicleOptions[event.vehicleId] ?? event.vehicleId }}</div>
                                <div class="item-meta">
                                    {% if event.odometerKilometers is not null %}<span>{{ 'vehicle.show.odometer'|trans({'%odometer%': event.odometerKilometers}) }}</span>{% endif %}
                                    {% if event.totalCostCents is not null %}<span>{{ 'vehicle.show.cost'|trans({'%amount%': (event.totalCostCents / 100)|number_format(2, '.', ' '), '%currency%': event.currencyCode}) }}</span>{% endif %}
                                </div>
                                {% if event.description %}<div class="item-sub">{{ event.description }}</div>{% endif %}
                                <div class="actions-wrap">
                                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_event_edit', {id: event.id.toString, return_to: maintenanceReturnTo}) }}">{{ 'action.edit'|trans }}</a>
                                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_vehicle_show', {id: event.vehicleId}) }}">{{ 'analytics.open_vehicle'|trans }}</a>
                                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {vehicle_id: event.vehicleId}) }}">{{ 'nav.receipts'|trans }}</a>
                                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {vehicle_id: event.vehicleId}) }}">{{ 'nav.analytics'|trans }}</a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>

            <article class="planner-section">
                <section class="card panel">
                    <div class="panel-header">
                        <h2>{{ 'maintenance_dashboard.planner_upcoming'|trans }}</h2>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_plan_new', vehicleFilter ? {vehicle_id: vehicleFilter, return_to: maintenanceReturnTo} : {return_to: maintenanceReturnTo}) }}">{{ 'maintenance.plan_form.title_new'|trans }}</a>
                    </div>
                    {% if upcomingPlans is empty %}
                        <div class="empty-state">
                            <p>{{ 'maintenance_dashboard.no_upcoming_planned_cost'|trans }}</p>
                            <div class="actions-wrap">
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_plan_new', vehicleFilter ? {vehicle_id: vehicleFilter, return_to: maintenanceReturnTo} : {return_to: maintenanceReturnTo}) }}">{{ 'vehicle.show.add_first_plan'|trans }}</a>
                                {% if vehicleFilter %}
                                    <a class="btn btn-secondary" href="{{ path('ui_vehicle_show', {id: vehicleFilter}) }}">{{ 'analytics.open_vehicle'|trans }}</a>
                                {% endif %}
                            </div>
                        </div>
                    {% else %}
                        <div class="planner-list">
                            {% for plan in upcomingPlans|slice(0, 8) %}
                                <div class="card-subtle planner-item">
                                <div class="item-title">
                                    <strong>{{ plan.label }}</strong>
                                    <div class="show-action-list">
                                        {% if plan.plannedFor <= soonPlanCutoff %}
                                            <span class="pill pill-maintenance-soon">{{ 'maintenance_dashboard.due_soon'|trans }}</span>
                                        {% else %}
                                            <span class="pill pill-maintenance-later">{{ 'maintenance_dashboard.later'|trans }}</span>
                                        {% endif %}
                                        <span class="muted">{{ plan.plannedFor|date('d/m/Y') }}</span>
                                    </div>
                                </div>
                                    <div class="item-sub">{{ vehicleOptions[plan.vehicleId] ?? plan.vehicleId }}</div>
                                    <div class="item-meta">
                                        <span>{{ 'vehicle.show.budget'|trans({'%amount%': (plan.plannedCostCents / 100)|number_format(2, '.', ' '), '%currency%': plan.currencyCode}) }}</span>
                                        {% if plan.eventType is not null %}<span>{{ 'maintenance_dashboard.suggested_event'|trans({'%event%': plan.eventType.value|upper}) }}</span>{% endif %}
                                    </div>
                                    {% if plan.notes %}<div class="item-sub">{{ plan.notes }}</div>{% endif %}
                                    <div class="actions-wrap">
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_plan_edit', {id: plan.id.toString, return_to: maintenanceReturnTo}) }}">{{ 'action.edit'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_vehicle_show', {id: plan.vehicleId}) }}">{{ 'analytics.open_vehicle'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {vehicle_id: plan.vehicleId}) }}">{{ 'nav.receipts'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {vehicle_id: plan.vehicleId}) }}">{{ 'nav.analytics'|trans }}</a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>

                <section class="card panel">
                    <div class="panel-header">
                        <h2>{{ 'maintenance_dashboard.reminder_rules'|trans }}</h2>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_rule_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">{{ 'maintenance.rule_form.title_new'|trans }}</a>
                    </div>
                    {% if reminderRules is empty %}
                        <div class="empty-state">
                            <p>{{ 'maintenance_dashboard.no_reminder_rule_yet'|trans }}</p>
                            <div class="actions-wrap">
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_rule_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">{{ 'maintenance.rule_form.title_new'|trans }}</a>
                                {% if vehicleFilter %}
                                    <a class="btn btn-secondary" href="{{ path('ui_vehicle_show', {id: vehicleFilter}) }}">{{ 'analytics.open_vehicle'|trans }}</a>
                                {% endif %}
                            </div>
                        </div>
                    {% else %}
                        <div class="rule-grid">
                            {% for rule in reminderRules %}
                                <div class="card-subtle rule-item">
                                    <div class="item-title">
                                        <strong>{{ rule.name }}</strong>
                                        <span class="muted">{{ vehicleOptions[rule.vehicleId] ?? rule.vehicleId }}</span>
                                    </div>
                                    {% set insight = ruleInsights[rule.id.toString] ?? null %}
                                    {% set lifecycle = ruleLifecycle[rule.id.toString] ?? null %}
                                    <div class="item-meta">
                                        <span>{{ 'maintenance_dashboard.trigger'|trans({'%mode%': rule.triggerMode.value|replace({'_': ' '})|upper}) }}</span>
                                        {% if rule.intervalDays is not null %}<span>{{ (rule.intervalDays > 1 ? 'maintenance_dashboard.every_days_plural' : 'maintenance_dashboard.every_days')|trans({'%count%': rule.intervalDays}) }}</span>{% endif %}
                                        {% if rule.intervalKilometers is not null %}<span>{{ 'maintenance_dashboard.every_kilometers'|trans({'%count%': rule.intervalKilometers}) }}</span>{% endif %}
                                        {% if rule.eventType is not null %}<span>{{ 'maintenance_dashboard.suggested_event'|trans({'%event%': rule.eventType.value|upper}) }}</span>{% endif %}
                                        {% if lifecycle %}<span class="pill {{ lifecycle.badgeClass }}">{{ lifecycle.label }}</span>{% endif %}
                                    </div>
                                    {% if lifecycle and lifecycle.detail %}
                                        <div class="item-sub">{{ lifecycle.detail }}</div>
                                    {% endif %}
                                    {% if insight and insight.message %}
                                        <div class="item-sub">{{ insight.message }}</div>
                                    {% endif %}
                                    {% if insight and insight.lastEventSummary %}
                                        <div class="item-sub">{{ insight.lastEventSummary }}</div>
                                    {% endif %}
                                    <div class="actions-wrap">
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_rule_edit', {id: rule.id.toString}) }}">{{ 'action.edit'|trans }}</a>
                                        <form method="post" action="{{ path('ui_maintenance_rule_delete', {id: rule.id.toString}) }}" data-turbo-confirm="{{ 'maintenance_dashboard.delete_rule_confirm'|trans({'%name%': rule.name}) }}" style="display:inline-flex;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('maintenance_rule_delete_' ~ rule.id.toString) }}">
                                            <button class="btn btn-secondary btn-compact" type="submit">{{ 'action.delete'|trans }}</button>
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>

                <section class="card panel">
                    <div class="panel-header">
                        <h2>{{ 'maintenance_dashboard.triggered_reminders'|trans }}</h2>
                        {% if reminderRules is not empty %}
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_rule_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">{{ 'maintenance_dashboard.add_another_rule'|trans }}</a>
                        {% endif %}
                    </div>
                    {% if reminders is empty %}
                        <div class="empty-state">
                            {% if reminderRules is empty %}
                                <p>{{ 'maintenance_dashboard.no_triggered_reminder_without_rules'|trans }}</p>
                            {% elseif dueRuleCount > 0 %}
                                <p>{{ 'maintenance_dashboard.no_triggered_reminder_due_rules'|trans }}</p>
                            {% else %}
                                <p>{{ 'maintenance_dashboard.no_triggered_reminder_tracking'|trans }}</p>
                            {% endif %}
                            <div class="actions-wrap">
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_rule_new', vehicleFilter ? {vehicle_id: vehicleFilter} : {}) }}">{{ 'maintenance.rule_form.title_new'|trans }}</a>
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_plan_new', vehicleFilter ? {vehicle_id: vehicleFilter, return_to: maintenanceReturnTo} : {return_to: maintenanceReturnTo}) }}">{{ 'maintenance.plan_form.title_new'|trans }}</a>
                                <a class="btn btn-secondary" href="{{ path('ui_maintenance_event_new', vehicleFilter ? {vehicle_id: vehicleFilter, return_to: maintenanceReturnTo} : {return_to: maintenanceReturnTo}) }}">{{ 'maintenance.event_form.title_new'|trans }}</a>
                            </div>
                        </div>
                    {% else %}
                        <div class="planner-list">
                            {% for reminder in reminders|slice(0, 8) %}
                                <div class="card-subtle planner-item">
                                    <div class="item-title">
                                        <strong>{{ ruleNames[reminder.ruleId] ?? reminder.ruleId }}</strong>
                                        <span class="muted">{{ reminder.createdAt|date('d/m/Y H:i') }}</span>
                                    </div>
                                    <div class="item-sub">{{ vehicleOptions[reminder.vehicleId] ?? reminder.vehicleId }}</div>
                                    <div class="item-meta">
                                        {% if reminder.dueAtDate is not null %}<span>{{ 'maintenance_dashboard.due_date'|trans({'%date%': reminder.dueAtDate|date('d/m/Y')}) }}</span>{% endif %}
                                        {% if reminder.dueAtOdometerKilometers is not null %}<span>{{ 'maintenance_dashboard.due_odometer'|trans({'%odometer%': reminder.dueAtOdometerKilometers}) }}</span>{% endif %}
                                        {% if reminder.dueByDate %}<span class="pill pill-reminder-date">{{ 'maintenance_dashboard.date_due'|trans }}</span>{% endif %}
                                        {% if reminder.dueByOdometer %}<span class="pill pill-reminder-odometer">{{ 'maintenance_dashboard.odometer_due'|trans }}</span>{% endif %}
                                    </div>
                                    {% set ruleDetail = ruleDetails[reminder.ruleId] ?? null %}
                                    {% if ruleDetail %}
                                        <div class="item-sub">
                                            {{ 'maintenance_dashboard.trigger'|trans({'%mode%': ruleDetail.triggerMode|replace({'_': ' '})|upper}) }}
                                            {% if ruleDetail.intervalDays %}
                                                · {{ (ruleDetail.intervalDays > 1 ? 'maintenance_dashboard.every_days_plural' : 'maintenance_dashboard.every_days')|trans({'%count%': ruleDetail.intervalDays}) }}
                                            {% endif %}
                                            {% if ruleDetail.intervalKilometers %}
                                                · {{ 'maintenance_dashboard.every_kilometers'|trans({'%count%': ruleDetail.intervalKilometers}) }}
                                            {% endif %}
                                            {% if ruleDetail.eventType %}
                                                · {{ 'maintenance_dashboard.suggested_event'|trans({'%event%': ruleDetail.eventType|upper}) }}
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    {% set logEventParams = {vehicle_id: reminder.vehicleId} %}
                                    {% if ruleDetail and ruleDetail.eventType %}
                                        {% set logEventParams = logEventParams|merge({event_type: ruleDetail.eventType}) %}
                                    {% endif %}
                                    {% set logEventParams = logEventParams|merge({return_to: maintenanceReturnTo}) %}
                                    <div class="actions-wrap">
                                        <a class="btn btn-primary btn-compact" href="{{ path('ui_maintenance_event_new', logEventParams) }}">{{ 'maintenance_dashboard.log_event_now'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_vehicle_show', {id: reminder.vehicleId}) }}">{{ 'analytics.open_vehicle'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: reminder.vehicleId}) }}">{{ 'vehicle.show.vehicle_timeline'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {vehicle_id: reminder.vehicleId}) }}">{{ 'nav.receipts'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {vehicle_id: reminder.vehicleId}) }}">{{ 'nav.analytics'|trans }}</a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>
            </article>
        </section>
    </main>
{% endblock %}
