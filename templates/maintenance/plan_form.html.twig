{% extends 'base.html.twig' %}

{% block title %}{% if isEdit %}Edit maintenance plan{% else %}New maintenance plan{% endif %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .maintenance-form-page {
            max-width: 880px;
            margin: 0 auto;
            display: grid;
            gap: 1rem;
        }

        .maintenance-form-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .maintenance-form-card {
            padding: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    {% set backToListUrl = backToListUrl is defined and backToListUrl is not empty ? backToListUrl : path('ui_maintenance_index') %}
    <main class="app-shell maintenance-form-page">
        <header class="maintenance-form-header">
            <div class="page-header">
                <h1 class="page-title">{% if isEdit %}Edit maintenance plan{% else %}Add maintenance plan{% endif %}</h1>
                <p class="muted section-lead">Plan a future maintenance operation with date, budget and optional event type linkage.</p>
            </div>
            <a class="btn btn-secondary" href="{{ backToListUrl }}" data-turbo-frame="_top">Back</a>
        </header>

        <section class="card maintenance-form-card">
            {% if errors is not empty %}
                <div class="flash flash-error">
                    <ul class="flash-list">
                        {% for error in errors %}
                            <li>{{ error }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <form method="post" action="" data-turbo-frame="_top" class="form-stack">
                <input type="hidden" name="_token" value="{{ csrfToken }}">
                <input type="hidden" name="_return_to" value="{{ backToListUrl }}">

                <div class="form-grid-2">
                    <label class="label">
                        Vehicle
                        <select class="select" name="vehicleId" required>
                            <option value="">Select vehicle</option>
                            {% for optionId, optionLabel in vehicleOptions %}
                                <option value="{{ optionId }}" {% if formData.vehicleId == optionId %}selected{% endif %}>{{ optionLabel }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="label">
                        Label
                        <input class="input" type="text" name="label" maxlength="160" value="{{ formData.label }}" required>
                    </label>
                    <label class="label">
                        Event type (optional)
                        <select class="select" name="eventType">
                            <option value="">Not linked</option>
                            {% for eventType in eventTypes %}
                                <option value="{{ eventType }}" {% if formData.eventType == eventType %}selected{% endif %}>{{ eventType|upper }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="label">
                        Planned date
                        <input class="input" type="text" name="plannedFor" data-datepicker="date" value="{{ formData.plannedFor }}" autocomplete="off" required>
                    </label>
                    <label class="label">
                        Planned cost (EUR)
                        <input class="input" type="text" inputmode="decimal" name="plannedCostEuros" value="{{ formData.plannedCostEuros }}" placeholder="320.00" required>
                        <small class="muted">Use an amount in euros, for example <code>320.00</code>.</small>
                    </label>
                    <label class="label">
                        Currency
                        <input class="input" type="text" maxlength="3" name="currencyCode" value="{{ formData.currencyCode }}" required>
                    </label>
                </div>

                <label class="label">
                    Notes
                    <textarea class="input" name="notes" rows="4" maxlength="2000">{{ formData.notes }}</textarea>
                </label>

                <div class="actions-wrap">
                    <button class="btn btn-primary" type="submit">{% if isEdit %}Save changes{% else %}Create plan{% endif %}</button>
                    <a class="btn btn-secondary" href="{{ backToListUrl }}" data-turbo-frame="_top">Cancel</a>
                </div>
            </form>
        </section>
    </main>
{% endblock %}
