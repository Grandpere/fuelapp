{% extends 'base.html.twig' %}

{% block title %}{% if isEdit %}{{ 'maintenance.rule_form.title_edit'|trans }}{% else %}{{ 'maintenance.rule_form.title_new'|trans }}{% endif %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .maintenance-form-page {
            max-width: 880px;
            margin: 0 auto;
            display: grid;
            gap: 1rem;
        }

        .maintenance-form-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .maintenance-form-card {
            padding: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell maintenance-form-page">
        <header class="maintenance-form-header">
            <div class="page-header">
                <h1 class="page-title">{% if isEdit %}{{ 'maintenance.rule_form.title_edit'|trans }}{% else %}{{ 'maintenance.rule_form.title_new'|trans }}{% endif %}</h1>
                <p class="muted section-lead">{{ 'maintenance.rule_form.lead'|trans }}</p>
            </div>
            <a class="btn btn-secondary" href="{{ path('ui_maintenance_index', formData.vehicleId ? {vehicle_id: formData.vehicleId} : {}) }}" data-turbo-frame="_top">{{ 'common.back'|trans }}</a>
        </header>

        <section class="card maintenance-form-card">
            {% if errors is not empty %}
                <div class="flash flash-error">
                    <ul class="flash-list">
                        {% for error in errors %}
                            <li>{{ error|trans }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <form method="post" action="" data-turbo-frame="_top" class="form-stack">
                <input type="hidden" name="_token" value="{{ csrfToken }}">

                <div class="form-grid-2">
                    <label class="label">
                        {{ 'maintenance.form.vehicle'|trans }}
                        <select class="select" name="vehicleId" required>
                            <option value="">{{ 'maintenance.form.select_vehicle'|trans }}</option>
                            {% for optionId, optionLabel in vehicleOptions %}
                                <option value="{{ optionId }}" {% if formData.vehicleId == optionId %}selected{% endif %}>{{ optionLabel }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="label">
                        {{ 'maintenance.rule_form.rule_name'|trans }}
                        <input class="input" type="text" name="name" maxlength="120" value="{{ formData.name }}" placeholder="{{ 'maintenance.rule_form.rule_name_placeholder'|trans }}" required>
                    </label>
                    <label class="label">
                        {{ 'maintenance.rule_form.trigger_mode'|trans }}
                        <select class="select" name="triggerMode" required>
                            {% for triggerMode in triggerModes %}
                                <option value="{{ triggerMode }}" {% if formData.triggerMode == triggerMode %}selected{% endif %}>{{ triggerMode|replace({'_': ' '})|upper }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="label">
                        {{ 'maintenance.rule_form.suggested_event_type'|trans }}
                        <select class="select" name="eventType">
                            <option value="">{{ 'common.not_linked'|trans }}</option>
                            {% for eventType in eventTypes %}
                                <option value="{{ eventType }}" {% if formData.eventType == eventType %}selected{% endif %}>{{ eventType|upper }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="label">
                        {{ 'maintenance.rule_form.interval_days'|trans }}
                        <input class="input" type="number" min="1" step="1" name="intervalDays" value="{{ formData.intervalDays }}" placeholder="180">
                        <small class="muted">{{ 'maintenance.rule_form.interval_days_help'|trans|raw }}</small>
                    </label>
                    <label class="label">
                        {{ 'maintenance.rule_form.interval_kilometers'|trans }}
                        <input class="input" type="number" min="1" step="1" name="intervalKilometers" value="{{ formData.intervalKilometers }}" placeholder="12000">
                        <small class="muted">{{ 'maintenance.rule_form.interval_kilometers_help'|trans|raw }}</small>
                    </label>
                </div>

                <div class="actions-wrap">
                    <button class="btn btn-primary" type="submit">{% if isEdit %}{{ 'maintenance.rule_form.action_save'|trans }}{% else %}{{ 'maintenance.rule_form.action_create'|trans }}{% endif %}</button>
                    <a class="btn btn-secondary" href="{{ path('ui_maintenance_index', formData.vehicleId ? {vehicle_id: formData.vehicleId} : {}) }}" data-turbo-frame="_top">{{ 'action.cancel'|trans }}</a>
                </div>
            </form>
        </section>
    </main>
{% endblock %}
