<turbo-frame id="receipt_form_frame">
    {% set selectedSuggestionValue = selectedStationSuggestion is defined and selectedStationSuggestion is not null ? selectedStationSuggestion.value : '' %}

    {% if errors is not empty %}
        <div class="flash flash-error">
            <ul class="flash-list">
                {% for error in errors %}
                    <li>{{ error|trans }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form method="post" action="{{ path('ui_receipt_new') }}" data-turbo-frame="_top" class="form-stack">
        <input type="hidden" name="_token" value="{{ csrfToken }}">
        <input type="hidden" name="_station_lookup_requested" id="receipt_station_lookup_requested" value="0">

        <label class="label">
            {{ 'receipt.form.date'|trans }}
            <input class="input" type="text" name="issuedAt" value="{{ formData.issuedAt }}" data-datepicker="datetime" autocomplete="off" required>
        </label>
        <label class="label">
            {{ 'receipt.form.vehicle_optional'|trans }}
            <select class="select" name="vehicleId">
                <option value="">{{ 'receipt.form.no_linked_vehicle'|trans }}</option>
                {% for optionId, optionLabel in vehicleOptions %}
                    <option value="{{ optionId }}" {% if formData.vehicleId == optionId %}selected{% endif %}>{{ optionLabel }}</option>
                {% endfor %}
            </select>
        </label>
        <label class="label">
            {{ 'receipt.form.odometer_optional'|trans }}
            <input class="input" type="number" min="0" step="1" name="odometerKilometers" value="{{ formData.odometerKilometers }}">
        </label>

        <fieldset class="card-subtle form-block">
            <legend class="muted">{{ 'receipt.form.fuel_line'|trans }}</legend>
            <div class="form-grid-2">
                <label class="label">
                    {{ 'receipt.form.fuel_type'|trans }}
                    <select class="select" name="fuelType">
                        {% for fuelType in fuelTypes %}
                            <option value="{{ fuelType }}" {% if formData.fuelType == fuelType %}selected{% endif %}>{{ fuelType|upper }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="label">
                    {{ 'receipt.form.quantity'|trans }}
                    <input class="input" type="text" inputmode="decimal" name="quantityLiters" value="{{ formData.quantityLiters }}" placeholder="40.40" required>
                    <small class="muted">{{ 'receipt.form.quantity_help'|trans|raw }}</small>
                </label>
                <label class="label">
                    {{ 'receipt.form.unit_price'|trans }}
                    <input class="input" type="text" inputmode="decimal" name="unitPriceEurosPerLiter" value="{{ formData.unitPriceEurosPerLiter }}" placeholder="1.769" required>
                    <small class="muted">{{ 'receipt.form.unit_price_help'|trans|raw }}</small>
                </label>
                <label class="label">
                    {{ 'receipt.form.vat'|trans }}
                    <input class="input" type="number" min="0" max="100" step="1" name="vatRatePercent" value="{{ formData.vatRatePercent }}" required>
                </label>
            </div>
        </fieldset>

        <fieldset class="card-subtle form-block">
            <legend class="muted">{{ 'receipt.form.station_section'|trans }}</legend>
            <div class="station-lookup-block">
                <label class="label">
                    {{ 'receipt.form.existing_station_optional'|trans }}
                    <input class="input" type="text" name="stationSearch" value="{{ formData.stationSearch }}" placeholder="{{ 'receipt.form.station_search_placeholder'|trans }}">
                </label>
                <div class="actions-wrap station-lookup-actions">
                    <button class="btn btn-secondary btn-compact station-lookup-button" type="submit" name="_station_lookup" value="1" formnovalidate onclick="document.getElementById('receipt_station_lookup_requested').value='1';">{{ 'receipt.form.station_lookup'|trans }}</button>
                    <p class="muted station-lookup-hint">{{ 'receipt.form.station_lookup_hint'|trans|raw }}</p>
                </div>
                {% if stationLookupPerformed %}
                    <div class="station-lookup-feedback">
                        <span class="station-lookup-feedback-label">{{ 'receipt.form.station_lookup_result'|trans }}</span>
                        <p class="muted compact-note">
                        {% if stationLookupCount > 0 %}
                            {{ (stationLookupCount == 1 ? 'receipt.form.station_lookup_matches_single' : 'receipt.form.station_lookup_matches_plural')|trans({'%count%': stationLookupCount}) }}
                        {% else %}
                            {{ 'receipt.form.station_lookup_no_match'|trans }}
                        {% endif %}
                        </p>
                    </div>
                {% endif %}
                {% set existingStationSuggestions = existingStationSuggestions|default([]) %}
                {% set publicStationSuggestions = publicStationSuggestions|default([]) %}
                {% if existingStationSuggestions is not empty or publicStationSuggestions is not empty %}
                    <div class="station-selection-state {{ selectedStationSuggestion is not null ? 'is-visible' : '' }}" data-station-selection-state>
                        <span class="station-selection-state-label">{{ 'receipt.form.station_selection_active'|trans }}</span>
                        <p class="station-selection-state-title" data-station-selection-title>{{ selectedStationSuggestion is not null ? selectedStationSuggestion.title : '' }}</p>
                        <p class="station-selection-state-copy" data-station-selection-copy>{% if selectedStationSuggestion is not null %}{% if selectedStationSuggestion.kind == 'public' %}<strong>{{ 'receipt.form.station_selection_public_prefix'|trans }}</strong> {{ selectedStationSuggestion.meta }} {{ 'receipt.form.station_selection_public_suffix'|trans }}{% else %}<strong>{{ 'receipt.form.station_selection_existing_prefix'|trans }}</strong> {{ selectedStationSuggestion.meta }} {{ 'receipt.form.station_selection_existing_suffix'|trans }}{% endif %}{% endif %}</p>
                        <button class="btn btn-secondary btn-compact station-selection-reset" type="button" data-station-selection-reset>{{ 'receipt.form.station_selection_reset'|trans }}</button>
                    </div>
                    <div class="station-lookup-results">
                        {% if existingStationSuggestions is not empty %}
                            <p class="station-lookup-results-title">{{ 'receipt.form.station_suggestions_existing'|trans }}</p>
                            {% for candidate in existingStationSuggestions %}
                                {% set candidateValue = 'station:' ~ candidate.sourceId %}
                                {% set isSelected = selectedSuggestionValue == candidateValue %}
                                <label class="station-lookup-option {{ isSelected ? 'is-selected' : '' }}" data-suggestion-kind="existing" data-suggestion-title="{{ candidate.name }}" data-suggestion-meta="{{ candidate.streetName }}, {{ candidate.postalCode }} {{ candidate.city }}">
                                    <input type="radio" name="selectedSuggestion" value="{{ candidateValue }}" {% if isSelected %}checked{% endif %}>
                                    <span class="station-lookup-option-content">
                                        <span class="station-lookup-option-badge">{{ 'receipt.form.station_suggestion_existing_badge'|trans }}</span>
                                        <span class="station-lookup-option-selection-badge">{{ 'receipt.form.station_suggestion_selected_badge'|trans }}</span>
                                        <strong>{{ candidate.name }}</strong>
                                        <span>{{ candidate.streetName }}</span>
                                        <span class="station-lookup-option-meta">{{ candidate.postalCode }} {{ candidate.city }}</span>
                                    </span>
                                </label>
                            {% endfor %}
                        {% endif %}
                        {% if publicStationSuggestions is not empty %}
                            <p class="station-lookup-results-title">{{ 'receipt.form.station_suggestions_public'|trans }}</p>
                            {% for candidate in publicStationSuggestions %}
                                {% set candidateValue = 'public:' ~ candidate.sourceId %}
                                {% set isSelected = selectedSuggestionValue == candidateValue %}
                                <label class="station-lookup-option {{ isSelected ? 'is-selected' : '' }}" data-suggestion-kind="public" data-suggestion-title="{{ candidate.name }}" data-suggestion-meta="{{ candidate.postalCode }} {{ candidate.city }}">
                                    <input type="radio" name="selectedSuggestion" value="{{ candidateValue }}" {% if isSelected %}checked{% endif %}>
                                    <span class="station-lookup-option-content">
                                        <span class="station-lookup-option-badge station-lookup-option-badge-public">{{ 'receipt.form.station_suggestion_public_badge'|trans }}</span>
                                        <span class="station-lookup-option-selection-badge">{{ 'receipt.form.station_suggestion_selected_badge'|trans }}</span>
                                        <strong>{{ candidate.name }}</strong>
                                        <span class="station-lookup-option-meta">{{ candidate.postalCode }} {{ candidate.city }}</span>
                                        <span class="muted compact-note">{{ 'receipt.form.station_suggestion_public_help'|trans }}</span>
                                    </span>
                                </label>
                            {% endfor %}
                        {% endif %}
                        <label class="station-lookup-option station-lookup-manual">
                            <input type="radio" name="selectedSuggestion" value="" {% if selectedSuggestionValue == '' %}checked{% endif %}>
                            <span class="station-lookup-option-content">
                                <strong>{{ 'receipt.form.station_suggestion_manual_title'|trans }}</strong>
                                <span>{{ 'receipt.form.station_suggestion_manual_help'|trans }}</span>
                            </span>
                        </label>
                    </div>
                {% else %}
                    <input type="hidden" name="selectedSuggestion" value="">
                    <input type="hidden" name="selectedStationId" value="{{ formData.selectedStationId }}">
                {% endif %}
            </div>
            <div class="form-grid-2 station-manual-fields" data-station-manual-fields>
                <label class="label">
                    {{ 'receipt.form.station_name'|trans }}
                    <input class="input" type="text" name="stationName" value="{{ formData.stationName }}" required data-manual-required="1">
                </label>
                <label class="label">
                    {{ 'receipt.form.station_street_name'|trans }}
                    <input class="input" type="text" name="stationStreetName" value="{{ formData.stationStreetName }}" required data-manual-required="1">
                </label>
                <label class="label">
                    {{ 'receipt.form.station_postal_code'|trans }}
                    <input class="input" type="text" name="stationPostalCode" value="{{ formData.stationPostalCode }}" required data-manual-required="1">
                </label>
                <label class="label">
                    {{ 'receipt.form.station_city'|trans }}
                    <input class="input" type="text" name="stationCity" value="{{ formData.stationCity }}" required data-manual-required="1">
                </label>
                <label class="label">
                    {{ 'receipt.form.station_latitude_optional'|trans }}
                    <input class="input" type="number" name="latitudeMicroDegrees" value="{{ formData.latitudeMicroDegrees }}">
                </label>
                <label class="label">
                    {{ 'receipt.form.station_longitude_optional'|trans }}
                    <input class="input" type="number" name="longitudeMicroDegrees" value="{{ formData.longitudeMicroDegrees }}">
                </label>
            </div>
        </fieldset>

        <div class="actions-wrap">
            <button class="btn btn-primary" type="submit" onclick="document.getElementById('receipt_station_lookup_requested').value='0';">{{ 'receipt.form.save'|trans }}</button>
            <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}" data-turbo-frame="_top">{{ 'action.cancel'|trans }}</a>
        </div>
    </form>

    <script>
        (() => {
            const root = document.currentScript?.closest('turbo-frame') ?? document;
            const radios = Array.from(root.querySelectorAll('input[name="selectedSuggestion"]'));
            const manualFields = Array.from(root.querySelectorAll('[data-station-manual-fields] input, [data-station-manual-fields] select, [data-station-manual-fields] textarea'));
            const state = root.querySelector('[data-station-selection-state]');
            const stateTitle = root.querySelector('[data-station-selection-title]');
            const stateCopy = root.querySelector('[data-station-selection-copy]');
            const resetButton = root.querySelector('[data-station-selection-reset]');
            const publicSelectionPrefix = {{ 'receipt.form.station_selection_public_prefix'|trans|json_encode|raw }};
            const publicSelectionSuffix = {{ 'receipt.form.station_selection_public_suffix'|trans|json_encode|raw }};
            const existingSelectionPrefix = {{ 'receipt.form.station_selection_existing_prefix'|trans|json_encode|raw }};
            const existingSelectionSuffix = {{ 'receipt.form.station_selection_existing_suffix'|trans|json_encode|raw }};

            if (radios.length === 0 || manualFields.length === 0) {
                return;
            }

            const manualRadio = radios.find((radio) => radio.value === '') ?? null;

            const syncManualFields = () => {
                const selected = radios.find((radio) => radio.checked);
                const useSuggestion = !!selected && selected.value !== '';

                for (const radio of radios) {
                    radio.closest('.station-lookup-option')?.classList.toggle('is-selected', radio.checked && radio.value !== '');
                }

                for (const field of manualFields) {
                    field.disabled = useSuggestion;
                    field.required = !useSuggestion && field.dataset.manualRequired === '1';
                }

                if (!state || !stateTitle || !stateCopy) {
                    return;
                }

                if (!useSuggestion) {
                    state.classList.remove('is-visible');
                    stateTitle.textContent = '';
                    stateCopy.textContent = '';

                    return;
                }

                const option = selected?.closest('[data-suggestion-kind]');
                const title = option?.dataset.suggestionTitle ?? '';
                const meta = option?.dataset.suggestionMeta ?? '';
                const kind = option?.dataset.suggestionKind ?? '';

                state.classList.add('is-visible');
                stateTitle.textContent = title;

                if (kind === 'public') {
                    stateCopy.innerHTML = `<strong>${publicSelectionPrefix}</strong> ${meta} ${publicSelectionSuffix}`;
                } else {
                    stateCopy.innerHTML = `<strong>${existingSelectionPrefix}</strong> ${meta} ${existingSelectionSuffix}`;
                }
            };

            for (const radio of radios) {
                radio.addEventListener('change', syncManualFields);
            }

            resetButton?.addEventListener('click', () => {
                if (manualRadio) {
                    manualRadio.checked = true;
                    syncManualFields();
                }
            });

            syncManualFields();
        })();
    </script>
</turbo-frame>
