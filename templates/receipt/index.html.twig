{% extends 'base.html.twig' %}

{% block title %}{{ 'receipt.index.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .receipt-page {
            display: grid;
            gap: 1rem;
        }

        .receipt-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
        }

        .receipt-header p {
            margin: 0.35rem 0 0;
        }

        .panel {
            padding: 1rem;
        }

        .filters {
            display: grid;
            gap: 0.85rem;
        }

        .filters-row {
            display: grid;
            gap: 0.75rem;
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .actions-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.65rem;
        }

        .columns-wrap {
            display: grid;
            gap: 0.7rem;
            margin-top: 0.2rem;
            padding: 0.8rem;
        }

        .checkbox-grid {
            display: grid;
            gap: 0.5rem 0.8rem;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            font-size: 0.84rem;
            color: var(--text-soft);
        }

        .checkbox-grid label {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
        }

        .checkbox-grid input[type="checkbox"] {
            accent-color: var(--primary);
        }

        .summary {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.7rem;
            margin-top: 0.8rem;
            color: var(--text-soft);
            font-size: 0.88rem;
        }

        .summary nav {
            display: flex;
            gap: 0.55rem;
        }

        .summary nav a {
            color: var(--link-accent);
            text-decoration: none;
            font-weight: 700;
        }

        .receipt-preset-label {
            max-width: 260px;
        }

        .receipt-note {
            margin: 0.9rem 0 0;
            font-size: 0.84rem;
        }

        .receipt-inline-title {
            font-size: 1.15rem;
            margin-bottom: 0.25rem;
        }

        .receipt-inline-lead {
            margin-top: 0;
        }

        .shortcut-row {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .shortcut-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.35rem 0.6rem;
            border-radius: 999px;
            background: var(--surface-soft);
            border: 1px solid var(--table-wrap-border);
            color: var(--text-soft);
            font-size: 0.82rem;
        }

        .shortcut-pill strong {
            color: var(--text-primary);
        }

        .empty-state {
            margin-top: 0.8rem;
            padding: 0.85rem;
            border-radius: 10px;
            border: 1px dashed var(--table-wrap-border);
            color: var(--text-soft);
        }

        .receipt-row-actions {
            display: grid;
            justify-items: end;
            gap: 0.35rem;
        }

        @media (max-width: 900px) {
            .filters-row {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .checkbox-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 620px) {
            .receipt-header {
                flex-direction: column;
            }

            .filters-row {
                grid-template-columns: 1fr;
            }

            .checkbox-grid {
                grid-template-columns: 1fr;
            }

            .receipt-row-actions {
                justify-items: stretch;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell receipt-page">
        {% if enableRealtime %}
            <turbo-stream-source src="{{ mercure(mercureTopic) }}"></turbo-stream-source>
        {% endif %}

        <section class="receipt-header">
            <div>
                <h1 class="page-title">{{ 'receipt.index.title'|trans }}</h1>
                <p class="muted">{{ 'receipt.index.lead'|trans }}</p>
            </div>
            <a class="btn btn-primary" href="{{ path('ui_receipt_new', newReceiptParams) }}">{{ 'receipt.index.add'|trans }}</a>
        </section>

        {% for message in app.flashes('success') %}
            <div class="flash">{{ message }}</div>
        {% endfor %}

        <section class="card panel">
            <form method="get" action="{{ path('ui_receipt_index') }}" class="filters">
                <div class="filters-row">
                    <label class="label">
                        {{ 'receipt.index.filter_vehicle'|trans }}
                        <select class="select" name="vehicle_id">
                            <option value="">{{ 'receipt.index.filter_all'|trans }}</option>
                            {% for option in vehicleOptions %}
                                <option value="{{ option.id }}" {% if filters.vehicleId == option.id %}selected{% endif %}>{{ option.label }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="label">
                        {{ 'receipt.index.filter_station'|trans }}
                        <select class="select" name="station_id">
                            <option value="">{{ 'receipt.index.filter_all'|trans }}</option>
                            {% for option in stationOptions %}
                                <option value="{{ option.id }}" {% if filters.stationId == option.id %}selected{% endif %}>{{ option.label }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="label">
                        {{ 'receipt.index.filter_issued_from'|trans }}
                        <input class="input" type="text" name="issued_from" value="{{ filters.issuedFrom }}" data-datepicker="date" autocomplete="off">
                    </label>
                    <label class="label">
                        {{ 'receipt.index.filter_issued_to'|trans }}
                        <input class="input" type="text" name="issued_to" value="{{ filters.issuedTo }}" data-datepicker="date" autocomplete="off">
                    </label>
                    <label class="label">
                        {{ 'receipt.index.filter_fuel_type'|trans }}
                        <select class="select" name="fuel_type">
                            <option value="">{{ 'receipt.index.filter_all'|trans }}</option>
                            {% for fuelType in fuelTypeChoices %}
                                <option value="{{ fuelType }}" {% if filters.fuelType == fuelType %}selected{% endif %}>{{ fuelType|upper }}</option>
                            {% endfor %}
                        </select>
                    </label>
                </div>

                <div class="filters-row">
                    <label class="label">
                        {{ 'receipt.index.filter_quantity_min'|trans }}
                        <input class="input" type="number" name="quantity_min" value="{{ filters.quantityMin }}">
                    </label>
                    <label class="label">
                        {{ 'receipt.index.filter_quantity_max'|trans }}
                        <input class="input" type="number" name="quantity_max" value="{{ filters.quantityMax }}">
                    </label>
                    <label class="label">
                        {{ 'receipt.index.filter_unit_price_min'|trans }}
                        <input class="input" type="number" name="unit_price_min" value="{{ filters.unitPriceMin }}">
                    </label>
                    <label class="label">
                        {{ 'receipt.index.filter_unit_price_max'|trans }}
                        <input class="input" type="number" name="unit_price_max" value="{{ filters.unitPriceMax }}">
                    </label>
                </div>

                <div class="filters-row">
                    <label class="label">
                        {{ 'receipt.index.filter_sort_by'|trans }}
                        <select class="select" name="sort_by">
                            <option value="date" {% if filters.sortBy == 'date' %}selected{% endif %}>{{ 'receipt.index.sort_date'|trans }}</option>
                            <option value="total" {% if filters.sortBy == 'total' %}selected{% endif %}>{{ 'receipt.index.sort_total'|trans }}</option>
                            <option value="fuel_type" {% if filters.sortBy == 'fuel_type' %}selected{% endif %}>{{ 'receipt.index.sort_fuel_type'|trans }}</option>
                            <option value="quantity" {% if filters.sortBy == 'quantity' %}selected{% endif %}>{{ 'receipt.index.sort_quantity'|trans }}</option>
                            <option value="unit_price" {% if filters.sortBy == 'unit_price' %}selected{% endif %}>{{ 'receipt.index.sort_unit_price'|trans }}</option>
                            <option value="vat_rate" {% if filters.sortBy == 'vat_rate' %}selected{% endif %}>{{ 'receipt.index.sort_vat_rate'|trans }}</option>
                        </select>
                    </label>
                    <label class="label">
                        {{ 'receipt.index.sort_direction'|trans }}
                        <select class="select" name="sort_direction">
                            <option value="desc" {% if filters.sortDirection == 'desc' %}selected{% endif %}>{{ 'receipt.index.sort_direction_desc'|trans }}</option>
                            <option value="asc" {% if filters.sortDirection == 'asc' %}selected{% endif %}>{{ 'receipt.index.sort_direction_asc'|trans }}</option>
                        </select>
                    </label>
                    <label class="label">
                        {{ 'receipt.index.per_page'|trans }}
                        <select class="select" name="per_page">
                            {% for size in [10, 25, 50, 100] %}
                                <option value="{{ size }}" {% if perPage == size %}selected{% endif %}>{{ size }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="label">
                        {{ 'receipt.index.filter_vat_rate'|trans }}
                        <input class="input" type="number" name="vat_rate" value="{{ filters.vatRate }}">
                    </label>
                </div>

                <div class="actions-row">
                    <button class="btn btn-primary" type="submit">{{ 'action.apply'|trans }}</button>
                    <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}">{{ 'action.reset'|trans }}</a>
                    <a class="btn btn-secondary" href="{{ path('ui_receipt_export', exportQueryParams) }}">{{ 'receipt.index.export_csv'|trans }}</a>
                    <a class="btn btn-secondary" href="{{ path('ui_receipt_export', exportQueryParams|merge({ format: 'xlsx' })) }}">{{ 'receipt.index.export_xlsx'|trans }}</a>
                </div>
                <p class="muted receipt-note">{{ 'receipt.index.export_note'|trans }}</p>

                <div class="shortcut-row">
                    {% for shortcut in dateShortcutLinks %}
                        <a class="btn {{ shortcut.isActive ? 'btn-primary' : 'btn-secondary' }} btn-compact" href="{{ path('ui_receipt_index', shortcut.params) }}">{{ shortcut.label }}</a>
                    {% endfor %}
                </div>

                <fieldset class="card-subtle columns-wrap">
                    <legend class="muted">{{ 'receipt.index.columns'|trans }}</legend>
                    <label class="label receipt-preset-label">
                        {{ 'receipt.index.preset'|trans }}
                        <select class="select" name="columns_preset" onchange="this.form.submit()">
                            {% for presetKey, presetLabel in columnPresetOptions %}
                                <option value="{{ presetKey }}" {% if filters.columnsPreset == presetKey %}selected{% endif %}>{{ presetLabel }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <div class="checkbox-grid">
                        {% for columnKey, columnLabel in columnOptions %}
                            <label>
                                <input type="checkbox" name="columns[]" value="{{ columnKey }}" {% if columnKey in visibleColumns %}checked{% endif %}>
                                {{ columnLabel }}
                            </label>
                        {% endfor %}
                    </div>
                </fieldset>
            </form>
        </section>

        {% if activeFilters is not empty %}
            <section class="card panel">
                <div class="shortcut-row">
                    {% for filter in activeFilters %}
                        <span class="shortcut-pill"><strong>{{ filter.label }}:</strong> {{ filter.value }}</span>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        <section class="card panel">
                <div class="table-wrap">
                    <table class="app-table">
                        <thead>
                            <tr>
                                {% if 'id' in visibleColumns %}<th>{{ 'receipt.index.col_receipt_id'|trans }}</th>{% endif %}
                                {% if 'issued_at' in visibleColumns %}<th>{{ 'receipt.index.col_date'|trans }}</th>{% endif %}
                                {% if 'station_name' in visibleColumns %}<th>{{ 'receipt.index.col_station_name'|trans }}</th>{% endif %}
                                {% if 'station_street_name' in visibleColumns %}<th>{{ 'receipt.index.col_street'|trans }}</th>{% endif %}
                                {% if 'station_postal_code' in visibleColumns %}<th>{{ 'receipt.index.col_postal_code'|trans }}</th>{% endif %}
                                {% if 'station_city' in visibleColumns %}<th>{{ 'receipt.index.col_city'|trans }}</th>{% endif %}
                                {% if 'odometer_kilometers' in visibleColumns %}<th class="text-right">{{ 'receipt.index.col_odometer'|trans }}</th>{% endif %}
                                {% if 'fuel_type' in visibleColumns %}<th>{{ 'receipt.show.col_fuel'|trans }}</th>{% endif %}
                                {% if 'quantity_milli_liters' in visibleColumns %}<th class="text-right">{{ 'receipt.show.col_quantity'|trans }}</th>{% endif %}
                                {% if 'unit_price_deci_cents_per_liter' in visibleColumns %}<th class="text-right">{{ 'receipt.show.col_unit_price'|trans }}</th>{% endif %}
                                {% if 'vat_rate_percent' in visibleColumns %}<th class="text-right">{{ 'receipt.show.col_vat_rate'|trans }}</th>{% endif %}
                                {% if 'total_cents' in visibleColumns %}<th class="text-right">{{ 'receipt.index.col_total'|trans }}</th>{% endif %}
                                {% if 'vat_amount_cents' in visibleColumns %}<th class="text-right">{{ 'receipt.show.col_vat'|trans }}</th>{% endif %}
                                <th class="text-right">{{ 'common.actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody id="receipts_rows">
                            {% for receipt in receipts %}
                                {% include 'receipt/_row.html.twig' with { receipt: receipt, redirectUrl: app.request.uri, visibleColumns: visibleColumns } only %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if receipts is empty %}
                    <div id="receipts-empty" class="empty-state">
                        <p>{{ 'receipt.index.empty'|trans }}</p>
                        <div class="actions-wrap">
                            <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_new', newReceiptParams) }}">{{ 'receipt.index.add_first'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_import_index') }}">{{ 'receipt.index.open_imports'|trans }}</a>
                            {% if selectedVehicle %}
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_vehicle_show', {id: selectedVehicle.id}) }}">{{ 'receipt.index.open_vehicle'|trans }}</a>
                            {% endif %}
                            {% if selectedStation %}
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_station_show', {id: selectedStation.id, return_to: app.request.uri}) }}">{{ 'receipt.index.open_station'|trans }}</a>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}

                <div class="summary">
                    <div>{{ 'receipt.index.summary'|trans({'%count%': total, '%page%': page, '%last_page%': lastPage}) }}</div>
                    <nav>
                        {% if page > 1 %}
                            <a href="{{ path('ui_receipt_index', queryParams|merge({page: page - 1})) }}">{{ 'receipt.index.previous'|trans }}</a>
                        {% endif %}
                        {% if page < lastPage %}
                            <a href="{{ path('ui_receipt_index', queryParams|merge({page: page + 1})) }}">{{ 'receipt.index.next'|trans }}</a>
                        {% endif %}
                    </nav>
                </div>
        </section>
    </main>
{% endblock %}
