{% extends 'base.html.twig' %}

{% block title %}New Receipt{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .new-page {
            max-width: 860px;
            margin: 0 auto;
            display: grid;
            gap: 1rem;
        }

        .new-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 0.8rem;
            align-items: start;
        }

        .new-card {
            padding: 1rem;
        }

        @media (max-width: 720px) {
            .new-header {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell new-page">
        <header class="new-header">
            <div class="page-header">
                <h1 class="page-title">Add receipt</h1>
                <p class="muted section-lead">Create a receipt manually when you do not want to go through the import flow.</p>
            </div>
            <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}">Back to list</a>
        </header>

        <section class="card new-card">
            {% include 'receipt/_form.html.twig' %}
        </section>
    </main>
{% endblock %}
