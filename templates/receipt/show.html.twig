{% extends 'base.html.twig' %}

{% block title %}Receipt {{ receipt.id.toString() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .show-page {
            max-width: 1080px;
            margin: 0 auto;
            display: grid;
            gap: 1rem;
        }

        .show-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
        }

        .show-actions {
            display: inline-flex;
            gap: 0.55rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .show-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1rem;
        }

        .show-card {
            padding: 1rem;
        }

        .show-card h2 {
            margin: 0 0 0.7rem;
            font-size: 1.05rem;
            font-family: var(--font-display);
        }

        .show-kv {
            display: grid;
            gap: 0.45rem;
            font-size: 0.95rem;
        }

        .show-card-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: 0.7rem;
            flex-wrap: wrap;
        }

        .show-action-list {
            display: flex;
            gap: 0.55rem;
            flex-wrap: wrap;
        }

        .show-helper {
            margin: 0 0 0.8rem;
        }

        @media (max-width: 1100px) {
            .show-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 900px) {
            .show-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 700px) {
            .show-header {
                flex-direction: column;
            }
        }
    </style>
{% endblock %}

{% block body %}
    {% set requestedReturnTo = app.request.query.get('return_to') %}
    {% set backToListUrl = requestedReturnTo is not empty and requestedReturnTo starts with('/') and not (requestedReturnTo starts with('//')) ? requestedReturnTo : path('ui_receipt_index') %}
    {% set receiptShowUrl = path('ui_receipt_show', {id: receipt.id.toString(), return_to: backToListUrl}) %}
    <main class="app-shell show-page">
        <header class="show-header">
            <div>
                <h1 class="page-title">Receipt detail</h1>
                <p class="muted section-lead">Traceable fuel purchase snapshot.</p>
            </div>
            <div class="show-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_edit_metadata', {id: receipt.id.toString(), return_to: backToListUrl}) }}">Edit details</a>
                <a class="btn btn-secondary" href="{{ path('ui_receipt_edit_lines', {id: receipt.id.toString(), return_to: backToListUrl}) }}">Edit lines</a>
                <form method="post" action="{{ path('ui_receipt_delete', {id: receipt.id.toString()}) }}" onsubmit="return confirm('Delete this receipt?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_receipt_' ~ receipt.id.toString()) }}">
                    <input type="hidden" name="_redirect" value="{{ backToListUrl }}">
                    <button class="btn btn-danger" type="submit">Delete</button>
                </form>
                <a class="btn btn-secondary" href="{{ backToListUrl }}">Back to list</a>
            </div>
        </header>

        <section class="card show-card">
            <div class="show-card-head">
                <h2 class="section-title">Quick corrections</h2>
            </div>
            <p class="muted section-lead show-helper">Use the closest correction flow without leaving the receipt context.</p>
            <div class="show-action-list">
                {% if vehicle is null %}
                    <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_edit_metadata', {id: receipt.id.toString(), return_to: backToListUrl}) }}">Link vehicle</a>
                {% endif %}
                {% if station is null %}
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_edit_metadata', {id: receipt.id.toString(), return_to: backToListUrl}) }}">Link station</a>
                {% endif %}
                {% if receipt.odometerKilometers is null %}
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_edit_metadata', {id: receipt.id.toString(), return_to: backToListUrl}) }}">Add odometer</a>
                {% endif %}
                <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_edit_lines', {id: receipt.id.toString(), return_to: backToListUrl}) }}">Adjust fuel lines</a>
                {% if latestMaintenanceEvent %}
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_event_edit', {id: latestMaintenanceEvent.id.toString(), return_to: receiptShowUrl}) }}">Edit last maintenance</a>
                {% endif %}
                {% if station %}
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_station_edit', {id: station.id.toString(), redirect: receiptShowUrl}) }}">Edit station</a>
                {% endif %}
            </div>
        </section>

        <section class="show-grid">
            <article class="card show-card">
                <h2>Summary</h2>
                <div class="show-kv">
                    <div><strong>ID:</strong> {{ receipt.id.toString() }}</div>
                    <div><strong>Date:</strong> {{ receipt.issuedAt|date('d/m/Y H:i') }}</div>
                    <div><strong>Vehicle:</strong> {{ vehicle ? vehicle.name ~ ' (' ~ vehicle.plateNumber ~ ')' : 'n/a' }}</div>
                    <div><strong>Odometer:</strong> {{ receipt.odometerKilometers is not null ? receipt.odometerKilometers ~ ' km' : 'n/a' }}</div>
                    <div><strong>Total:</strong> {{ (receipt.totalCents / 100)|number_format(2, ',', ' ') }} EUR</div>
                    <div><strong>VAT:</strong> {{ (receipt.vatAmountCents / 100)|number_format(2, ',', ' ') }} EUR</div>
                </div>
            </article>

            <article class="card show-card">
                <div class="show-card-head">
                    <h2 class="section-title">Vehicle context</h2>
                    {% if vehicle %}
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_vehicle_show', {id: vehicle.id.toString()}) }}">Open vehicle</a>
                    {% endif %}
                </div>
                {% if vehicle %}
                    <div class="show-kv">
                        <div><strong>{{ vehicle.name }}</strong></div>
                        <div>Plate {{ vehicle.plateNumber }}</div>
                        {% if latestMaintenanceEvent %}
                            <div><strong>Last maintenance:</strong> {{ latestMaintenanceEvent.eventType.value|upper }} on {{ latestMaintenanceEvent.occurredAt|date('d/m/Y H:i') }}</div>
                            {% if latestMaintenanceEvent.description %}
                                <div><strong>Maintenance note:</strong> {{ latestMaintenanceEvent.description }}</div>
                            {% endif %}
                            {% if latestMaintenanceEvent.totalCostCents is not null %}
                                <div><strong>Maintenance cost:</strong> {{ (latestMaintenanceEvent.totalCostCents / 100)|number_format(2, ',', ' ') }} {{ latestMaintenanceEvent.currencyCode }}</div>
                            {% endif %}
                            {% if latestMaintenanceEvent.odometerKilometers is not null %}
                                <div><strong>Maintenance odometer:</strong> {{ latestMaintenanceEvent.odometerKilometers }} km</div>
                            {% endif %}
                        {% else %}
                            <div class="muted">No maintenance event tracked yet for this vehicle.</div>
                        {% endif %}
                        {% if maintenanceOdometerDelta is not null %}
                            <div><strong>Distance since last maintenance:</strong> {{ maintenanceOdometerDelta }} km</div>
                        {% endif %}
                    </div>
                    <div class="show-action-list">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {vehicle_id: vehicle.id.toString()}) }}">Vehicle receipts</a>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString()}) }}">Maintenance</a>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {vehicle_id: vehicle.id.toString()}) }}">Analytics</a>
                        {% if latestMaintenanceEvent %}
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_event_edit', {id: latestMaintenanceEvent.id.toString(), return_to: receiptShowUrl}) }}">Edit last maintenance</a>
                        {% endif %}
                        <a class="btn btn-primary btn-compact" href="{{ path('ui_maintenance_event_new', {vehicle_id: vehicle.id.toString()}) }}">Add maintenance event</a>
                    </div>
                {% else %}
                    <p class="muted section-lead">No vehicle linked to this receipt yet.</p>
                {% endif %}
            </article>

            <article class="card show-card">
                <div class="show-card-head">
                    <h2 class="section-title">Station</h2>
                    {% if station %}
                        <div class="show-action-list">
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_station_show', {id: station.id.toString(), return_to: receiptShowUrl}) }}">Open station</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {station_id: station.id.toString()}) }}">Station receipts</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {station_id: station.id.toString()}) }}">Analytics</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_station_edit', {id: station.id.toString(), redirect: receiptShowUrl}) }}">Edit station</a>
                        </div>
                    {% endif %}
                </div>
                {% if station %}
                    <div class="show-kv">
                        <div><strong>{{ station.name }}</strong></div>
                        <div>{{ station.streetName }}</div>
                        <div>{{ station.postalCode }} {{ station.city }}</div>
                    </div>
                {% else %}
                    <p class="muted section-lead">No station associated.</p>
                {% endif %}
            </article>
        </section>

        <section class="card show-card">
            <div class="show-card-head">
                <h2 class="section-title">Lines</h2>
                <a
                    class="btn btn-secondary icon-btn"
                    href="{{ path('ui_receipt_edit_lines', {id: receipt.id.toString(), return_to: backToListUrl}) }}"
                    aria-label="Edit lines"
                    title="Edit lines"
                >
                    ✎
                </a>
            </div>
            <div class="table-wrap table-min-740">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>Fuel</th>
                            <th class="text-right">Quantity</th>
                            <th class="text-right">Unit price</th>
                            <th class="text-right">VAT %</th>
                            <th class="text-right">VAT</th>
                            <th class="text-right">Line total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for line in receipt.lines %}
                            <tr class="table-row">
                                <td><span class="pill pill-energy">{{ line.fuelType.value|upper }}</span></td>
                                <td class="text-right">{{ (line.quantityMilliLiters / 1000)|number_format(3, ',', ' ') }} L</td>
                                <td class="text-right">{{ (line.unitPriceDeciCentsPerLiter / 1000)|number_format(3, ',', ' ') }} EUR/L</td>
                                <td class="text-right">{{ line.vatRatePercent }}%</td>
                                <td class="text-right">{{ (line.vatAmountCents / 100)|number_format(2, ',', ' ') }} EUR</td>
                                <td class="text-right"><strong>{{ (line.lineTotalCents / 100)|number_format(2, ',', ' ') }} EUR</strong></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
