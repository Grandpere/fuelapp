{% extends 'base.html.twig' %}

{% block title %}{{ 'security.login.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .login-shell {
            max-width: 460px;
            margin: 10vh auto 0;
        }

        .login-card {
            padding: 1.2rem;
            display: grid;
            gap: 0.9rem;
        }

        .login-card h1 {
            margin: 0;
            font-family: var(--font-display);
            font-size: 1.4rem;
        }

        .login-lead,
        .login-provider-list {
            margin: 0;
        }

        .login-form {
            display: grid;
            gap: 0.75rem;
        }

        .login-divider {
            display: flex;
            align-items: center;
            gap: 0.7rem;
        }

        .login-divider::before,
        .login-divider::after {
            content: "";
            height: 1px;
            flex: 1;
            background: var(--table-wrap-border);
        }

        .login-provider-list {
            display: grid;
            gap: 0.5rem;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell login-shell">
        <section class="card login-card">
            <h1>{{ 'security.login.title'|trans }}</h1>
            <p class="muted login-lead">{{ 'security.login.lead'|trans }}</p>

            {% if error %}
                <div class="flash flash-error-soft">
                    {{ 'security.login.invalid_credentials'|trans }}
                </div>
            {% endif %}

            <form method="post" class="login-form">
                <label class="label">
                    {{ 'security.login.email'|trans }}
                    <input class="input" type="email" name="email" value="{{ lastUsername }}" autocomplete="email" required autofocus>
                </label>

                <label class="label">
                    {{ 'security.login.password'|trans }}
                    <input class="input" type="password" name="password" autocomplete="current-password" required>
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="btn btn-primary" type="submit">{{ 'security.login.title'|trans }}</button>
            </form>

            {% if oidcProviders is not empty %}
                <div class="muted login-divider">
                    <span>{{ 'security.login.continue_with'|trans }}</span>
                </div>
                <div class="login-provider-list">
                    {% for provider in oidcProviders %}
                        <a class="btn btn-secondary" href="{{ path('ui_oidc_start', {provider: provider.name}) }}">
                            {{ 'security.login.provider_continue_with'|trans({'%provider%': provider.label}) }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
