{% extends 'base.html.twig' %}

{% block title %}Sign in{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .login-shell {
            max-width: 460px;
            margin: 10vh auto 0;
        }

        .login-card {
            padding: 1.2rem;
            display: grid;
            gap: 0.9rem;
        }

        .login-card h1 {
            margin: 0;
            font-family: "Space Grotesk", sans-serif;
            font-size: 1.4rem;
        }

        .login-lead,
        .login-provider-list {
            margin: 0;
        }

        .login-form {
            display: grid;
            gap: 0.75rem;
        }

        .login-divider {
            display: flex;
            align-items: center;
            gap: 0.7rem;
        }

        .login-divider::before,
        .login-divider::after {
            content: "";
            height: 1px;
            flex: 1;
            background: rgba(255, 255, 255, 0.2);
        }

        .login-provider-list {
            display: grid;
            gap: 0.5rem;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell login-shell">
        <section class="card login-card">
            <h1>Sign in</h1>
            <p class="muted login-lead">Use your FuelApp account credentials.</p>

            {% if error %}
                <div class="flash flash-error-soft">
                    Invalid credentials.
                </div>
            {% endif %}

            <form method="post" class="login-form">
                <label class="label">
                    Email
                    <input class="input" type="email" name="email" value="{{ lastUsername }}" autocomplete="email" required autofocus>
                </label>

                <label class="label">
                    Password
                    <input class="input" type="password" name="password" autocomplete="current-password" required>
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="btn btn-primary" type="submit">Sign in</button>
            </form>

            {% if oidcProviders is not empty %}
                <div class="muted login-divider">
                    <span>or continue with</span>
                </div>
                <div class="login-provider-list">
                    {% for provider in oidcProviders %}
                        <a class="btn btn-secondary" href="{{ path('ui_oidc_start', {provider: provider.name}) }}">
                            Continue with {{ provider.label }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
