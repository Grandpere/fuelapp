{% extends 'base.html.twig' %}

{% block title %}{{ 'station.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stations-page {
            display: grid;
            gap: 1rem;
        }

        .stations-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .stations-header p {
            margin: 0.35rem 0 0;
        }

        .stations-panel {
            padding: 1rem;
        }

        .station-summary {
            display: grid;
            gap: 0.25rem;
        }

        .station-summary-main {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .station-summary-title {
            display: grid;
            gap: 0.25rem;
        }

        .station-summary-title-head {
            display: flex;
            gap: 0.55rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .station-summary-meta {
            display: flex;
            gap: 0.55rem;
            flex-wrap: wrap;
            color: var(--text-soft);
            font-size: 0.84rem;
        }

        .favorite-toggle-form {
            margin: 0;
        }

        .favorite-toggle-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            min-height: 2rem;
        }

        .favorite-toggle-icon {
            font-size: 0.92rem;
            line-height: 1;
        }

        .favorite-pill {
            background: rgba(247, 181, 0, 0.16);
            border-color: rgba(247, 181, 0, 0.3);
            color: var(--text-strong);
        }

    </style>
{% endblock %}

{% block body %}
    <main class="app-shell stations-page">
        <section class="stations-header">
            <div>
                <h1 class="page-title">{{ 'station.title'|trans }}</h1>
                <p class="muted section-lead">{{ 'station.lead'|trans }}</p>
            </div>
            <div class="page-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}">{{ 'nav.receipts'|trans }}</a>
                <a class="btn btn-primary" href="{{ path('ui_receipt_new') }}">{{ 'receipt.form.action_create'|trans }}</a>
            </div>
        </section>

        {% for message in app.flashes('success') %}
            <div class="flash">{{ message|trans }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash flash-error">{{ message|trans }}</div>
        {% endfor %}

        <section class="card stations-panel">
            {% if stationRows is empty %}
                <div class="empty-state">
                    <p>{{ 'station.empty'|trans }}</p>
                    <div class="actions-wrap">
                        <a class="btn btn-primary" href="{{ path('ui_receipt_new') }}">{{ 'station.empty_action_add_receipt'|trans }}</a>
                        <a class="btn btn-secondary" href="{{ path('ui_import_index') }}">{{ 'station.empty_action_open_imports'|trans }}</a>
                    </div>
                </div>
            {% else %}
                <div class="table-wrap table-min-920">
                    <table class="app-table">
                        <thead>
                            <tr>
                                <th>{{ 'nav.stations'|trans|slice(0) }}</th>
                                <th>{{ 'station.latest_visit'|trans }}</th>
                                <th>{{ 'station.receipts_count'|trans }}</th>
                                <th>{{ 'station.recent_spend'|trans }}</th>
                                <th>{{ 'station.latest_odometer'|trans }}</th>
                                <th>{{ 'receipt.action.details'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in stationRows %}
                                <tr
                                    class="table-row row-link"
                                    data-controller="row-link"
                                    data-action="click->row-link#navigate"
                                    data-row-link-url-value="{{ path('ui_station_show', {id: row.id, return_to: path('ui_station_list')}) }}"
                                    onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                                >
                                    <td>
                                        <div class="station-summary">
                                            <div class="station-summary-main">
                                                <div class="station-summary-title">
                                                    <div class="station-summary-title-head">
                                                        <strong>{{ row.name }}</strong>
                                                        {% if row.isFavorite %}
                                                            <span class="pill favorite-pill">{{ 'station.favorite'|trans }}</span>
                                                        {% endif %}
                                                    </div>
                                                    <span class="muted">{{ row.streetName }}</span>
                                                </div>
                                            </div>
                                            <div class="station-summary-meta">
                                                <span>{{ row.postalCode }} {{ row.city }}</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        {% if row.latestIssuedAt %}
                                            {{ row.latestIssuedAt|date('d/m/Y') }}
                                        {% else %}
                                            <span class="muted">{{ 'common.na'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ row.receiptCount }}</td>
                                    <td>{{ (row.recentSpendCents / 100)|number_format(2, '.', ' ') }} EUR</td>
                                    <td>
                                        {% if row.latestOdometer is not null %}
                                            {{ row.latestOdometer }} km
                                        {% else %}
                                            <span class="muted">{{ 'common.na'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="action-cell-flex">
                                        <form class="favorite-toggle-form" method="post" action="{{ path('ui_station_toggle_favorite', {id: row.id}) }}" data-row-link-ignore>
                                            <input type="hidden" name="_token" value="{{ csrf_token('station_favorite_toggle_' ~ row.id) }}">
                                            <input type="hidden" name="_redirect" value="{{ path('ui_station_list') }}">
                                            <button class="btn {{ row.isFavorite ? 'btn-primary' : 'btn-secondary' }} btn-compact favorite-toggle-btn" type="submit">
                                                <span class="favorite-toggle-icon" aria-hidden="true">{{ row.isFavorite ? '★' : '☆' }}</span>
                                                {{ row.isFavorite ? 'station.favorite'|trans : 'station.add_favorite'|trans }}
                                            </button>
                                        </form>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_station_show', {id: row.id, return_to: path('ui_station_list')}) }}" data-row-link-ignore>{{ 'action.open'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {station_id: row.id}) }}" data-row-link-ignore>{{ 'nav.receipts'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {station_id: row.id}) }}" data-row-link-ignore>{{ 'nav.analytics'|trans }}</a>
                                        <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_new', {station_id: row.id}) }}" data-row-link-ignore>{{ 'receipt.form.action_create'|trans }}</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
