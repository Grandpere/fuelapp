{% extends 'base.html.twig' %}

{% block title %}Stations{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stations-page {
            display: grid;
            gap: 1rem;
        }

        .stations-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .stations-header p {
            margin: 0.35rem 0 0;
        }

        .stations-kpi-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .stations-kpi-card,
        .stations-panel {
            padding: 1rem;
        }

        .stations-kpi-label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--text-soft);
        }

        .stations-kpi-value {
            margin-top: 0.3rem;
            font-family: var(--font-display);
            font-size: 1.18rem;
            font-weight: 700;
        }

        .station-summary {
            display: grid;
            gap: 0.25rem;
        }

        .station-summary-main {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .station-summary-title {
            display: grid;
            gap: 0.25rem;
        }

        .station-summary-meta {
            display: flex;
            gap: 0.55rem;
            flex-wrap: wrap;
            color: var(--text-soft);
            font-size: 0.84rem;
        }

        @media (max-width: 900px) {
            .stations-kpi-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell stations-page">
        <section class="stations-header">
            <div>
                <h1 class="page-title">Stations</h1>
                <p class="muted section-lead">Quick view of the places you revisit most, with direct shortcuts into receipts and analytics.</p>
            </div>
            <div class="page-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index') }}">Receipts</a>
                <a class="btn btn-primary" href="{{ path('ui_receipt_new') }}" data-turbo-frame="receipt_form_frame">Add receipt</a>
            </div>
        </section>

        {% for message in app.flashes('success') %}
            <div class="flash">{{ message }}</div>
        {% endfor %}

        <section class="stations-kpi-grid">
            <article class="card-subtle stations-kpi-card">
                <div class="stations-kpi-label">Tracked stations</div>
                <div class="stations-kpi-value">{{ trackedStationCount }}</div>
            </article>
            <article class="card-subtle stations-kpi-card">
                <div class="stations-kpi-label">Accessible stations</div>
                <div class="stations-kpi-value">{{ stationRows|length }}</div>
            </article>
            <article class="card-subtle stations-kpi-card">
                <div class="stations-kpi-label">Receipts linked</div>
                <div class="stations-kpi-value">{{ totalReceiptCount }}</div>
            </article>
        </section>

        <section class="card stations-panel">
            {% if stationRows is empty %}
                <div class="empty-state">
                    <p>No station is visible yet. Add or import a receipt with station details to start building this list.</p>
                    <div class="actions-wrap">
                        <a class="btn btn-primary" href="{{ path('ui_receipt_new') }}" data-turbo-frame="receipt_form_frame">Add first receipt</a>
                        <a class="btn btn-secondary" href="{{ path('ui_import_index') }}">Open imports</a>
                    </div>
                </div>
            {% else %}
                <div class="table-wrap table-min-920">
                    <table class="app-table">
                        <thead>
                            <tr>
                                <th>Station</th>
                                <th>Latest visit</th>
                                <th>Receipts</th>
                                <th>Recent spend</th>
                                <th>Latest odometer</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in stationRows %}
                                <tr
                                    class="table-row row-link"
                                    data-controller="row-link"
                                    data-action="click->row-link#navigate"
                                    data-row-link-url-value="{{ path('ui_station_show', {id: row.id, return_to: path('ui_station_list')}) }}"
                                    onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                                >
                                    <td>
                                        <div class="station-summary">
                                            <div class="station-summary-main">
                                                <div class="station-summary-title">
                                                    <strong>{{ row.name }}</strong>
                                                    <span class="muted">{{ row.streetName }}</span>
                                                </div>
                                                <span class="pill pill-energy" data-row-link-ignore>Tracked</span>
                                            </div>
                                            <div class="station-summary-meta">
                                                <span>{{ row.postalCode }} {{ row.city }}</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        {% if row.latestIssuedAt %}
                                            {{ row.latestIssuedAt|date('d/m/Y') }}
                                        {% else %}
                                            <span class="muted">n/a</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ row.receiptCount }}</td>
                                    <td>{{ (row.recentSpendCents / 100)|number_format(2, '.', ' ') }} EUR</td>
                                    <td>
                                        {% if row.latestOdometer is not null %}
                                            {{ row.latestOdometer }} km
                                        {% else %}
                                            <span class="muted">n/a</span>
                                        {% endif %}
                                    </td>
                                    <td class="action-cell-flex">
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_station_show', {id: row.id, return_to: path('ui_station_list')}) }}" data-row-link-ignore>Open</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {station_id: row.id}) }}" data-row-link-ignore>Receipts</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {station_id: row.id}) }}" data-row-link-ignore>Analytics</a>
                                        <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_new', {station_id: row.id}) }}" data-turbo-frame="receipt_form_frame" data-row-link-ignore>Add receipt</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
