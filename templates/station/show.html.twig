{% extends 'base.html.twig' %}

{% block title %}{{ station.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .station-show-page {
            max-width: 1120px;
            margin: 0 auto;
            display: grid;
            gap: 1rem;
        }

        .station-show-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .station-show-header p {
            margin: 0.35rem 0 0;
        }

        .station-show-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .station-favorite-summary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .favorite-toggle-form {
            margin: 0;
        }

        .favorite-toggle-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

        .favorite-toggle-icon {
            font-size: 0.95rem;
            line-height: 1;
        }

        .favorite-pill {
            background: rgba(247, 181, 0, 0.16);
            border-color: rgba(247, 181, 0, 0.3);
            color: var(--text-strong);
        }

        .station-kpi-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.8rem;
        }

        .station-kpi-card,
        .station-panel,
        .station-item {
            padding: 0.95rem;
        }

        .station-kpi-label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--text-soft);
        }

        .station-kpi-value {
            margin-top: 0.3rem;
            font-size: 1.16rem;
            font-weight: 700;
            font-family: var(--font-display);
        }

        .station-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.95fr);
            gap: 1rem;
            align-items: start;
        }

        .station-panel {
            display: grid;
            gap: 0.9rem;
        }

        .station-panel-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .station-panel-head h2 {
            margin: 0;
            font-size: 1.06rem;
        }

        .station-list {
            display: grid;
            gap: 0.7rem;
        }

        .station-item {
            display: grid;
            gap: 0.45rem;
        }

        .station-item-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.65rem;
            flex-wrap: wrap;
        }

        .station-item-sub,
        .station-item-meta {
            color: var(--text-soft);
            font-size: 0.84rem;
        }

        .station-item-meta {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .station-public-match {
            padding: 0.85rem;
            display: grid;
            gap: 0.45rem;
        }

        .station-public-match-head {
            display: flex;
            justify-content: space-between;
            gap: 0.7rem;
            align-items: flex-start;
        }

        .station-public-fuels {
            display: flex;
            gap: 0.4rem;
            flex-wrap: wrap;
        }

        .station-public-fuel-pill {
            padding: 0.2rem 0.48rem;
            border-radius: 999px;
            border: 1px solid var(--surface-soft-border);
            background: var(--surface-soft-bg);
            font-size: 0.78rem;
            color: var(--text-soft);
        }

        .station-public-fuel-pill.is-available {
            color: var(--text-strong);
            border-color: rgba(32, 176, 124, 0.34);
            background: rgba(32, 176, 124, 0.14);
        }

        .station-empty {
            padding: 0.85rem;
            border: 1px dashed var(--table-wrap-border);
            border-radius: 10px;
            color: var(--text-soft);
        }

        @media (max-width: 980px) {
            .station-grid,
            .station-kpi-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell station-show-page">
        {% for message in app.flashes('success') %}
            <div class="flash">{{ message|trans }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash flash-error">{{ message|trans }}</div>
        {% endfor %}

        <header class="station-show-header">
            <div>
                <h1 class="page-title">{{ station.name }}</h1>
                <p class="muted section-lead">{{ station.streetName }}, {{ station.postalCode }} {{ station.city }}. {{ 'station.workflow_hub'|trans }}</p>
            </div>
            <div class="station-show-actions">
                <form class="favorite-toggle-form" method="post" action="{{ path('ui_station_toggle_favorite', {id: station.id.toString()}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('station_favorite_toggle_' ~ station.id.toString()) }}">
                    <input type="hidden" name="_redirect" value="{{ path('ui_station_show', {id: station.id.toString(), return_to: backToListUrl}) }}">
                    <button class="btn {{ isFavorite ? 'btn-primary' : 'btn-secondary' }} favorite-toggle-btn" type="submit">
                        <span class="favorite-toggle-icon" aria-hidden="true">{{ isFavorite ? '★' : '☆' }}</span>
                        {{ isFavorite ? 'station.favorite_station'|trans : 'station.add_favorite'|trans }}
                    </button>
                </form>
                <a class="btn btn-secondary" href="{{ path('ui_receipt_new', {station_id: station.id.toString()}) }}">{{ 'receipt.form.action_create'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index', {station_id: station.id.toString()}) }}">{{ 'nav.receipts'|trans }}</a>
                <a class="btn btn-primary" href="{{ path('ui_analytics_dashboard', {station_id: station.id.toString()}) }}">{{ 'nav.analytics'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_station_edit', {id: station.id.toString(), redirect: path('ui_station_show', {id: station.id.toString(), return_to: backToListUrl})}) }}">{{ 'action.edit'|trans }}</a>
                <a class="btn btn-secondary" href="{{ backToListUrl }}">{{ 'common.back'|trans }}</a>
            </div>
        </header>

        <section class="station-kpi-grid">
            <article class="card-subtle station-kpi-card">
                <div class="station-kpi-label">{{ 'station.receipts_tracked'|trans }}</div>
                <div class="station-kpi-value">{{ receiptCount }}</div>
            </article>
            <article class="card-subtle station-kpi-card">
                <div class="station-kpi-label">{{ 'station.latest_visit'|trans }}</div>
                <div class="station-kpi-value">
                    {% if latestReceipt %}
                        {{ latestReceipt.issuedAt|date('d/m/Y') }}
                    {% else %}
                        {{ 'common.na'|trans }}
                    {% endif %}
                </div>
            </article>
            <article class="card-subtle station-kpi-card">
                <div class="station-kpi-label">{{ 'station.recent_spend_snapshot'|trans }}</div>
                <div class="station-kpi-value">{{ (recentFuelSpendCents / 100)|number_format(2, '.', ' ') }} EUR</div>
            </article>
        </section>

        <section class="station-grid">
            <section class="card station-panel">
                <div class="station-panel-head">
                    <h2>{{ 'station.latest_receipts'|trans }}</h2>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {station_id: station.id.toString()}) }}">{{ 'nav.receipts'|trans }}</a>
                </div>
                {% if receiptRows is not empty %}
                    <div class="station-list">
                        {% for row in receiptRows %}
                            <article class="card-subtle station-item">
                                <div class="station-item-title">
                                    <strong>{{ row.issuedAt|date('d/m/Y H:i') }}</strong>
                                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_show', {id: row.id, return_to: path('ui_station_show', {id: station.id.toString(), return_to: backToListUrl})}) }}">{{ 'receipt.action.open'|trans }}</a>
                                </div>
                                <div class="station-item-meta">
                                    <span>{{ 'analytics.chart_total_label'|trans }}: {{ (row.totalCents / 100)|number_format(2, '.', ' ') }} EUR</span>
                                    {% if row.odometerKilometers is not null %}<span>{{ row.odometerKilometers }} km</span>{% endif %}
                                    {% if row.fuelType %}<span>{{ row.fuelType|upper }}</span>{% endif %}
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="station-empty">
                        <p>{{ 'station.no_receipts_yet'|trans }}</p>
                        <div class="actions-wrap">
                            <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_new', {station_id: station.id.toString()}) }}">{{ 'station.empty_action_add_receipt'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_import_index') }}">{{ 'station.empty_action_open_imports'|trans }}</a>
                        </div>
                    </div>
                {% endif %}
            </section>

            <aside class="card station-panel">
                <div class="station-panel-head">
                    <h2>{{ 'station.station_context'|trans }}</h2>
                </div>
                <div class="station-favorite-summary">
                    <span class="pill favorite-pill">{{ isFavorite ? 'station.favorite_station'|trans : 'station.not_in_favorites'|trans }}</span>
                    {% if isFavorite %}
                        <span class="muted compact-note">{{ 'station.favorite_hint'|trans }}</span>
                    {% endif %}
                </div>
                <div class="station-item-sub">{{ station.streetName }}</div>
                <div class="station-item-sub">{{ station.postalCode }} {{ station.city }}</div>
                {% if latestOdometer is not null %}
                    <div class="station-item-meta">
                        <span>{{ 'station.latest_odometer_seen'|trans({'%odometer%': latestOdometer}) }}</span>
                    </div>
                {% endif %}
                <div class="actions-wrap">
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_new', {station_id: station.id.toString()}) }}">{{ 'receipt.form.action_create'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {station_id: station.id.toString()}) }}">{{ 'station.receipt_timeline'|trans }}</a>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {station_id: station.id.toString()}) }}">{{ 'nav.analytics'|trans }}</a>
                </div>
            </aside>
        </section>

        <section class="card station-panel">
            <div class="station-panel-head">
                <div>
                    <h2>{{ 'station.public_candidates'|trans }}</h2>
                    <p class="muted compact-note">{{ 'station.public_candidates_lead'|trans }}</p>
                </div>
                <a class="btn btn-secondary btn-compact" href="{{ path('ui_public_fuel_station_map', {q: station.postalCode, available: '1'}) }}">{{ 'station.open_fuel_map'|trans }}</a>
            </div>

            {% if publicStationCandidates is not empty %}
                <div class="station-list">
                    {% for candidate in publicStationCandidates %}
                        <article class="card-subtle station-public-match">
                            <div class="station-public-match-head">
                                <div>
                                    <strong>{{ candidate.city }}</strong>
                                    <div class="muted compact-note">{{ candidate.postalCode }} · {{ candidate.address }}</div>
                                </div>
                                <span class="pill">{{ candidate.confidence }}</span>
                            </div>
                            <div class="station-item-meta">
                                <span>{{ 'station.public_id'|trans({'%id%': candidate.sourceId}) }}</span>
                                {% if candidate.distanceMeters is not null %}<span>{{ 'station.distance_away'|trans({'%distance%': candidate.distanceMeters}) }}</span>{% endif %}
                            </div>
                            <div class="station-public-fuels">
                                {% for fuel, snapshot in candidate.fuels %}
                                    {% if snapshot.priceMilliEurosPerLiter is defined and snapshot.priceMilliEurosPerLiter %}
                                        <span class="station-public-fuel-pill {{ snapshot.available ? 'is-available' : '' }}">
                                            {{ fuel|upper }} {{ (snapshot.priceMilliEurosPerLiter / 1000)|number_format(3, '.', ' ') }} EUR/L
                                        </span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <div class="station-empty">{{ 'station.no_public_candidate'|trans }}</div>
            {% endif %}
        </section>
    </main>
{% endblock %}
