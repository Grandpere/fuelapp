{% extends 'base.html.twig' %}

{% block title %}{% if isEdit %}{{ 'vehicle.form.title_edit'|trans }}{% else %}{{ 'vehicle.form.title_new'|trans }}{% endif %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .vehicle-form-page {
            max-width: 760px;
            margin: 0 auto;
            display: grid;
            gap: 1rem;
        }

        .vehicle-form-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: start;
            gap: 0.8rem;
        }

        .vehicle-form-card {
            padding: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell vehicle-form-page">
        <header class="vehicle-form-header">
            <div class="page-header">
                <h1 class="page-title">{% if isEdit %}{{ 'vehicle.form.title_edit'|trans }}{% else %}{{ 'vehicle.form.title_new'|trans }}{% endif %}</h1>
                <p class="muted section-lead">{% if isEdit %}{{ 'vehicle.form.lead_edit'|trans }}{% else %}{{ 'vehicle.form.lead_new'|trans }}{% endif %}</p>
            </div>
            <a class="btn btn-secondary" href="{{ backToListUrl }}" data-turbo-frame="_top">{{ 'common.back'|trans }}</a>
        </header>

        <section class="card vehicle-form-card">
            {% if errors is not empty %}
                <div class="flash flash-error">
                    <ul class="flash-list">
                        {% for error in errors %}
                            <li>{{ error|trans }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <form method="post" action="" data-turbo-frame="_top" class="form-stack">
                <input type="hidden" name="_token" value="{{ csrfToken }}">
                <input type="hidden" name="_return_to" value="{{ backToListUrl }}">
                <label class="label">
                    {{ 'vehicle.form.name'|trans }}
                    <input class="input" type="text" name="name" maxlength="120" value="{{ formData.name }}" required>
                </label>
                <label class="label">
                    {{ 'vehicle.form.plate_number'|trans }}
                    <input class="input" type="text" name="plateNumber" maxlength="40" value="{{ formData.plateNumber }}" required>
                </label>

                <div class="actions-wrap">
                    <button class="btn btn-primary" type="submit">{% if isEdit %}{{ 'vehicle.form.action_save'|trans }}{% else %}{{ 'vehicle.form.action_create'|trans }}{% endif %}</button>
                    <a class="btn btn-secondary" href="{{ backToListUrl }}" data-turbo-frame="_top">{{ 'action.cancel'|trans }}</a>
                </div>
            </form>
        </section>
    </main>
{% endblock %}
