{% extends 'base.html.twig' %}

{% block title %}{{ 'vehicle.index.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .vehicles-page {
            display: grid;
            gap: 1rem;
        }

        .vehicles-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .vehicles-header p {
            margin: 0.35rem 0 0;
        }

        .panel {
            padding: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell vehicles-page">
        <section class="vehicles-header">
            <div>
                <h1 class="page-title">{{ 'vehicle.index.title'|trans }}</h1>
                <p class="muted">{{ 'vehicle.index.lead'|trans }}</p>
            </div>
            <div class="page-actions">
                <a class="btn btn-secondary" href="{{ path('ui_station_list') }}">{{ 'nav.stations'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_index') }}">{{ 'nav.maintenance'|trans }}</a>
                <a class="btn btn-primary" href="{{ path('ui_vehicle_new') }}">{{ 'vehicle.index.add'|trans }}</a>
            </div>
        </section>

        {% for message in app.flashes('success') %}
            <div class="flash">{{ message }}</div>
        {% endfor %}

        <section class="card panel">
            <div class="table-wrap table-min-760">
                <table class="app-table">
                    <thead>
                    <tr>
                        <th>{{ 'vehicle.index.col_name'|trans }}</th>
                        <th>{{ 'vehicle.index.col_plate'|trans }}</th>
                        <th>{{ 'vehicle.index.col_updated'|trans }}</th>
                        <th>{{ 'common.actions'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for vehicle in vehicles %}
                        {% set vehicleShowUrl = path('ui_vehicle_show', {id: vehicle.id.toString}) %}
                        {% set vehicleListUrl = path('ui_vehicle_list') %}
                        <tr
                            class="table-row row-link"
                            data-controller="row-link"
                            data-action="click->row-link#navigate"
                            data-row-link-url-value="{{ vehicleShowUrl }}"
                            onclick="if (!event.target.closest('a,button,input,form,select,textarea,label,[data-row-link-ignore]')) { window.location.assign(this.getAttribute('data-row-link-url-value')); }"
                        >
                            <td>{{ vehicle.name }}</td>
                            <td>{{ vehicle.plateNumber }}</td>
                            <td>{{ vehicle.updatedAt|date('Y-m-d H:i') }}</td>
                            <td class="action-cell-flex">
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {vehicle_id: vehicle.id.toString}) }}" data-row-link-ignore>{{ 'nav.receipts'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString}) }}" data-row-link-ignore>{{ 'nav.maintenance'|trans }}</a>
                                <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_new', {vehicle_id: vehicle.id.toString}) }}" data-row-link-ignore>{{ 'receipt.form.action_create'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ vehicleShowUrl }}" data-row-link-ignore>{{ 'action.open'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_vehicle_edit', {id: vehicle.id.toString, return_to: vehicleListUrl}) }}" data-row-link-ignore>{{ 'action.edit'|trans }}</a>
                                <form method="post" action="{{ path('ui_vehicle_delete', {id: vehicle.id.toString}) }}" onsubmit="return confirm('{{ 'vehicle.index.confirm_delete'|trans|e('js') }}');" data-row-link-ignore>
                                    <input type="hidden" name="_token" value="{{ csrf_token('vehicle_delete_' ~ vehicle.id.toString) }}">
                                    <button class="btn btn-danger btn-compact" type="submit">{{ 'action.delete'|trans }}</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="muted">{{ 'vehicle.index.empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
