{% extends 'base.html.twig' %}

{% block title %}{{ vehicle.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .vehicle-show-page {
            max-width: 1180px;
            margin: 0 auto;
            display: grid;
            gap: 1rem;
        }

        .vehicle-show-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .vehicle-show-header p {
            margin: 0.35rem 0 0;
        }

        .vehicle-show-actions {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .vehicle-kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.8rem;
        }

        .vehicle-kpi-card {
            padding: 0.95rem;
        }

        .vehicle-kpi-label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--text-soft);
        }

        .vehicle-kpi-value {
            margin-top: 0.3rem;
            font-size: 1.18rem;
            font-weight: 700;
            font-family: var(--font-display);
        }

        .vehicle-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.95fr);
            gap: 1rem;
            align-items: start;
        }

        .vehicle-insights {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.8rem;
        }

        .vehicle-insight {
            padding: 0.95rem;
            display: grid;
            gap: 0.45rem;
        }

        .vehicle-insight h2 {
            margin: 0;
            font-size: 1rem;
        }

        .vehicle-panel {
            padding: 1rem;
            display: grid;
            gap: 0.9rem;
        }

        .vehicle-panel-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .vehicle-panel-head h2 {
            margin: 0;
            font-size: 1.06rem;
        }

        .vehicle-list {
            display: grid;
            gap: 0.7rem;
        }

        .vehicle-item {
            padding: 0.85rem;
            display: grid;
            gap: 0.45rem;
        }

        .vehicle-item-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.65rem;
            flex-wrap: wrap;
        }

        .vehicle-item-sub,
        .vehicle-item-meta {
            color: var(--text-soft);
            font-size: 0.84rem;
        }

        .vehicle-item-meta {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .vehicle-empty {
            padding: 0.85rem;
            border: 1px dashed var(--table-wrap-border);
            border-radius: 10px;
            color: var(--text-soft);
        }

        @media (max-width: 1100px) {
            .vehicle-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 900px) {
            .vehicle-kpi-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .vehicle-insights {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 700px) {
            .vehicle-kpi-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="app-shell vehicle-show-page">
        <header class="vehicle-show-header">
            <div>
                <h1 class="page-title">{{ vehicle.name }}</h1>
                <p class="muted section-lead">{{ 'vehicle.show.lead'|trans({'%plate%': vehicle.plateNumber}) }}</p>
            </div>
            <div class="vehicle-show-actions">
                <a class="btn btn-secondary" href="{{ path('ui_receipt_new', {vehicle_id: vehicle.id.toString()}) }}">{{ 'receipt.form.action_create'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_receipt_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'nav.receipts'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'nav.maintenance'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_maintenance_plan_new', {vehicle_id: vehicle.id.toString()}) }}">{{ 'maintenance.plan_form.title_new'|trans }}</a>
                <a class="btn btn-primary" href="{{ path('ui_maintenance_event_new', {vehicle_id: vehicle.id.toString()}) }}">{{ 'maintenance.event_form.title_new'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_vehicle_edit', {id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'vehicle.form.title_edit'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('ui_vehicle_list') }}">{{ 'action.back_to_list'|trans }}</a>
            </div>
        </header>

        <section class="vehicle-kpi-grid">
            <article class="card-subtle vehicle-kpi-card">
                <div class="vehicle-kpi-label">{{ 'vehicle.show.receipts_tracked'|trans }}</div>
                <div class="vehicle-kpi-value">{{ receiptCount }}</div>
            </article>
            <article class="card-subtle vehicle-kpi-card">
                <div class="vehicle-kpi-label">{{ 'vehicle.show.maintenance_events'|trans }}</div>
                <div class="vehicle-kpi-value">{{ maintenanceEventCount }}</div>
            </article>
            <article class="card-subtle vehicle-kpi-card">
                <div class="vehicle-kpi-label">{{ 'vehicle.show.upcoming_plans'|trans }}</div>
                <div class="vehicle-kpi-value">{{ upcomingMaintenancePlanCount }}</div>
            </article>
            <article class="card-subtle vehicle-kpi-card">
                <div class="vehicle-kpi-label">{{ 'vehicle.show.latest_odometer_seen'|trans }}</div>
                <div class="vehicle-kpi-value">{{ latestReceiptOdometer ?? latestMaintenanceOdometer ?? ('common.na'|trans) }}{% if latestReceiptOdometer is not null or latestMaintenanceOdometer is not null %} km{% endif %}</div>
            </article>
        </section>

        <section class="vehicle-insights">
            <article class="card vehicle-insight">
                <h2>{{ 'vehicle.show.latest_fuel_snapshot'|trans }}</h2>
                {% if latestReceipt %}
                    <div class="vehicle-item-sub">{{ latestReceipt.issuedAt|date('d/m/Y H:i') }}</div>
                    <div class="vehicle-item-meta">
                        <span>{{ 'vehicle.show.total'|trans }}: {{ (latestReceipt.totalCents / 100)|number_format(2, '.', ' ') }} EUR</span>
                        {% if latestReceipt.stationName %}<span>{{ latestReceipt.stationName }}</span>{% endif %}
                    </div>
                    <div class="actions-wrap">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_show', {id: latestReceipt.id, return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'receipt.action.open'|trans }}</a>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_edit_metadata', {id: latestReceipt.id, return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'receipt.action.edit_details'|trans }}</a>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'vehicle.show.all_receipts'|trans }}</a>
                    </div>
                {% else %}
                    <div class="vehicle-empty">{{ 'vehicle.show.no_receipt_yet'|trans }}</div>
                {% endif %}
            </article>

            <article class="card vehicle-insight">
                <h2>{{ 'vehicle.show.maintenance_watch'|trans }}</h2>
                {% if nextMaintenancePlan %}
                    <div class="vehicle-item-sub">{{ 'vehicle.show.next_plan'|trans({'%label%': nextMaintenancePlan.label}) }}</div>
                    <div class="vehicle-item-meta">
                        <span>{{ nextMaintenancePlan.plannedFor|date('d/m/Y') }}</span>
                        <span>{{ 'vehicle.show.budget'|trans({'%amount%': (nextMaintenancePlan.plannedCostCents / 100)|number_format(2, '.', ' '), '%currency%': nextMaintenancePlan.currencyCode}) }}</span>
                    </div>
                    <div class="actions-wrap">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_plan_edit', {id: nextMaintenancePlan.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'dashboard.edit_next_plan'|trans }}</a>
                        <a class="btn btn-primary btn-compact" href="{{ path('ui_maintenance_event_new', {vehicle_id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'maintenance_dashboard.log_event_now'|trans }}</a>
                    </div>
                {% elseif latestMaintenanceEvent %}
                    <div class="vehicle-item-sub">{{ 'vehicle.show.last_event'|trans({'%type%': latestMaintenanceEvent.eventType.value|upper}) }}</div>
                    <div class="vehicle-item-meta">
                        <span>{{ latestMaintenanceEvent.occurredAt|date('d/m/Y H:i') }}</span>
                        {% if latestMaintenanceEvent.totalCostCents is not null %}<span>{{ 'vehicle.show.cost'|trans({'%amount%': (latestMaintenanceEvent.totalCostCents / 100)|number_format(2, '.', ' '), '%currency%': latestMaintenanceEvent.currencyCode}) }}</span>{% endif %}
                    </div>
                    <div class="actions-wrap">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'analytics.open_maintenance'|trans }}</a>
                        <a class="btn btn-primary btn-compact" href="{{ path('ui_maintenance_event_new', {vehicle_id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'maintenance.event_form.title_new'|trans }}</a>
                    </div>
                {% else %}
                    <div class="vehicle-empty">
                        <p>{{ 'vehicle.show.no_maintenance_signal'|trans }}</p>
                        <div class="actions-wrap">
                            <a class="btn btn-primary btn-compact" href="{{ path('ui_maintenance_event_new', {vehicle_id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'vehicle.show.add_first_event'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_plan_new', {vehicle_id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'vehicle.show.add_first_plan'|trans }}</a>
                        </div>
                    </div>
                {% endif %}
            </article>

            <article class="card vehicle-insight">
                <h2>{{ 'vehicle.show.quick_attention'|trans }}</h2>
                {% if attentionSummary %}
                    <div class="vehicle-item-sub">{{ attentionSummary }}</div>
                    <div class="vehicle-item-meta">
                        <span>{{ 'vehicle.show.recent_fuel_spend'|trans({'%amount%': (fuelSpendTotalCents / 100)|number_format(2, '.', ' ')}) }}</span>
                        <span>{{ (receiptCount > 1 ? 'vehicle.show.receipt_count_plural' : 'vehicle.show.receipt_count')|trans({'%count%': receiptCount}) }}</span>
                    </div>
                    <div class="actions-wrap">
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_analytics_dashboard', {vehicle_id: vehicle.id.toString()}) }}">{{ 'nav.analytics'|trans }}</a>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'vehicle.show.vehicle_timeline'|trans }}</a>
                    </div>
                {% else %}
                    <div class="vehicle-empty">
                        <p>{{ 'vehicle.show.start_hint'|trans }}</p>
                        <div class="actions-wrap">
                            <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_new', {vehicle_id: vehicle.id.toString()}) }}">{{ 'receipt.form.action_create'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_event_new', {vehicle_id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'maintenance.event_form.title_new'|trans }}</a>
                        </div>
                    </div>
                {% endif %}
            </article>
        </section>

        <section class="vehicle-grid">
            <article class="card vehicle-panel">
                <div class="vehicle-panel-head">
                    <h2>{{ 'vehicle.show.recent_receipts'|trans }}</h2>
                    <a class="btn btn-secondary btn-compact" href="{{ path('ui_receipt_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'vehicle.show.open_filtered_list'|trans }}</a>
                </div>

                {% if receiptRows is empty %}
                    <div class="vehicle-empty">
                        <p>{{ 'vehicle.show.no_receipt_yet'|trans }}</p>
                        <div class="actions-wrap">
                            <a class="btn btn-primary btn-compact" href="{{ path('ui_receipt_new', {vehicle_id: vehicle.id.toString()}) }}">{{ 'receipt.form.action_create'|trans }}</a>
                            <a class="btn btn-secondary btn-compact" href="{{ path('ui_import_index') }}">{{ 'nav.imports'|trans }}</a>
                        </div>
                    </div>
                {% else %}
                    <div class="table-wrap table-min-740">
                        <table class="app-table">
                            <thead>
                                <tr>
                                    <th>{{ 'receipt.form.date'|trans }}</th>
                                    <th>{{ 'analytics.station'|trans }}</th>
                                    <th class="text-right">{{ 'maintenance.event_form.odometer'|trans }}</th>
                                    <th>{{ 'receipt.form.fuel_type'|trans }}</th>
                                    <th class="text-right">{{ 'analytics.total_cost'|trans }}</th>
                                    <th>{{ 'common.actions'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for receipt in receiptRows %}
                                    {% include 'receipt/_row.html.twig' with {
                                        receipt: receipt,
                                        redirectUrl: path('ui_vehicle_show', {id: vehicle.id.toString()}),
                                        visibleColumns: ['issued_at', 'station_name', 'odometer_kilometers', 'fuel_type', 'total_cents']
                                    } only %}
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </article>

            <div class="vehicle-list">
                <article class="card vehicle-panel">
                    <div class="vehicle-panel-head">
                        <h2>{{ 'vehicle.show.recent_maintenance_events'|trans }}</h2>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'analytics.open_maintenance'|trans }}</a>
                    </div>

                    {% if recentMaintenanceEvents is empty %}
                        <div class="vehicle-empty">
                            <p>{{ 'vehicle.show.no_maintenance_event_yet'|trans }}</p>
                            <div class="actions-wrap">
                                <a class="btn btn-primary btn-compact" href="{{ path('ui_maintenance_event_new', {vehicle_id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'vehicle.show.add_first_event'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_plan_new', {vehicle_id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'maintenance.plan_form.title_new'|trans }}</a>
                            </div>
                        </div>
                    {% else %}
                        <div class="vehicle-list">
                            {% for event in recentMaintenanceEvents %}
                                <div class="card-subtle vehicle-item">
                                    <div class="vehicle-item-title">
                                        <strong>{{ event.eventType.value|upper }}</strong>
                                        <span class="muted">{{ event.occurredAt|date('d/m/Y H:i') }}</span>
                                    </div>
                                    {% if event.description %}<div class="vehicle-item-sub">{{ event.description }}</div>{% endif %}
                                    <div class="vehicle-item-meta">
                                        {% if event.odometerKilometers is not null %}<span>{{ 'vehicle.show.odometer'|trans({'%odometer%': event.odometerKilometers}) }}</span>{% endif %}
                                        {% if event.totalCostCents is not null %}<span>{{ 'vehicle.show.cost'|trans({'%amount%': (event.totalCostCents / 100)|number_format(2, '.', ' '), '%currency%': event.currencyCode}) }}</span>{% endif %}
                                    </div>
                                    <div class="actions-wrap">
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_event_edit', {id: event.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'maintenance.event_form.title_edit'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'vehicle.show.vehicle_timeline'|trans }}</a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </article>

                <article class="card vehicle-panel">
                    <div class="vehicle-panel-head">
                        <h2>{{ 'vehicle.show.upcoming_maintenance_plans'|trans }}</h2>
                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_plan_new', {vehicle_id: vehicle.id.toString()}) }}">{{ 'maintenance.plan_form.title_new'|trans }}</a>
                    </div>

                    {% if upcomingMaintenancePlans is empty %}
                        <div class="vehicle-empty">
                            <p>{{ 'vehicle.show.no_upcoming_plan'|trans }}</p>
                            <div class="actions-wrap">
                                <a class="btn btn-primary btn-compact" href="{{ path('ui_maintenance_plan_new', {vehicle_id: vehicle.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'vehicle.show.add_first_plan'|trans }}</a>
                                <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'analytics.open_maintenance'|trans }}</a>
                            </div>
                        </div>
                    {% else %}
                        <div class="vehicle-list">
                            {% for plan in upcomingMaintenancePlans %}
                                <div class="card-subtle vehicle-item">
                                    <div class="vehicle-item-title">
                                        <strong>{{ plan.label }}</strong>
                                        <span class="muted">{{ plan.plannedFor|date('d/m/Y') }}</span>
                                    </div>
                                    <div class="vehicle-item-meta">
                                        {% if plan.eventType is not null %}<span>{{ plan.eventType.value|upper }}</span>{% endif %}
                                        <span>{{ 'vehicle.show.budget'|trans({'%amount%': (plan.plannedCostCents / 100)|number_format(2, '.', ' '), '%currency%': plan.currencyCode}) }}</span>
                                    </div>
                                    {% if plan.notes %}<div class="vehicle-item-sub">{{ plan.notes }}</div>{% endif %}
                                    <div class="actions-wrap">
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_plan_edit', {id: plan.id.toString(), return_to: path('ui_vehicle_show', {id: vehicle.id.toString()})}) }}">{{ 'maintenance.plan_form.title_edit'|trans }}</a>
                                        <a class="btn btn-secondary btn-compact" href="{{ path('ui_maintenance_index', {vehicle_id: vehicle.id.toString()}) }}">{{ 'vehicle.show.vehicle_timeline'|trans }}</a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </article>
            </div>
        </section>
    </main>
{% endblock %}
